---
import "../styles/global.css";

interface Props {
  titulo?: string;
  descripcion?: string;
}

const {
  titulo = "El Suelo",
  descripcion = "Di qué ves antes de que se acabe tu tiempo.",
} = Astro.props;

// URL canónica para Open Graph. En producción cogemos el host real;
// en build sin SITE configurado, usamos un default y el navegador
// resolverá relativo si es necesario.
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://el-suelo.app";
const ogImage = `${siteUrl}/og.png`;
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=DM+Sans:wght@400;500;700&family=Barlow+Condensed:wght@400;600;700;900&display=swap"
      rel="stylesheet"
    />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#050c1e" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="El Suelo" />
    <link rel="apple-touch-icon" href="/el-suelo-icon.svg" />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />

    {/* Open Graph (Facebook/WhatsApp/LinkedIn/Discord) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="El Suelo" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="El Suelo — juego de adivinanza por voz" />
    <meta property="og:locale" content="es_ES" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="min-h-screen">
    <slot />
    <!-- Vercel Web Analytics (script ligero, sin cookies) -->
    <script defer src="/_vercel/insights/script.js"></script>
  </body>
</html>
