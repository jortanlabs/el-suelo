---
import "../styles/global.css";

interface Props {
  titulo?: string;
  descripcion?: string;
}

const {
  titulo = "El Suelo",
  descripcion = "Di qué ves antes de que se acabe tu tiempo.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=DM+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#050c1e" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="El Suelo" />
    <link rel="apple-touch-icon" href="/el-suelo-icon.svg" />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
