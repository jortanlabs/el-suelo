---
import Base from "../layouts/Base.astro";
import { subcategorias } from "../data/catalogoCine.ts";
import { subcategoriasMundo, bloquesMundo } from "../data/catalogoMundo.ts";
// Todos los slugs disponibles — el filtro por "publicadas" ocurre en runtime
const cineSlugsNombres: Record<string, string> = Object.fromEntries(
  subcategorias
    .filter((s) => !s.esMetaCategoria && !s.derivadoDe && !!s.nombres && !s.pendiente)
    .map((s) => [s.slug, s.nombre])
);

const cineSlugsDerivados: Record<string, { baseSlug: string }> = {};
for (const s of subcategorias) {
  if (s.derivadoDe && s.modoDerivado === "pelicula") {
    cineSlugsDerivados[s.slug] = { baseSlug: s.derivadoDe };
    cineSlugsNombres[s.slug] = s.nombre;
  }
}

const cineSlugsMetaMezcla: Record<string, string[]> = {};
for (const s of subcategorias) {
  if (!s.esMetaCategoria && s.subcategorias?.length && !s.derivadoDe && !s.pendiente) {
    cineSlugsMetaMezcla[s.slug] = s.subcategorias;
    cineSlugsNombres[s.slug] = s.nombre;
  }
}

const mundoSlugsNombres: Record<string, string> = Object.fromEntries(
  subcategoriasMundo
    .filter((s) => !s.esMetaCategoria && !!s.nombres)
    .map((s) => [s.slug, s.nombre])
);

const DEPORTES_B2 = new Set(["futbol", "baloncesto", "tenis", "golf", "ciclismo", "motor", "multideporte"]);
const ARTE_B2 = new Set(["musica", "arte", "literatura", "teatro", "moda"]);
const MARCAS_B2 = new Set(["compras"]);
const PERSONAS_B2 = new Set(["personas"]);
const mundoSlugsGrupo: Record<string, string> = Object.fromEntries(
  subcategoriasMundo
    .filter((s) => !s.esMetaCategoria && !!s.nombres)
    .map((s) => {
      let grupo = "mundo";
      if (DEPORTES_B2.has(s.bloque)) grupo = "deportes";
      else if (ARTE_B2.has(s.bloque)) grupo = "arte";
      else if (MARCAS_B2.has(s.bloque)) grupo = "compras";
      else if (PERSONAS_B2.has(s.bloque)) grupo = "personas";
      return [s.slug, grupo];
    })
);

const bloqueEmojiMap: Record<string, string> = Object.fromEntries(
  bloquesMundo.map((b) => [b.slug, b.emoji])
);
const mundoSlugsEmoji: Record<string, string> = Object.fromEntries(
  subcategoriasMundo
    .filter((s) => !s.esMetaCategoria && !!s.nombres)
    .map((s) => [s.slug, bloqueEmojiMap[s.bloque] ?? "🌍"])
);

// Mapa combinado slug → nombre (para el JS)
const todasSlugsNombres: Record<string, string> = { ...cineSlugsNombres, ...mundoSlugsNombres };

// Slugs marcados como aptos para el modo infantil
const slugsInfantiles: string[] = [
  ...subcategorias.filter((s) => s.paraNinos && !!s.nombres && !s.esMetaCategoria).map((s) => s.slug),
  ...subcategoriasMundo.filter((s) => s.paraNinos && !!s.nombres && !s.esMetaCategoria).map((s) => s.slug),
];

// La key de Pusher es pública por diseño (acaba en el JS del cliente). El
// secret real es PUSHER_SECRET, server-side en /api/pusher-auth.
const pusherKey = import.meta.env.PUBLIC_PUSHER_KEY || "d8b48a4d7d6cb146cf1e";
const pusherCluster = import.meta.env.PUBLIC_PUSHER_CLUSTER || "eu";
---

<Base titulo="El Suelo — Crear sala" descripcion="Crea una sala y juega El Suelo de 2 a 4 jugadores, cada uno desde su móvil.">
  <div id="datos-cine-nombres" data-json={JSON.stringify(todasSlugsNombres)} class="hidden"></div>
  <div id="datos-cine-derivados" data-json={JSON.stringify(cineSlugsDerivados)} class="hidden"></div>
  <div id="datos-cine-mezcla" data-json={JSON.stringify(cineSlugsMetaMezcla)} class="hidden"></div>
  <div id="datos-infantiles" data-json={JSON.stringify(slugsInfantiles)} class="hidden"></div>
  <div id="datos-mundo-slugs" data-json={JSON.stringify(Object.keys(mundoSlugsNombres))} class="hidden"></div>
  <div id="datos-mundo-grupo" data-json={JSON.stringify(mundoSlugsGrupo)} class="hidden"></div>
  <div id="datos-mundo-emoji" data-json={JSON.stringify(mundoSlugsEmoji)} class="hidden"></div>
  <main id="floor-root" class="h-dvh flex flex-col overflow-hidden">
    <nav class="px-4 pb-3 flex items-center border-b-2 border-[#2a5090] shrink-0" style="padding-top: max(0.75rem, env(safe-area-inset-top))">
      <button id="boton-volver" class="font-titulo text-lg font-bold text-[#a8c5ff] hover:text-[#e8e8ff] transition py-1 px-2" aria-label="Volver atrás">← Volver</button>
    </nav>

    <!-- ENTRADA: elegir acción -->
    <section id="pantalla-entrada" class="flex-1 flex flex-col items-center justify-center px-6 gap-8 overflow-y-auto">
      <div class="text-center">
        <div class="inline-block relative px-10 py-3 mb-2">
          <span class="floor-corner floor-corner-tl"></span><span class="floor-corner floor-corner-tr"></span>
          <span class="floor-corner floor-corner-bl"></span><span class="floor-corner floor-corner-br"></span>
          <h1 class="font-titulo text-4xl font-bold neon-gold uppercase tracking-[0.25em]">El suelo</h1>
        </div>
        <p class="text-[#a8c5ff] font-titulo text-sm">📱 Salas de 2 a 4 jugadores</p>
      </div>
      <div class="w-full max-w-xs flex flex-col gap-4">
        <button id="boton-ir-crear" class="floor-btn floor-btn-a w-full font-titulo font-bold text-2xl py-6 uppercase">➕ Crear sala</button>
        <p class="text-sm text-[#a8c5ff] font-titulo text-center -mt-2">Invitas tú. Los demás entran con un código.</p>
        <button id="boton-ir-unirse" class="floor-btn floor-btn-gold w-full font-titulo font-bold text-2xl py-6 uppercase">🚪 Unirme</button>
        <p class="text-sm text-[#a8c5ff] font-titulo text-center -mt-2">Te han pasado un código de sala.</p>
      </div>
    </section>

    <!-- CREAR SALA: nombre -->
    <section id="pantalla-crear" class="flex-1 flex flex-col items-center justify-center px-6 gap-6 hidden">
      <h2 class="font-titulo text-3xl font-bold text-[#ffcc00] uppercase tracking-wider text-center">Crear sala</h2>
      <div class="w-full max-w-xs flex flex-col gap-4">
        <div>
          <label class="font-titulo text-base font-bold text-[#e8e8ff] block mb-2 text-center">¿Cómo te llamas?</label>
          <input id="nombre-crear" type="text" placeholder="Tu nombre" maxlength="20" class="floor-input text-center text-lg py-3" autocomplete="off" />
        </div>
        <button id="boton-crear" class="floor-btn floor-btn-a w-full font-titulo font-bold text-xl py-4">Crear sala →</button>
        <p id="error-crear" class="hidden text-sm text-[#ff1dce] text-center font-bold font-titulo"></p>
      </div>
    </section>

    <!-- UNIRSE: nombre + código -->
    <section id="pantalla-unirse" class="flex-1 flex flex-col items-center justify-center px-6 gap-6 hidden">
      <h2 class="font-titulo text-3xl font-bold text-[#ffcc00] uppercase tracking-wider text-center">Unirte a sala</h2>
      <div class="w-full max-w-xs flex flex-col gap-4">
        <div>
          <label class="font-titulo text-base font-bold text-[#e8e8ff] block mb-2 text-center">¿Cómo te llamas?</label>
          <input id="nombre-unirse" type="text" placeholder="Tu nombre" maxlength="20" class="floor-input text-center text-lg py-3" autocomplete="off" />
        </div>
        <div>
          <label class="font-titulo text-base font-bold text-[#e8e8ff] block mb-2 text-center">Código de sala</label>
          <input id="codigo-sala" type="text" placeholder="ABCDEF" maxlength="6" class="floor-input text-center text-2xl uppercase tracking-widest font-bold py-3" autocomplete="off" />
        </div>
        <button id="boton-unirse" class="floor-btn floor-btn-gold w-full font-titulo font-bold text-xl py-4">Unirme →</button>
        <p id="error-unirse" class="hidden text-sm text-[#ff1dce] text-center font-bold font-titulo"></p>
      </div>
    </section>

    <!-- SALA (lobby) -->
    <section id="pantalla-sala" class="flex-1 flex flex-col items-center justify-center px-6 gap-5 hidden">
      <div class="floor-card p-6 w-full max-w-xs text-center">
        <p class="text-[#a8c5ff] font-titulo text-sm uppercase tracking-widest mb-2">Código de sala</p>
        <p id="sala-codigo" class="font-titulo text-5xl font-bold neon-gold tracking-[0.2em] mb-5"></p>
        <div id="sala-slots" class="space-y-2 text-left"></div>
      </div>
      <button id="boton-sala-jugar" class="floor-btn floor-btn-gold w-full max-w-xs font-titulo font-bold text-xl py-4 hidden">Elegir modo →</button>
      <button id="boton-compartir" class="floor-btn w-full max-w-xs font-titulo font-bold text-base py-3" style="color:#a8c5ff;border-color:#2a5090;">📤 Compartir código</button>
      <p id="sala-info" class="text-[#a8c5ff] font-titulo text-sm text-center leading-relaxed">Comparte el código.<br>Pueden entrar hasta 3 jugadores más.</p>
    </section>

    <!-- SETUP (host) -->
    <section id="pantalla-setup" class="flex-1 overflow-y-auto px-4 py-5 hidden flex flex-col items-center justify-center">
      <div class="max-w-md w-full mx-auto">
        <div class="floor-card p-5 space-y-5">
          <div>
            <label class="font-titulo font-bold text-[#a8c5ff] text-sm block mb-2 uppercase tracking-widest">Modo</label>
            <div class="flex gap-2">
              <button id="modo-rapida" class="floor-btn flex-1 px-3 py-3 text-base font-titulo text-[#a8c5ff]" style="border-color:#a8c5ff">⚡ Rápida</button>
              <button id="modo-tablero" class="floor-btn flex-1 px-3 py-3 text-base font-titulo text-[#a8c5ff]" style="border-color:#a8c5ff">🏁 Tablero</button>
            </div>
          </div>
          <div id="seccion-categoria" class="hidden">
            <label class="font-titulo font-bold text-[#a8c5ff] text-sm block mb-2 uppercase tracking-widest">Categoría</label>
            <div class="grid grid-cols-3 gap-2">
              <button id="cat-cine" class="floor-btn px-2 py-2.5 text-sm font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🎬<br>Cine y Series</button>
              <button id="cat-mundo" class="floor-btn px-2 py-2.5 text-sm font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🌍<br>El Mundo</button>
              <button id="cat-deportes" class="floor-btn px-2 py-2.5 text-sm font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">⚽<br>Deportes</button>
              <button id="cat-arte" class="floor-btn px-2 py-2.5 text-sm font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🎨<br>Arte</button>
              <button id="cat-compras" class="floor-btn px-2 py-2.5 text-sm font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🛒<br>Compras</button>
              <button id="cat-personas" class="floor-btn px-2 py-2.5 text-sm font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🧑<br>Personas</button>
              <button id="cat-aleatorio" class="floor-btn floor-cat-selected col-span-3 px-2 py-2.5 text-base font-titulo leading-tight">🎲 Aleatorio</button>
              <button id="cat-infantil" class="floor-btn col-span-3 px-2 py-2.5 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🧒 Infantil</button>
            </div>
          </div>
          <div id="seccion-tablero" class="hidden">
            <label class="font-titulo font-bold text-[#a8c5ff] text-sm block mb-2 uppercase tracking-widest">¿Qué tablero?</label>
            <div class="grid grid-cols-2 gap-2">
              <button id="tab-adultos" class="floor-btn floor-cat-selected px-2 py-3 text-base font-titulo leading-tight">🎯 Adultos</button>
              <button id="tab-infantil" class="floor-btn px-2 py-3 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🧒 Infantil</button>
            </div>
          </div>
          <div class="flex gap-2">
            <button id="boton-empezar" class="floor-btn floor-btn-a flex-1 font-titulo font-bold text-xl px-6 py-4">¡A jugar! →</button>

          </div>
          <p id="error-setup" class="hidden text-sm text-[#ff1dce] text-center font-bold font-titulo"></p>
        </div>
      </div>
    </section>

    <!-- SETUP GUEST (waiting) -->
    <section id="pantalla-setup-guest" class="flex-1 flex flex-col items-center justify-center px-4 gap-3 hidden">
      <div class="text-5xl wiggle">⏳</div>
      <p class="font-titulo text-xl font-bold text-[#e8e8ff]">El anfitrión está eligiendo...</p>
      <p id="setup-guest-nombres" class="text-[#7b9ef5] font-titulo text-sm"></p>
    </section>

    <!-- LOADER -->
    <section id="pantalla-loader" class="flex-1 flex items-center justify-center px-4 hidden">
      <div class="text-center">
        <div class="text-6xl mb-4 wiggle inline-block">🔍</div>
        <p id="loader-cat-name" class="font-titulo text-xl font-bold text-[#ffcc00] mb-1"></p>
        <h2 class="font-titulo text-2xl font-bold text-[#e8e8ff] mb-2">Cargando imágenes...</h2>
        <p id="loader-progreso" class="text-[#7b9ef5] text-sm font-titulo">Un momento.</p>
      </div>
    </section>

    <!-- TABLERO -->
    <section id="pantalla-tablero" class="flex-1 flex flex-col overflow-hidden hidden relative" style="touch-action:none;overscroll-behavior:none">
      <div id="tablero-jugadores" class="px-2 py-2 flex items-center justify-center gap-1.5 flex-wrap border-b-2 border-[#163575] shrink-0"></div>
      <div class="flex-1 flex flex-col items-center justify-center px-4 py-4 min-h-0">
        <div id="tablero-grid" class="grid grid-cols-3 gap-3 w-full max-w-sm"></div>
      </div>
      <div class="px-4 py-3 text-center shrink-0">
        <p id="tablero-instruccion" class="font-titulo text-sm font-bold text-[#7b9ef5] uppercase tracking-wider"></p>
      </div>
      <div id="preduel-overlay" class="hidden absolute inset-0 flex flex-col items-center justify-center z-20 px-8" style="background:#07070fee">
        <p class="text-xs text-[#7b9ef5] font-titulo uppercase tracking-widest mb-2">Categoría del duelo</p>
        <div id="preduel-emoji" class="text-6xl my-2"></div>
        <p id="preduel-nombre-cat" class="font-titulo font-bold text-2xl text-[#e8e8ff] text-center mb-8"></p>
        <button id="preduel-empezar" class="floor-btn floor-btn-a font-titulo font-bold text-xl px-8 py-4 hidden">¡A jugar! →</button>
        <p id="preduel-espera" class="text-[#7b9ef5] font-titulo text-sm hidden">Esperando al jugador de turno...</p>
        <button id="preduel-volver" class="mt-4 font-titulo text-sm text-[#7b9ef5] hover:text-[#e8e8ff] transition-colors underline hidden">← Volver al tablero</button>
      </div>
    </section>

    <!-- JUEGO -->
    <section id="pantalla-juego" class="flex-1 flex flex-col hidden select-none min-h-0 overflow-hidden" style="touch-action:none;overscroll-behavior:none">
      <div class="flex-1 flex flex-col min-h-0 px-2 pt-2 pb-1 gap-1">
        <div id="jugadores-bar" class="flex gap-2 w-full max-w-sm mx-auto shrink-0"></div>
        <div class="flex-1 flex flex-col items-center min-w-0 min-h-0">
          <p id="juego-categoria-label" class="text-xl text-[#ffcc00] font-titulo text-center max-w-xs px-2 pt-1 font-bold uppercase tracking-wider leading-tight shrink-0"></p>
          <div class="flex-1 w-full flex flex-col items-center justify-center gap-2">
            <div class="w-full max-w-xs">
              <div class="floor-image-box">
                <img id="imagen-item" src="" alt="" class="absolute inset-0 w-full h-full object-contain hidden" />
                <span id="imagen-placeholder" class="absolute inset-0 flex items-center justify-center text-5xl text-[#163575] font-titulo font-bold text-center px-2">📷</span>
                <div id="overlay-acierto" class="floor-overlay-ok hidden">
                  <span class="font-titulo text-6xl font-bold text-[#07070f]">✓</span>
                  <span id="overlay-nombre" class="font-titulo text-sm font-bold text-[#07070f] mt-1 text-center px-2"></span>
                </div>
                <div id="overlay-pase" class="floor-overlay-pass hidden">
                  <span class="font-titulo text-2xl font-bold text-[#07070f]">Pasado →</span>
                  <span id="overlay-pase-nombre" class="font-titulo text-sm font-bold text-[#07070f] mt-1 text-center px-2"></span>
                </div>
              </div>
            </div>
            <p id="texto-voz" class="text-sm text-[#a8c5ff] font-titulo text-center max-w-xs px-2 min-h-[24px]"></p>
            <button id="boton-pasar" class="floor-btn floor-btn-gold font-titulo font-bold py-3 text-base w-full max-w-xs">Pasar (−3 s)</button>
          </div>
        </div>
      </div>
      <form id="chat-juego-bar-inline" class="hidden flex gap-2 px-3 py-2 border-t border-[#163575] shrink-0" style="background:rgba(9,23,40,0.92);padding-bottom:max(8px,env(safe-area-inset-bottom))">
        <input id="chat-juego-input" type="text" placeholder="💬 Mensaje a la sala..." class="floor-input flex-1 text-sm py-2" maxlength="200" autocomplete="off" />
        <button type="submit" class="floor-btn floor-btn-gold font-titulo font-bold px-3 text-base shrink-0">→</button>
      </form>
    </section>

    <!-- FINAL -->
    <section id="pantalla-final" class="flex-1 flex items-center justify-center px-4 py-8 hidden relative overflow-hidden">
      <div id="confeti" class="absolute inset-0 pointer-events-none"></div>
      <div class="max-w-sm w-full text-center relative z-10">
        <div class="text-7xl mb-4 flotar inline-block">🏆</div>
        <h1 class="font-titulo text-3xl font-bold text-[#e8e8ff] mb-2 uppercase tracking-widest">¡Partida terminada!</h1>
        <p id="texto-ganador" class="font-titulo text-2xl mb-6 neon-gold"></p>
        <div id="final-grid" class="grid grid-cols-2 gap-3 mb-8"></div>
        <div class="flex flex-col gap-3">
          <button id="boton-revancha" class="floor-btn floor-btn-gold font-titulo font-bold text-lg px-8 py-3">Revancha →</button>
          <button id="boton-menu-final" class="floor-btn floor-card-small text-[#7b9ef5] font-titulo font-bold text-base px-8 py-3 w-full">Volver al menú</button>
        </div>
      </div>
    </section>

    <!-- MODAL CONFIRMAR SALIDA -->
    <div id="modal-salir" class="hidden fixed inset-0 z-50 flex items-center justify-center px-6" style="background:rgba(5,12,30,0.94)">
      <div class="floor-card max-w-xs w-full p-5 text-center">
        <div class="text-4xl mb-2">⚠️</div>
        <h3 class="font-titulo font-bold text-lg text-[#ffcc00] uppercase tracking-wide mb-2">¿Salir de la sala?</h3>
        <p class="font-titulo text-sm text-[#e8e8ff] mb-4 leading-relaxed">Perderás el código y se desconectará a los demás jugadores.</p>
        <div class="flex gap-2">
          <button id="salir-cancelar" class="floor-btn floor-card-small text-[#7b9ef5] font-titulo font-bold text-sm px-4 py-2 flex-1">No, seguir</button>
          <button id="salir-confirmar" class="floor-btn floor-btn-a font-titulo font-bold text-sm px-4 py-2 flex-1">Sí, salir</button>
        </div>
      </div>
    </div>

    <!-- CHAT FLOATING (botón fuera de pJuego) -->
    <button id="chat-flot" class="hidden fixed bottom-4 right-4 z-30 w-12 h-12 rounded-full flex items-center justify-center text-2xl floor-btn floor-btn-gold" aria-label="Abrir chat">
      💬
      <span id="chat-badge" class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full bg-[#ff1dce] text-[10px] font-bold text-white flex items-center justify-center" style="box-shadow:0 0 8px #ff1dce">0</span>
    </button>

    <!-- Toasts del chat (durante duelo, encima del juego) -->
    <div id="chat-toasts" class="hidden fixed inset-x-0 z-30 px-3 flex flex-col gap-1.5 items-stretch pointer-events-none" style="bottom: calc(110px + env(safe-area-inset-bottom, 0px))"></div>

    <!-- CHAT OVERLAY completo (sala, tablero, etc.) -->
    <div id="chat-overlay" class="hidden fixed inset-x-0 bottom-0 z-40 flex flex-col floor-card border-t-2 border-x-0 border-b-0" style="background:#091728;max-height:75vh">
      <div class="flex items-center px-4 py-2 border-b border-[#163575]">
        <h3 class="font-titulo font-bold text-[#ffcc00] text-base flex-1">💬 Chat</h3>
        <button id="chat-cerrar" class="font-titulo text-sm text-[#7b9ef5] hover:text-[#e8e8ff]">✕ Cerrar</button>
      </div>
      <div id="chat-mensajes" class="flex-1 overflow-y-auto p-3 flex flex-col gap-2" style="min-height:30vh"></div>
      <form id="chat-form" class="flex gap-2 p-2 border-t border-[#163575]" style="padding-bottom:max(8px,env(safe-area-inset-bottom))">
        <input id="chat-input" type="text" placeholder="Escribe un mensaje..." class="floor-input flex-1" maxlength="200" autocomplete="off" />
        <button type="submit" class="floor-btn floor-btn-gold font-titulo font-bold px-4 text-lg">→</button>
      </form>
    </div>
  </main>
</Base>

<style>
  #floor-root {
    --a: #ff1dce; --b: #ffe100; --gold: #f5c518; --bg: #050c1e;
    --card: #091728; --border: #2a5090; --text: #e8f0ff; --dim: #7b9ef5;
    --ok: #00ff88; --font-titulo: 'Barlow Condensed', sans-serif;
    background: var(--bg);
    background-image: linear-gradient(rgba(30,80,200,.15) 1px,transparent 1px),linear-gradient(90deg,rgba(30,80,200,.15) 1px,transparent 1px);
    background-size: 52px 52px;
    color: var(--text);
    font-family: 'Barlow Condensed', sans-serif;
  }
  .neon-gold { color: var(--gold); text-shadow: 0 0 15px var(--gold); }
  .floor-btn { background:transparent;border:2px solid currentColor;border-radius:4px;font-weight:700;transition:all .15s;letter-spacing:.08em;text-transform:uppercase; }
  .floor-btn-a { color:var(--a)!important;border-color:var(--a)!important;box-shadow:0 0 12px color-mix(in srgb,var(--a) 50%,transparent); }
  .floor-btn-a:hover { background:color-mix(in srgb,var(--a) 15%,transparent); }
  .floor-btn-gold { color:var(--gold)!important;border-color:var(--gold)!important;box-shadow:0 0 12px color-mix(in srgb,var(--gold) 50%,transparent); }
  .floor-btn-gold:hover { background:color-mix(in srgb,var(--gold) 15%,transparent); }
  .floor-input { background:#050e20;border:2px solid var(--border);border-radius:4px;color:var(--text);padding:8px 16px;width:100%;outline:none;font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:1rem;letter-spacing:.04em;transition:border-color .2s; }
  .floor-input::placeholder { color:var(--dim); }
  .floor-input:focus { border-color:var(--gold); }
  .floor-card { background:var(--card);border:2px solid var(--border);border-radius:6px; }
  .floor-card-small { background:var(--card);border:1px solid var(--border);border-radius:4px; }
  .floor-image-box { border:2px solid var(--border);border-radius:6px;overflow:hidden;background:#050e20;aspect-ratio:1;position:relative;box-shadow:0 0 40px rgba(0,0,0,.8); }
  .floor-overlay-ok:not(.hidden) { position:absolute;inset:0;background:color-mix(in srgb,var(--ok) 88%,transparent);display:flex;flex-direction:column;align-items:center;justify-content:center; }
  .floor-overlay-pass:not(.hidden) { position:absolute;inset:0;background:color-mix(in srgb,var(--gold) 90%,transparent);display:flex;flex-direction:column;align-items:center;justify-content:center; }
  .floor-timer { text-shadow:0 0 20px currentColor; }
  .floor-timer-urgent { color: #ff3b3b !important; text-shadow: 0 0 24px #ff3b3b; }
  .floor-btn-urgent { color: #ff3b3b !important; border-color: #ff3b3b !important; box-shadow: 0 0 14px color-mix(in srgb, #ff3b3b 55%, transparent); }
  .floor-btn-urgent:hover { background: color-mix(in srgb, #ff3b3b 15%, transparent); }
  .floor-cat-selected { color:var(--gold)!important;border-color:var(--gold)!important; }
  .floor-corner { position:absolute;width:20px;height:20px; }
  .floor-corner-tl { top:0;left:0;border-top:4px solid var(--gold);border-left:4px solid var(--gold); }
  .floor-corner-tr { top:0;right:0;border-top:4px solid var(--gold);border-right:4px solid var(--gold); }
  .floor-corner-bl { bottom:0;left:0;border-bottom:4px solid var(--gold);border-left:4px solid var(--gold); }
  .floor-corner-br { bottom:0;right:0;border-bottom:4px solid var(--gold);border-right:4px solid var(--gold); }
  :global(.floor-square-neutral) { background:#0c1e48;border:2px solid #2a5285; }
  :global(.floor-square-p0) { background:#ff1dce;border:2px solid #ff80e8;box-shadow:0 0 24px #ff1dce; }
  :global(.floor-square-p1) { background:#ffe100;border:2px solid #fff380;box-shadow:0 0 24px #ffe100; }
  :global(.floor-square-p2) { background:#00ff88;border:2px solid #80ffc4;box-shadow:0 0 24px #00ff88; }
  :global(.floor-square-p3) { background:#00b3ff;border:2px solid #80d9ff;box-shadow:0 0 24px #00b3ff; }
  :global(.floor-square-attackable) { border:2px solid var(--gold)!important;box-shadow:0 0 12px var(--gold)!important;animation:floor-pulse-gold 1.4s ease-in-out infinite; }
  @keyframes floor-pulse-gold { 0%,100%{box-shadow:0 0 8px var(--gold)}50%{box-shadow:0 0 22px var(--gold)} }
  :global(body) { background:#050c1e!important; }
</style>

<script define:vars={{ pusherKey, pusherCluster }}>
  window.__PK__ = pusherKey;
  window.__PC__ = pusherCluster;
</script>

<script>
  import Pusher from "pusher-js";
  import type { Channel } from "pusher-js";
  import {
    cargarCatalogoCine, cargarCatalogoCinePeli,
    cargarCatalogoMundo, cargarMezclaCine, cargarPublicadas,
    type ItemFloor, crearReconocedor, navegadorSoportaVoz,
    type ReconocedorVoz, aciertoFlexible,
    barajar, poolSinRecientes, marcarRecientes,
  } from "../lib/floor-client.ts";

  const PUSHER_KEY = (window as any).__PK__ ?? "";
  const PUSHER_CLUSTER = (window as any).__PC__ ?? "eu";

  function trackEv(nombre: string, props?: Record<string, string | number | boolean>) {
    try {
      (window as unknown as { va?: (a: string, b: Record<string, unknown>) => void }).va?.("event", { name: nombre, ...(props ?? {}) });
    } catch {}
  }
  const cineSlugsNombres: Record<string, string> = JSON.parse(
    (document.getElementById("datos-cine-nombres") as HTMLElement).dataset.json!,
  );
  const cineSlugsDerivados: Record<string, { baseSlug: string }> = JSON.parse(
    (document.getElementById("datos-cine-derivados") as HTMLElement).dataset.json!,
  );
  const cineSlugsMetaMezcla: Record<string, string[]> = JSON.parse(
    (document.getElementById("datos-cine-mezcla") as HTMLElement).dataset.json!,
  );
  const mundoSlugsAll: string[] = JSON.parse(
    (document.getElementById("datos-mundo-slugs") as HTMLElement).dataset.json!,
  );
  const mundoSlugsGrupo: Record<string, string> = JSON.parse(
    (document.getElementById("datos-mundo-grupo") as HTMLElement).dataset.json!,
  );
  const mundoSlugsEmoji: Record<string, string> = JSON.parse(
    (document.getElementById("datos-mundo-emoji") as HTMLElement).dataset.json!,
  );

  function construirPool(pub: string[]): string[] {
    // Nota: en multi, cineSlugsNombres contiene cine + mundo (todasSlugsNombres),
    // así que el único bucle ya cubre ambos. No iterar mundoSlugsAll otra vez.
    const pool: string[] = [];
    for (const slug of Object.keys(cineSlugsNombres)) {
      const d = cineSlugsDerivados[slug];
      const m = cineSlugsMetaMezcla[slug];
      if (d) { if (pub.includes(d.baseSlug)) pool.push(slug); }
      else if (m) { if (m.every((s) => pub.includes(s))) pool.push(slug); }
      else if (pub.includes(slug)) pool.push(slug);
    }
    return pool;
  }

  // ── DOM ────────────────────────────────────────────────────
  const $ = (id: string) => document.getElementById(id)!;
  const pEntrada = $("pantalla-entrada");
  const pCrear = $("pantalla-crear");
  const pUnirse = $("pantalla-unirse");
  const pSala = $("pantalla-sala");
  const pSetup = $("pantalla-setup");
  const pSetupGuest = $("pantalla-setup-guest");
  const pLoader = $("pantalla-loader");
  const pTablero = $("pantalla-tablero");
  const pJuego = $("pantalla-juego");
  const pFinal = $("pantalla-final");
  const PANTALLAS = [pEntrada, pCrear, pUnirse, pSala, pSetup, pSetupGuest, pLoader, pTablero, pJuego, pFinal];
  // Pantallas en las que se muestra el botón de chat (todas menos entrada y final)
  const _PANTALLAS_CHAT = [pSala, pSetup, pSetupGuest, pLoader, pTablero, pJuego];

  function mostrar(p: HTMLElement) {
    PANTALLAS.forEach((s) => s.classList.add("hidden"));
    p.classList.remove("hidden");
    actualizarBotonChat();
  }

  // ── Estado global ──────────────────────────────────────────
  // Color de cada jugador por índice (rosa, amarillo, verde, azul)
  const COLORES = ["#ff1dce", "#ffe100", "#00ff88", "#00b3ff"];
  const DECIMAS_INICIO = 300; // 30 s por jugador
  const MAX_JUGADORES = 4;

  interface JugadorNet {
    nombre: string;
    decimas: number;
    eliminado: boolean;
    uid?: string; // solo lo conoce el host; no viaja en los sync
  }

  let canal: Channel | null = null;
  let rol: "host" | "guest" = "host";
  // Posición de este móvil en la lista de jugadores (host = 0; el guest la
  // recibe en client-asignado tras el handshake de unión).
  let miIndice = 0;
  let miNombre = "";
  const uidPropio = Math.random().toString(36).slice(2, 10) + Math.random().toString(36).slice(2, 8);
  let codigo = "";
  let jugadores: JugadorNet[] = [];
  let ordenEliminacion: number[] = [];
  let partidaEnCurso = false; // a true, no se aceptan uniones nuevas
  let modo: "rapida" | "tablero" = "rapida";
  let categoriaSlug = "";
  let turno = 0;
  let timestampTurno = 0;
  let indice = 0;
  let items: ItemFloor[] = [];
  let categoriaActual = "";
  let bloqueado = false;
  let terminado = false;
  let reco: ReconocedorVoz | null = null;
  let gameTimeout: ReturnType<typeof setTimeout> | null = null;
  let renderInt: ReturnType<typeof setInterval> | null = null;

  function jugadoresSync(): { nombre: string; decimas: number; eliminado: boolean }[] {
    return jugadores.map(({ nombre, decimas, eliminado }) => ({ nombre, decimas, eliminado }));
  }
  function vivos(): number[] {
    return jugadores.map((j, i) => (j.eliminado ? -1 : i)).filter((i) => i >= 0);
  }
  function siguienteVivo(desde: number): number {
    for (let k = 1; k <= jugadores.length; k++) {
      const i = (desde + k) % jugadores.length;
      if (!jugadores[i].eliminado) return i;
    }
    return desde;
  }
  function escapeHTML(s: string): string {
    return s.replace(/[<>&"]/g, (c) => ({ "<": "&lt;", ">": "&gt;", "&": "&amp;", '"': "&quot;" }[c]!));
  }

  // Tablero (host-only full data)
  interface CasillaSync { catSlug: string; catEmoji: string; catNombre: string; dueño: number | null; }
  interface CasillaFull extends CasillaSync {
    catNombres: string[] | null; catHardcoded: ItemFloor[] | null;
    items: ItemFloor[]; itemsOffset: number; empateCuenta: number;
  }
  let casillasSync: CasillaSync[] = [];
  let casillasHost: CasillaFull[] = [];
  let casillaDuelo = -1;
  let tableroAtacante = 0;

  // ── Chat ───────────────────────────────────────────────────
  const PANTALLAS_CON_CHAT = new Set<HTMLElement>(_PANTALLAS_CHAT);
  let chatAbierto = false;
  let chatNoLeidos = 0;

  function actualizarBotonChat() {
    if (!canal) {
      $("chat-flot").classList.add("hidden");
      const bar = $("chat-juego-bar-inline"); bar.classList.add("hidden"); bar.classList.remove("flex");
      $("chat-toasts").classList.add("hidden");
      return;
    }
    const pActual = PANTALLAS.find((s) => !s.classList.contains("hidden"));
    const enChat = !!(pActual && PANTALLAS_CON_CHAT.has(pActual));
    const enJuego = pActual === pJuego;
    // En juego: barra inline abajo + toasts. En otras pantallas con chat: botón flotante
    $("chat-flot").classList.toggle("hidden", !enChat || chatAbierto || enJuego);
    const bar = $("chat-juego-bar-inline");
    bar.classList.toggle("hidden", !enJuego);
    bar.classList.toggle("flex", enJuego);
    $("chat-toasts").classList.toggle("hidden", !enJuego);
    if (!enJuego) limpiarToasts();
  }

  function limpiarToasts() {
    $("chat-toasts").innerHTML = "";
  }

  function nombreDe(i: number): string {
    return jugadores[i]?.nombre ?? `Jugador ${i + 1}`;
  }

  function lanzarToastChat(autor: number, texto: string) {
    const cont = $("chat-toasts");
    const esMio = autor === miIndice;
    const border = COLORES[autor] ?? "#a8c5ff";
    const div = document.createElement("div");
    // Mis mensajes a la derecha, los de los demás a la izquierda
    div.className = `${esMio ? "self-end" : "self-start"} max-w-[90%] px-3 py-2 rounded-lg text-sm font-titulo font-bold pointer-events-none`;
    div.style.cssText = `background:color-mix(in srgb, ${border} 92%, transparent);border:1px solid ${border};color:#07070f;box-shadow:0 0 14px ${border}aa;transition:opacity .4s,transform .4s;transform:translateY(0);opacity:1`;
    div.innerHTML = `<span style="opacity:.7;font-size:.75em">${escapeHTML(nombreDe(autor))}:</span> ${escapeHTML(texto)}`;
    cont.appendChild(div);
    // Mantener máximo 3 toasts a la vez
    while (cont.children.length > 3) cont.firstChild!.remove();
    // Desvanecer después de 7 s
    setTimeout(() => {
      div.style.opacity = "0";
      div.style.transform = "translateY(-8px)";
      setTimeout(() => div.remove(), 400);
    }, 7000);
  }

  function actualizarBadgeChat() {
    const badge = $("chat-badge");
    if (chatNoLeidos > 0) {
      badge.textContent = String(Math.min(chatNoLeidos, 99));
      badge.classList.remove("hidden");
    } else {
      badge.classList.add("hidden");
    }
  }

  function addChatMsg(autor: number, texto: string, tipo: "texto" | "voz") {
    const lista = $("chat-mensajes");
    const div = document.createElement("div");
    const esMio = autor === miIndice;
    const border = COLORES[autor] ?? "#a8c5ff";
    div.className = `flex flex-col max-w-[85%] ${esMio ? "self-end items-end" : "self-start items-start"}`;
    div.innerHTML = `
      <div class="text-[10px] font-titulo text-[#7b9ef5] mb-0.5 px-1">${escapeHTML(nombreDe(autor))}${tipo === "voz" ? " 🎤" : ""}</div>
      <div class="px-3 py-1.5 text-sm font-titulo rounded-lg" style="background:color-mix(in srgb, ${border} 18%, transparent);border:1px solid ${border};color:#e8e8ff">${escapeHTML(texto)}</div>
    `;
    lista.appendChild(div);
    lista.scrollTop = lista.scrollHeight;
    if (!chatAbierto && autor !== miIndice) {
      chatNoLeidos++;
      actualizarBadgeChat();
    }
    // Si estamos en pJuego, mostrar el mensaje como toast efímero
    if (!pJuego.classList.contains("hidden")) lanzarToastChat(autor, texto);
  }

  function enviarChat(texto: string, tipo: "texto" | "voz" = "texto") {
    if (!canal || !texto.trim()) return;
    const t = texto.trim().slice(0, 200);
    const msg = { autor: miIndice, texto: t, tipo };
    try { canal.trigger("client-chat", msg); } catch {}
    addChatMsg(msg.autor, msg.texto, msg.tipo);
  }

  function abrirChat() {
    chatAbierto = true;
    chatNoLeidos = 0;
    actualizarBadgeChat();
    $("chat-overlay").classList.remove("hidden");
    $("chat-flot").classList.add("hidden");
    const input = $("chat-input") as HTMLInputElement;
    setTimeout(() => { const m = $("chat-mensajes"); m.scrollTop = m.scrollHeight; input.focus(); }, 50);
  }

  function cerrarChat() {
    chatAbierto = false;
    $("chat-overlay").classList.add("hidden");
    actualizarBotonChat();
  }

  $("chat-flot").addEventListener("click", abrirChat);
  $("chat-cerrar").addEventListener("click", cerrarChat);
  $("chat-form").addEventListener("submit", (e) => {
    e.preventDefault();
    const input = $("chat-input") as HTMLInputElement;
    enviarChat(input.value, "texto");
    input.value = "";
  });
  $("chat-juego-bar-inline").addEventListener("submit", (e) => {
    e.preventDefault();
    const input = $("chat-juego-input") as HTMLInputElement;
    enviarChat(input.value, "texto");
    input.value = "";
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && chatAbierto) { cerrarChat(); }
  });

  // ── Categoría ─────────────────────────────────────────────
  type FiltroCat = "cine" | "mundo" | "deportes" | "arte" | "compras" | "personas" | "aleatorio" | "infantil";
  let categoriaFiltro: FiltroCat = "aleatorio";

  const slugsInfantiles: string[] = JSON.parse(
    document.getElementById("datos-infantiles")!.dataset.json!,
  );
  const setInfantiles = new Set(slugsInfantiles);
  let tableroInfantil = false;

  function seleccionarFiltro(filtro: FiltroCat) {
    categoriaFiltro = filtro;
    const btns: Record<FiltroCat, HTMLElement> = {
      cine: $("cat-cine"), mundo: $("cat-mundo"), deportes: $("cat-deportes"),
      arte: $("cat-arte"), compras: $("cat-compras"), personas: $("cat-personas"),
      aleatorio: $("cat-aleatorio"), infantil: $("cat-infantil"),
    };
    for (const [k, btn] of Object.entries(btns)) {
      btn.classList.toggle("floor-cat-selected", k === filtro);
    }
  }

  $("cat-cine").addEventListener("click", () => seleccionarFiltro("cine"));
  $("cat-mundo").addEventListener("click", () => seleccionarFiltro("mundo"));
  $("cat-deportes").addEventListener("click", () => seleccionarFiltro("deportes"));
  $("cat-arte").addEventListener("click", () => seleccionarFiltro("arte"));
  $("cat-compras").addEventListener("click", () => seleccionarFiltro("compras"));
  $("cat-personas").addEventListener("click", () => seleccionarFiltro("personas"));
  $("cat-aleatorio").addEventListener("click", () => seleccionarFiltro("aleatorio"));
  $("cat-infantil").addEventListener("click", () => seleccionarFiltro("infantil"));

  function seleccionarTablero(infantil: boolean) {
    tableroInfantil = infantil;
    $("tab-adultos").classList.toggle("floor-cat-selected", !infantil);
    $("tab-infantil").classList.toggle("floor-cat-selected", infantil);
  }
  $("tab-adultos").addEventListener("click", () => seleccionarTablero(false));
  $("tab-infantil").addEventListener("click", () => seleccionarTablero(true));

  // ── Pusher helpers ─────────────────────────────────────────
  interface SyncEstado {
    fase: string;
    jugadores?: { nombre: string; decimas: number; eliminado: boolean }[];
    modo?: string;
    turno?: number; timestampTurno?: number; indice?: number;
    items?: ItemFloor[]; categoriaActual?: string; categoriaSlug?: string;
    aciertoNombre?: string; paseNombre?: string; agotadoNombre?: string;
    casillas?: CasillaSync[]; casillaDuelo?: number; tableroAtacante?: number;
    preduelEmoji?: string; preduelNombreCat?: string;
    ganadorTexto?: string;
    cards?: { nombre: string; color: string; valor: string; label: string }[];
  }

  function sync(estado: SyncEstado) {
    if (!canal || rol !== "host") return;
    canal.trigger("client-estado", estado);
  }

  function accion(tipo: string, extra?: Record<string, unknown>) {
    if (!canal || rol !== "guest") return;
    canal.trigger("client-accion", { tipo, de: miIndice, ...extra });
  }

  function estadoBase(): SyncEstado {
    return { fase: "juego", jugadores: jugadoresSync(), modo };
  }
  function estadoJuego(extra?: Partial<SyncEstado>): SyncEstado {
    return { ...estadoBase(), turno, timestampTurno, indice, items, categoriaActual, categoriaSlug, ...extra };
  }

  // ── Generador de código ────────────────────────────────────
  function generarCodigo(): string {
    const chars = "ABCDEFGHJKMNPQRSTUVWXYZ23456789";
    return Array.from({ length: 6 }, () => chars[Math.floor(Math.random() * chars.length)]).join("");
  }

  // ── Pantalla entrada ───────────────────────────────────────
  function mostrarError(el: HTMLElement, msg: string) {
    el.textContent = msg;
    el.classList.remove("hidden");
  }

  // Recordar nombre del jugador entre sesiones
  const NOMBRE_KEY = "el-suelo:multi-nombre";
  const nombreGuardado = (() => { try { return localStorage.getItem(NOMBRE_KEY) || ""; } catch { return ""; } })();
  if (nombreGuardado) {
    ($("nombre-crear") as HTMLInputElement).value = nombreGuardado;
    ($("nombre-unirse") as HTMLInputElement).value = nombreGuardado;
  }
  function recordarNombre(n: string) {
    try { localStorage.setItem(NOMBRE_KEY, n); } catch {}
  }

  // Si el link viene con ?codigo=XXXX (compartido por whatsapp), saltar directamente a "Unirse"
  try {
    const params = new URLSearchParams(location.search);
    const codigoUrl = (params.get("codigo") || "").trim().toUpperCase().slice(0, 6);
    if (codigoUrl && /^[A-Z0-9]{4,6}$/.test(codigoUrl)) {
      ($("codigo-sala") as HTMLInputElement).value = codigoUrl;
      mostrar(pUnirse);
      setTimeout(() => ($("nombre-unirse") as HTMLInputElement).focus(), 100);
    }
  } catch {}

  // Navegación: en pantalla-entrada, los dos botones grandes
  $("boton-ir-crear").addEventListener("click", () => mostrar(pCrear));
  $("boton-ir-unirse").addEventListener("click", () => mostrar(pUnirse));

  function flagInputError(input: HTMLInputElement) {
    input.focus();
    input.style.borderColor = "#ff1dce";
    input.style.boxShadow = "0 0 12px #ff1dce88";
    setTimeout(() => { input.style.borderColor = ""; input.style.boxShadow = ""; }, 2000);
  }

  // Lobby: pinta las MAX_JUGADORES plazas de la sala con quién las ocupa
  function renderSala() {
    const cont = $("sala-slots");
    let html = "";
    for (let i = 0; i < MAX_JUGADORES; i++) {
      const j = jugadores[i];
      const color = COLORES[i];
      if (j) {
        html += `<div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background:${color};box-shadow:0 0 8px ${color}"></span>
          <span class="font-titulo font-bold text-[#e8e8ff] text-base">${escapeHTML(j.nombre)}${i === miIndice ? " (tú)" : ""}</span>
          ${i === 0 ? '<span class="text-[#a8c5ff] font-titulo text-xs ml-auto">anfitrión</span>' : ""}
        </div>`;
      } else {
        html += `<div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-[#2a5090] shrink-0"></span>
          <span class="font-titulo text-[#7b9ef5] text-sm italic">Libre</span>
        </div>`;
      }
    }
    cont.innerHTML = html;
    if (rol === "host") $("boton-sala-jugar").classList.toggle("hidden", jugadores.length < 2);
  }

  $("boton-crear").addEventListener("click", () => {
    const nombreInput = $("nombre-crear") as HTMLInputElement;
    const nombre = nombreInput.value.trim();
    const errEl = $("error-crear");
    errEl.classList.add("hidden");
    if (!nombre) {
      flagInputError(nombreInput);
      mostrarError(errEl, "Primero escribe tu nombre ↑");
      return;
    }
    if (!PUSHER_KEY) { mostrarError(errEl, "Error de configuración del servidor."); return; }
    recordarNombre(nombre);
    rol = "host"; miIndice = 0; miNombre = nombre;
    jugadores = [{ nombre, decimas: DECIMAS_INICIO, eliminado: false, uid: uidPropio }];
    codigo = generarCodigo();
    partidaEnCurso = false;
    trackEv("sala-creada", {});
    initPusher(() => {
      $("sala-codigo").textContent = codigo;
      renderSala();
      $("boton-sala-jugar").classList.add("hidden");
      $("sala-info").innerHTML = "Comparte el código.<br>Pueden entrar hasta 3 jugadores más.";
      mostrar(pSala);
    });
  });

  $("boton-unirse").addEventListener("click", () => {
    const nombreInput = $("nombre-unirse") as HTMLInputElement;
    const codigoInput = $("codigo-sala") as HTMLInputElement;
    const nombre = nombreInput.value.trim();
    const cod = codigoInput.value.trim().toUpperCase();
    const errEl = $("error-unirse");
    errEl.classList.add("hidden");
    if (!nombre) {
      flagInputError(nombreInput);
      mostrarError(errEl, "Primero escribe tu nombre ↑");
      return;
    }
    if (cod.length < 4 || cod.length > 6) {
      flagInputError(codigoInput);
      mostrarError(errEl, "Introduce el código que te han pasado.");
      return;
    }
    if (!PUSHER_KEY) { mostrarError(errEl, "Error de configuración del servidor."); return; }
    recordarNombre(nombre);
    rol = "guest"; miIndice = -1; miNombre = nombre;
    jugadores = [];
    codigo = cod;
    trackEv("sala-unida", {});
    initPusher(() => {
      $("sala-codigo").textContent = codigo;
      $("sala-slots").innerHTML = "";
      $("sala-info").textContent = "Conectado. Esperando al anfitrión...";
      $("boton-sala-jugar").classList.add("hidden");
      mostrar(pSala);
      canal!.trigger("client-unirse", { nombre: miNombre, uid: uidPropio });
    });
  });

  function initPusher(onOk: () => void) {
    const pusher = new Pusher(PUSHER_KEY, { cluster: PUSHER_CLUSTER, authEndpoint: "/api/pusher-auth" });
    canal = pusher.subscribe(`private-game-${codigo}`);
    canal.bind("pusher:subscription_succeeded", onOk);
    canal.bind("pusher:subscription_error", (data: { status?: number; error?: string }) => {
      const status = data?.status ?? "?";
      console.error("Pusher subscription_error:", data);
      // Solo mostramos error si todavía estamos en las pantallas de crear/unirse
      const errEl = !pCrear.classList.contains("hidden") ? $("error-crear")
                  : !pUnirse.classList.contains("hidden") ? $("error-unirse")
                  : null;
      if (errEl) mostrarError(errEl, `Error de conexión (${status}). Inténtalo de nuevo.`);
    });
    canal.bind("client-estado", (d: SyncEstado) => { if (rol === "guest") applyEstado(d); });
    canal.bind("client-chat", (d: { autor: number; texto: string; tipo: "texto" | "voz" }) => {
      if (!d || !d.texto || typeof d.autor !== "number") return;
      addChatMsg(d.autor, d.texto, d.tipo);
    });
    canal.bind("client-voz", (d: { de?: number; texto: string }) => {
      // Voz del jugador de turno → mostrarla bajo la imagen de los demás
      if (!d || !d.texto) return;
      if (turno === miIndice) return; // ignoro mi propia voz
      const el = $("texto-voz");
      if (!el || pJuego.classList.contains("hidden")) return;
      el.textContent = `🎤 "${d.texto}"`;
    });
    // Avisos de evento (acierto/pase) para que vibren los demás móviles
    canal.bind("client-aviso", (d: { tipo: "acierto" | "pase" }) => {
      if (!d) return;
      if (d.tipo === "acierto") vibrar([30, 50, 30]);
      else if (d.tipo === "pase") vibrar(20);
    });
    // Un nuevo jugador se quiere unir (lo gestiona el host)
    canal.bind("client-unirse", (d: { nombre: string; uid: string }) => {
      if (rol !== "host" || !d || !d.uid) return;
      let idx = jugadores.findIndex((j) => j.uid === d.uid);
      if (idx === -1) {
        if (partidaEnCurso || jugadores.length >= MAX_JUGADORES) {
          try { canal!.trigger("client-rechazado", { uid: d.uid, motivo: partidaEnCurso ? "La partida ya ha empezado." : "La sala está llena (4 jugadores)." }); } catch {}
          return;
        }
        jugadores.push({ nombre: d.nombre || `Jugador ${jugadores.length + 1}`, decimas: DECIMAS_INICIO, eliminado: false, uid: d.uid });
        idx = jugadores.length - 1;
      } else {
        jugadores[idx].nombre = d.nombre || jugadores[idx].nombre;
      }
      // Decir al recién llegado su índice + el roster actual (solo nombres)
      try { canal!.trigger("client-asignado", { uid: d.uid, indice: idx, roster: jugadores.map((j) => j.nombre) }); } catch {}
      renderSala();
      $("sala-info").textContent = `${jugadores[idx].nombre} se ha unido 🎉`;
      $("boton-sala-jugar").classList.toggle("hidden", jugadores.length < 2);
      // Refrescar el lobby de todos los conectados
      sync({ fase: "sala", jugadores: jugadoresSync() });
    });
    // El host me asigna mi índice y me manda el roster (lo gestiona el guest)
    canal.bind("client-asignado", (d: { uid: string; indice: number; roster: string[] }) => {
      if (rol !== "guest" || !d || d.uid !== uidPropio) return;
      miIndice = d.indice;
      jugadores = (d.roster || []).map((nombre) => ({ nombre, decimas: DECIMAS_INICIO, eliminado: false }));
      renderSala();
      $("sala-info").textContent = jugadores.length >= 2
        ? "En la sala. Esperando a que el anfitrión empiece."
        : "Conectado. Esperando jugadores...";
      mostrar(pSala);
    });
    canal.bind("client-rechazado", (d: { uid: string; motivo: string }) => {
      if (rol !== "guest" || !d || d.uid !== uidPropio) return;
      mostrar(pUnirse);
      mostrarError($("error-unirse"), d.motivo || "No se pudo unir a la sala.");
    });
    canal.bind("client-accion", (d: { tipo: string; de?: number; idx?: number }) => {
      if (rol !== "host") return;
      handleAccion(d);
    });
  }

  function applyEstado(e: SyncEstado) {
    if (e.jugadores) jugadores = e.jugadores.map((j) => ({ ...j }));
    if (e.turno !== undefined) turno = e.turno;
    if (e.timestampTurno !== undefined) timestampTurno = e.timestampTurno;
    if (e.indice !== undefined) indice = e.indice;
    if (e.items) items = e.items;
    if (e.categoriaActual) categoriaActual = e.categoriaActual;
    if (e.categoriaSlug !== undefined) categoriaSlug = e.categoriaSlug;
    if (e.casillas) casillasSync = e.casillas;
    if (e.casillaDuelo !== undefined) casillaDuelo = e.casillaDuelo;
    if (e.tableroAtacante !== undefined) tableroAtacante = e.tableroAtacante;

    if (e.fase === "sala") {
      renderSala();
      $("sala-info").textContent = jugadores.length >= 2
        ? "En la sala. Esperando a que el anfitrión empiece."
        : "Conectado. Esperando jugadores...";
      mostrar(pSala);
    } else if (e.fase === "setup-espera") {
      $("setup-guest-nombres").textContent = jugadores.map((j) => j.nombre).join(" · ");
      mostrar(pSetupGuest);
    } else if (e.fase === "cargando") {
      mostrar(pLoader);
    } else if (e.fase === "juego") {
      bloqueado = false; terminado = false;
      $("preduel-overlay").classList.add("hidden");
      $("juego-categoria-label").textContent = categoriaActual;
      mostrar(pJuego);
      renderJugadoresBar();
      mostrarImagen();
      iniciarRenderLoop();
      if (e.aciertoNombre) {
        $("overlay-nombre").textContent = e.aciertoNombre;
        $("overlay-acierto").classList.remove("hidden");
        $("overlay-pase").classList.add("hidden");
        setTimeout(() => $("overlay-acierto").classList.add("hidden"), 1000);
      } else if (e.paseNombre) {
        $("overlay-pase-nombre").textContent = e.paseNombre;
        $("overlay-pase").classList.remove("hidden");
        $("overlay-acierto").classList.add("hidden");
        setTimeout(() => $("overlay-pase").classList.add("hidden"), 1000);
      } else {
        $("overlay-acierto").classList.add("hidden");
        $("overlay-pase").classList.add("hidden");
      }
      const yoEliminado = !!jugadores[miIndice]?.eliminado;
      if (turno === miIndice && !yoEliminado) {
        bloqueado = false;
        iniciarReconocedor();
        iniciarVoz();
        $("boton-pasar").classList.remove("hidden");
      } else {
        pararVoz();
        $("boton-pasar").classList.add("hidden");
        if (e.agotadoNombre) $("texto-voz").textContent = `⏱️ ¡Se acabó el tiempo de ${e.agotadoNombre}!`;
        else $("texto-voz").textContent = `🎤 Turno de ${nombreDe(turno)}...`;
      }
    } else if (e.fase === "tablero") {
      pararVoz();
      stopRenderLoop();
      $("preduel-overlay").classList.add("hidden");
      $("overlay-acierto").classList.add("hidden");
      $("overlay-pase").classList.add("hidden");
      renderTableroSync();
      mostrar(pTablero);
    } else if (e.fase === "preduel") {
      $("preduel-emoji").textContent = e.preduelEmoji ?? "";
      $("preduel-nombre-cat").textContent = e.preduelNombreCat ?? "";
      const esAtacante = tableroAtacante === miIndice;
      $("preduel-empezar").classList.toggle("hidden", !esAtacante);
      $("preduel-espera").classList.toggle("hidden", esAtacante);
      $("preduel-volver").classList.toggle("hidden", !esAtacante);
      renderTableroSync();
      $("preduel-overlay").classList.remove("hidden");
      mostrar(pTablero);
    } else if (e.fase === "final") {
      pararVoz(); stopRenderLoop();
      $("preduel-overlay").classList.add("hidden");
      $("overlay-acierto").classList.add("hidden");
      $("overlay-pase").classList.add("hidden");
      $("texto-ganador").textContent = e.ganadorTexto ?? "";
      if (e.cards) renderFinalCards(e.cards);
      mostrar(pFinal);
      lanzarConfeti();
    }
  }

  // ── Setup (host) ───────────────────────────────────────────
  $("boton-compartir").addEventListener("click", async () => {
    const url = `https://elsuelo.es/multi?codigo=${codigo}`;
    const texto = `¡Únete a mi sala en El Suelo!\nCódigo: ${codigo}`;
    trackEv("compartir", { tipo: "sala" });
    try {
      if (navigator.share) {
        await navigator.share({ title: "El Suelo — Crear sala", text: texto, url });
      } else {
        await navigator.clipboard.writeText(`${texto}\n${url}`);
        $("sala-info").textContent = "¡Enlace copiado! ✓";
      }
    } catch {}
  });

  $("boton-sala-jugar").addEventListener("click", () => {
    if (rol !== "host") return;
    if (jugadores.length < 2) return;
    sync({ fase: "setup-espera", jugadores: jugadoresSync() });
    mostrar(pSetup);
  });

  let modoElegido = false;

  $("modo-rapida").addEventListener("click", () => {
    modo = "rapida"; modoElegido = true;
    $("seccion-categoria").classList.remove("hidden");
    $("seccion-tablero").classList.add("hidden");
    $("modo-rapida").classList.add("floor-btn-a");
    $("modo-tablero").classList.remove("floor-btn-a");
  });

  $("modo-tablero").addEventListener("click", () => {
    modo = "tablero"; modoElegido = true;
    // En tablero no se elige categoría, pero sí adulto/infantil
    $("seccion-categoria").classList.add("hidden");
    $("seccion-tablero").classList.remove("hidden");
    $("modo-tablero").classList.add("floor-btn-a");
    $("modo-rapida").classList.remove("floor-btn-a");
  });

  $("boton-empezar").addEventListener("click", async () => {
    if (rol !== "host") return;
    const errEl = $("error-setup");
    errEl.classList.add("hidden");
    if (!modoElegido) {
      errEl.textContent = "Elige un modo primero."; errEl.classList.remove("hidden"); return;
    }
    if (jugadores.length < 2) {
      errEl.textContent = "Necesitas al menos 2 jugadores."; errEl.classList.remove("hidden"); return;
    }
    if (modo === "tablero") {
      trackEv("partida-iniciada", { modo: "multi-tablero", variante: tableroInfantil ? "infantil" : "adultos", jugadores: jugadores.length });
      sync({ fase: "cargando", jugadores: jugadoresSync() });
      mostrar(pLoader);
      pararVoz();
      await initTablero();
      return;
    }
    // Auto-pick random subcategory usando lista publicada en runtime
    const pub = await cargarPublicadas();
    const pool = construirPool(pub);
    const _esMundoS = (s: string) => mundoSlugsAll.includes(s);
    const poolFiltrado = categoriaFiltro === "cine"
      ? pool.filter((s) => !_esMundoS(s))
      : categoriaFiltro === "aleatorio"
      ? pool
      : categoriaFiltro === "infantil"
      ? pool.filter((s) => setInfantiles.has(s))
      : pool.filter((s) => mundoSlugsGrupo[s] === categoriaFiltro);
    if (poolFiltrado.length === 0) {
      errEl.textContent = categoriaFiltro === "infantil"
        ? "No hay temas infantiles publicados aún."
        : "No hay categorías publicadas para este filtro.";
      errEl.classList.remove("hidden"); return;
    }
    // Excluimos las últimas elegidas (con fallback al pool si el filtro deja
    // muy pocas) para evitar repetición entre partidas seguidas.
    const _poolMuestreo = poolSinRecientes(poolFiltrado, 5);
    const _slug = _poolMuestreo[Math.floor(Math.random() * _poolMuestreo.length)];
    marcarRecientes([_slug]);
    const _esMundo = mundoSlugsAll.includes(_slug);
    trackEv("partida-iniciada", { modo: "multi-rapida", filtro: categoriaFiltro, categoria: _slug, jugadores: jugadores.length });
    sync({ fase: "cargando", jugadores: jugadoresSync() });
    mostrar(pLoader);
    $("loader-cat-name").textContent = cineSlugsNombres[_slug] ?? _slug;
    try {
      let raw: ItemFloor[];
      if (_esMundo) {
        raw = await cargarCatalogoMundo(_slug);
      } else if (cineSlugsMetaMezcla[_slug]) {
        raw = await cargarMezclaCine(cineSlugsMetaMezcla[_slug]);
      } else {
        const derivado = cineSlugsDerivados[_slug];
        raw = derivado
          ? await cargarCatalogoCinePeli(_slug, derivado.baseSlug)
          : await cargarCatalogoCine(_slug);
      }
      categoriaSlug = _slug;
      categoriaActual = cineSlugsNombres[_slug] ?? _slug;
      items = barajar(raw).slice(0, 20);
      partidaEnCurso = true;
      jugadores.forEach((j) => { j.decimas = DECIMAS_INICIO; j.eliminado = false; });
      ordenEliminacion = [];
      turno = 0; indice = 0; terminado = false; bloqueado = false;
      $("juego-categoria-label").textContent = categoriaActual;
      mostrar(pJuego);
      iniciarRenderLoop();
      iniciarTurno();
    } catch (e) {
      const msg = e instanceof Error ? e.message : "Error";
      errEl.textContent = `No se pudo cargar: ${msg}`; errEl.classList.remove("hidden");
      mostrar(pSetup);
      sync({ fase: "setup-espera", jugadores: jugadoresSync() });
    }
  });

  // ── Turno (host) ───────────────────────────────────────────
  function iniciarTurno() {
    if (terminado) return;
    if (items.length === 0 || indice >= items.length) { terminar(); return; }
    bloqueado = false;
    ($("boton-pasar") as HTMLButtonElement).disabled = false;
    $("juego-categoria-label").textContent = categoriaActual;
    timestampTurno = Date.now();
    renderJugadoresBar();
    mostrarImagen();
    if (gameTimeout) clearTimeout(gameTimeout);
    gameTimeout = setTimeout(() => {
      if (!bloqueado && !terminado) procesarAgotado();
    }, Math.max(0, jugadores[turno].decimas) * 100);
    // Sync del estado a los guests
    sync(estadoJuego());
    // Voz solo en mi turno
    if (turno === miIndice) {
      iniciarReconocedor(); iniciarVoz();
      $("boton-pasar").classList.remove("hidden");
    } else {
      pararVoz();
      $("boton-pasar").classList.add("hidden");
      $("texto-voz").textContent = `🎤 Turno de ${nombreDe(turno)}...`;
    }
  }

  // ── Ajustes (sonido/vibración) ─────────────────────────────
  function leerAjustes(): { sonido: boolean; vibracion: boolean } {
    try {
      const raw = localStorage.getItem("el-suelo:ajustes-v1");
      if (raw) return { sonido: true, vibracion: true, ...JSON.parse(raw) };
    } catch {}
    return { sonido: true, vibracion: true };
  }

  function vibrar(pattern: number | number[]) {
    try {
      if (!leerAjustes().vibracion) return;
      if (navigator.vibrate) navigator.vibrate(pattern);
    } catch {}
  }

  // Sonidos WebAudio (sin assets externos)
  let audioCtx: AudioContext | null = null;
  function getAudioCtx(): AudioContext | null {
    if (!leerAjustes().sonido) return null;
    try {
      if (!audioCtx) audioCtx = new ((window as any).AudioContext || (window as any).webkitAudioContext)();
      return audioCtx;
    } catch { return null; }
  }
  function tono(freq: number, dur = 0.08, tipo: OscillatorType = "sine", vol = 0.15) {
    const ctx = getAudioCtx();
    if (!ctx) return;
    const osc = ctx.createOscillator();
    const g = ctx.createGain();
    osc.type = tipo;
    osc.frequency.setValueAtTime(freq, ctx.currentTime);
    g.gain.setValueAtTime(vol, ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
    osc.connect(g).connect(ctx.destination);
    osc.start();
    osc.stop(ctx.currentTime + dur);
  }
  function sonidoAcierto() { tono(880, 0.08); setTimeout(() => tono(1320, 0.12), 90); }
  function sonidoPase() { tono(440, 0.07, "triangle"); setTimeout(() => tono(330, 0.1, "triangle"), 70); }
  function sonidoFin() { tono(660, 0.15, "sawtooth", 0.12); setTimeout(() => tono(330, 0.25, "sawtooth", 0.12), 160); }

  // ── Acciones (host autoritativo) ───────────────────────────
  function registrarAcierto() {
    if (bloqueado || terminado) return;
    bloqueado = true;
    vibrar(60);
    sonidoAcierto();
    try { canal?.trigger("client-aviso", { tipo: "acierto" }); } catch {}
    if (gameTimeout) clearTimeout(gameTimeout);
    pararVoz();
    const elapsed = (Date.now() - timestampTurno) / 100;
    const j = jugadores[turno];
    j.decimas = Math.max(0, j.decimas - elapsed);
    const nombre = items[indice]?.nombre ?? "";
    indice++;
    $("overlay-nombre").textContent = nombre;
    $("overlay-acierto").classList.remove("hidden");
    $("overlay-pase").classList.add("hidden");
    $("texto-voz").textContent = `✓ ¡${nombre}!`;
    sync(estadoJuego({ aciertoNombre: nombre }));
    setTimeout(() => {
      $("overlay-acierto").classList.add("hidden");
      cambiarTurno();
    }, 1200);
  }

  function registrarPase() {
    if (bloqueado || terminado) return;
    bloqueado = true;
    vibrar([40, 40, 40]);
    sonidoPase();
    try { canal?.trigger("client-aviso", { tipo: "pase" }); } catch {}
    if (gameTimeout) clearTimeout(gameTimeout);
    pararVoz();
    const elapsed = (Date.now() - timestampTurno) / 100;
    const j = jugadores[turno];
    j.decimas = Math.max(0, j.decimas - elapsed - 30);
    const nombre = items[indice]?.nombre ?? "";
    indice++;
    $("overlay-pase-nombre").textContent = nombre;
    $("overlay-pase").classList.remove("hidden");
    $("overlay-acierto").classList.add("hidden");
    sync(estadoJuego({ paseNombre: nombre }));
    const idxJ = turno;
    setTimeout(() => {
      $("overlay-pase").classList.add("hidden");
      if (jugadores[idxJ].decimas <= 0) { procesarAgotado(); return; }
      // Mismo turno: solo continúa con el siguiente item
      iniciarTurno();
    }, 1200);
  }

  // El jugador del turno se quedó sin tiempo (por reloj o por pase).
  // En rápida queda eliminado y sigue la partida si quedan 2+; en tablero
  // (o si solo queda uno) el duelo termina.
  function procesarAgotado() {
    if (terminado) return;
    bloqueado = true;
    pararVoz();
    if (gameTimeout) clearTimeout(gameTimeout);
    const j = jugadores[turno];
    j.decimas = 0;
    $("texto-voz").textContent = `⏱️ ¡Se acabó el tiempo de ${j.nombre}!`;
    if (modo !== "tablero") {
      j.eliminado = true;
      if (!ordenEliminacion.includes(turno)) ordenEliminacion.push(turno);
      if (vivos().length > 1) {
        renderJugadoresBar();
        sync(estadoJuego({ agotadoNombre: j.nombre }));
        setTimeout(cambiarTurno, 1200);
        return;
      }
    }
    sync(estadoJuego({ agotadoNombre: j.nombre }));
    setTimeout(terminar, 1200);
  }

  function cambiarTurno() {
    if (terminado) return;
    turno = siguienteVivo(turno);
    iniciarTurno();
  }

  function terminar() {
    if (terminado) return;
    terminado = true;
    vibrar([150, 100, 150]);
    sonidoFin();
    if (gameTimeout) clearTimeout(gameTimeout);
    pararVoz();
    // Limpiar overlays para no dejarlos visibles al cambiar a tablero/final
    $("overlay-acierto").classList.add("hidden");
    $("overlay-pase").classList.add("hidden");
    if (modo === "tablero") {
      if (casillaDuelo >= 0 && casillaDuelo < casillasHost.length) {
        const c = casillasHost[casillaDuelo];
        if (c.items.length > 0) c.itemsOffset = (c.itemsOffset + indice) % c.items.length;
      }
      terminarDueloTablero();
      return;
    }
    // Clasificación: primero los vivos por tiempo restante; después los
    // eliminados en orden inverso (el último en caer queda mejor).
    const ranking = [
      ...vivos().sort((a, b) => jugadores[b].decimas - jugadores[a].decimas),
      ...[...ordenEliminacion].reverse(),
    ];
    const seg = (i: number) => Math.max(0, Math.ceil(jugadores[i].decimas / 10));
    const empate = ranking.length > 1
      && !jugadores[ranking[0]].eliminado && !jugadores[ranking[1]].eliminado
      && jugadores[ranking[0]].decimas === jugadores[ranking[1]].decimas;
    const ganadorTexto = empate ? "¡Empate! 🤝" : `🥇 Gana ${jugadores[ranking[0]].nombre}`;
    const POSICIONES = ["🥇", "🥈", "🥉", "4º"];
    const cards = ranking.map((idx, pos) => ({
      nombre: `${POSICIONES[pos] ?? ""} ${jugadores[idx].nombre}`,
      color: COLORES[idx],
      valor: `${seg(idx)}s`,
      label: "tiempo restante",
    }));
    $("texto-ganador").textContent = ganadorTexto;
    renderFinalCards(cards);
    sync({ fase: "final", jugadores: jugadoresSync(), modo, ganadorTexto, cards });
    stopRenderLoop();
    mostrar(pFinal);
    lanzarConfeti();
  }

  // ── Acciones recibidas de un guest ─────────────────────────
  function handleAccion(d: { tipo: string; de?: number; idx?: number }) {
    if (rol !== "host" || !d) return;
    if (d.tipo === "acierto" && d.de === turno && !bloqueado && !terminado) {
      registrarAcierto();
    } else if (d.tipo === "pase" && d.de === turno && !bloqueado && !terminado) {
      registrarPase();
    } else if (d.tipo === "casilla" && d.de === tableroAtacante && d.idx !== undefined) {
      mostrarPreDuelo(d.idx);
    } else if (d.tipo === "iniciar-duelo" && d.de === tableroAtacante) {
      $("preduel-overlay").classList.add("hidden");
      atacarCasilla(casillaDuelo);
    } else if (d.tipo === "cancelar-preduel" && d.de === tableroAtacante) {
      $("preduel-overlay").classList.add("hidden");
      casillaDuelo = -1;
      sync({ fase: "tablero", jugadores: jugadoresSync(), casillas: casillasSync, casillaDuelo: -1, tableroAtacante });
      renderTableroSync();
      mostrar(pTablero);
    }
  }

  $("boton-pasar").addEventListener("click", () => {
    if (turno !== miIndice || bloqueado || terminado) return;
    if (rol === "host") registrarPase();
    else accion("pase");
  });

  // ── Voz ─────────────────────────────────────────────────────
  let ultimoVozTextoEnviado = "";
  let ultimoVozTimestamp = 0;

  function iniciarReconocedor() {
    pararVoz();
    if (!navegadorSoportaVoz()) return;
    reco = crearReconocedor({
      onTranscripcion: (texto) => {
        if (bloqueado || terminado || turno !== miIndice) return;
        const item = items[indice];
        if (!item) return;
        $("texto-voz").textContent = `"${texto}"`;
        // Enviar la voz a los demás para que aparezca bajo su imagen (no en chat)
        const ahora = Date.now();
        if (canal && texto && texto !== ultimoVozTextoEnviado && ahora - ultimoVozTimestamp > 400) {
          ultimoVozTextoEnviado = texto;
          ultimoVozTimestamp = ahora;
          try { canal.trigger("client-voz", { de: miIndice, texto }); } catch {}
        }
        // Prioridad 1: si lo dicho contiene la respuesta correcta, acierto
        if (aciertoFlexible(texto, item.nombre, categoriaActual, categoriaSlug)) {
          if (rol === "host") registrarAcierto();
          else accion("acierto");
          return;
        }
        // Prioridad 2: comando de voz "paso/pasar" como última palabra de la frase.
        // Normalizamos tildes para no perder "pasó".
        const palabras = texto.toLowerCase()
          .normalize("NFD").replace(/[̀-ͯ]/g, "")
          .trim().replace(/[.,!¡?¿;:]/g, "")
          .split(/\s+/).filter(Boolean);
        const ultima = palabras[palabras.length - 1] || "";
        if (ultima === "paso" || ultima === "pasar" || ultima === "pasa" || ultima === "pasando" || ultima === "pasao" || ultima === "pase" || ultima === "siguiente") {
          if (rol === "host") registrarPase();
          else accion("pase");
        }
      },
      onError: (err) => {
        const msgs: Record<string, string> = {
          "not-allowed": "Sin permiso de micrófono",
          "audio-capture": "No se detecta micrófono",
          "network": "Error de red",
          "aborted": "", "no-speech": "",
        };
        const txt = msgs[err] ?? `Error: ${err}`;
        if (txt) $("texto-voz").textContent = `⚠️ ${txt}`;
      },
      lang: navigator.language || "es-ES",
    });
    reco?.iniciar();
  }

  function iniciarVoz() {
    if (!reco) { $("texto-voz").textContent = "⚠️ Tu navegador no reconoce voz — pulsa Pasar para saltar"; return; }
    reco.resetOffset();
    $("texto-voz").textContent = "🎤 Escuchando...";
  }

  function pararVoz() { if (reco) { reco.parar(); reco = null; } }

  // ── Render ──────────────────────────────────────────────────
  // Barra superior con un chip por jugador: tiempo + nombre, resaltado el del
  // turno. Se reconstruye al cambiar el turno; el render loop actualiza números.
  function renderJugadoresBar() {
    const bar = $("jugadores-bar");
    bar.innerHTML = jugadores.map((j, i) => {
      const color = COLORES[i];
      const seg = Math.max(0, Math.ceil(j.decimas / 10));
      const activo = i === turno && !j.eliminado;
      let estilo = "border:2px solid transparent;opacity:0.7";
      if (j.eliminado) estilo = "border:2px solid transparent;opacity:0.35";
      else if (activo) estilo = `border:2px solid ${color};background:color-mix(in srgb, ${color} 12%, transparent);box-shadow:0 0 16px color-mix(in srgb, ${color} 40%, transparent)`;
      return `<div class="flex-1 min-w-0 flex flex-col items-center justify-center rounded px-1 py-1.5 transition-all" style="${estilo}">
        <span data-timer="${i}" class="font-titulo font-bold tabular-nums leading-none text-center floor-timer ${activo ? "text-3xl" : "text-xl"}" style="color:${color}">${j.eliminado ? "✖" : seg}</span>
        <span class="font-titulo text-xs font-bold mt-0.5 truncate w-full text-center" style="color:${color}">${escapeHTML(j.nombre)}${i === miIndice ? " (tú)" : ""}</span>
      </div>`;
    }).join("");
  }

  function iniciarRenderLoop() {
    stopRenderLoop();
    renderInt = setInterval(() => {
      const elapsed = (Date.now() - timestampTurno) / 100;
      jugadores.forEach((j, i) => {
        const el = document.querySelector(`#jugadores-bar [data-timer="${i}"]`);
        if (!el) return;
        const dec = (i === turno && !j.eliminado) ? Math.max(0, j.decimas - elapsed) : j.decimas;
        const seg = Math.max(0, Math.ceil(dec / 10));
        if (!j.eliminado) el.textContent = String(seg);
        const urgente = i === turno && !j.eliminado && seg <= 10;
        el.classList.toggle("animate-pulse", urgente);
        el.classList.toggle("floor-timer-urgent", urgente);
      });
      const jt = jugadores[turno];
      const segActual = jt ? Math.max(0, Math.ceil(Math.max(0, jt.decimas - elapsed) / 10)) : 0;
      $("boton-pasar").classList.toggle("floor-btn-urgent", turno === miIndice && segActual <= 10);
    }, 100);
  }

  function stopRenderLoop() { if (renderInt) { clearInterval(renderInt); renderInt = null; } }

  // Tarjetas de la pantalla final (una por jugador, en orden de clasificación)
  function renderFinalCards(cards: { nombre: string; color: string; valor: string; label: string }[]) {
    $("final-grid").innerHTML = cards.map((c) => `
      <div class="floor-card-small p-4" style="border-color:${c.color}44">
        <p class="font-titulo font-bold text-sm mb-1 uppercase tracking-wide" style="color:${c.color}">${escapeHTML(c.nombre)}</p>
        <p class="font-titulo font-bold text-4xl floor-timer" style="color:${c.color}">${c.valor}</p>
        <p class="text-xs text-[#7b9ef5] font-titulo">${c.label}</p>
      </div>`).join("");
  }

  // Si la foto no carga, el host salta el ítem y sincroniza para que los guests
  // avancen con él. El guest, si solo le falla a él, muestra placeholder y
  // espera al host (no toca indice para no desincronizar).
  let fallosImagenSeguidos = 0;
  const MAX_FALLOS_IMAGEN = 8;

  function mostrarImagen() {
    if (items.length === 0) return;
    if (indice >= items.length) { if (rol === "host") terminar(); return; }
    if (rol === "host" && fallosImagenSeguidos >= MAX_FALLOS_IMAGEN) {
      fallosImagenSeguidos = 0;
      $("texto-voz").textContent = "📵 Sin imágenes — revisa tu conexión";
      terminar();
      return;
    }
    const item = items[indice];
    const img = $("imagen-item") as HTMLImageElement;
    const ph = $("imagen-placeholder");
    img.onload = () => {
      fallosImagenSeguidos = 0;
      img.classList.remove("hidden"); ph.classList.add("hidden");
    };
    img.onerror = () => {
      img.classList.add("hidden");
      ph.classList.remove("hidden");
      (ph as HTMLElement).textContent = "📷";
      if (rol === "host") {
        fallosImagenSeguidos++;
        indice++;
        sync(estadoJuego());
        mostrarImagen();
      }
    };
    img.classList.add("hidden");
    ph.classList.remove("hidden");
    (ph as HTMLElement).textContent = "📷";
    img.src = item.imagen; img.alt = item.nombre;
    // Precarga de la siguiente imagen — bajada de cuelgues por red.
    const siguiente = items[indice + 1];
    if (siguiente && siguiente.imagen) {
      const pre = new Image();
      pre.src = siguiente.imagen;
    }
    $("overlay-acierto").classList.add("hidden");
    $("overlay-pase").classList.add("hidden");
    $("texto-voz").textContent = "🎤 Escuchando...";
  }

  // ── Tablero (host) ─────────────────────────────────────────
  async function initTablero() {
    partidaEnCurso = true;
    const pub = await cargarPublicadas();
    let poolT = construirPool(pub);
    if (tableroInfantil) poolT = poolT.filter((s) => setInfantiles.has(s));
    const _esM = (s: string) => mundoSlugsAll.includes(s);
    if (poolT.length === 0) {
      const errEl = $("error-setup");
      errEl.textContent = tableroInfantil
        ? "No hay temas infantiles publicados aún."
        : "No hay categorías publicadas aún.";
      errEl.classList.remove("hidden");
      mostrar(pSetup);
      sync({ fase: "setup-espera", jugadores: jugadoresSync() });
      return;
    }
    if (poolT.length < 9) {
      if (!confirm(`Solo hay ${poolT.length} categorías publicadas. Algunas se repetirán en el tablero. ¿Continuar?`)) {
        mostrar(pSetup);
        sync({ fase: "setup-espera", jugadores: jugadoresSync() });
        return;
      }
    }
    const poolMuestreo = poolSinRecientes(poolT, 9);
    const barajados = barajar(poolMuestreo);
    const slugsN: string[] = [];
    for (let i = 0; i < 9; i++) slugsN.push(barajados[i % barajados.length]);
    marcarRecientes(slugsN);
    const _redistr = barajar(slugsN);
    slugsN.splice(0, slugsN.length, ..._redistr);
    casillasHost = slugsN.map((slug) => {
      const emoji = _esM(slug) ? (mundoSlugsEmoji[slug] ?? "🌍") : "🎬";
      const nombre = cineSlugsNombres[slug] ?? slug;
      return { catSlug: slug, catEmoji: emoji, catNombre: nombre, catNombres: null, catHardcoded: null, dueño: null, items: [], itemsOffset: 0, empateCuenta: 0 };
    });
    casillasSync = casillasHost.map(({ catSlug, catEmoji, catNombre, dueño }) => ({ catSlug, catEmoji, catNombre, dueño }));
    casillaDuelo = -1; tableroAtacante = 0;
    jugadores.forEach((j) => { j.decimas = DECIMAS_INICIO; j.eliminado = false; });
    sync({ fase: "tablero", jugadores: jugadoresSync(), casillas: casillasSync, casillaDuelo, tableroAtacante });
    renderTableroSync();
    mostrar(pTablero);
  }

  function renderTableroJugadores() {
    const src = rol === "host" ? (casillasHost as CasillaSync[]) : casillasSync;
    const cont = $("tablero-jugadores");
    cont.innerHTML = jugadores.map((j, i) => {
      const color = COLORES[i];
      const count = src.filter((c) => c.dueño === i).length;
      const activo = i === tableroAtacante;
      const estilo = activo
        ? `border:1px solid ${color};background:color-mix(in srgb, ${color} 10%, transparent)`
        : "border:1px solid transparent";
      return `<div class="flex items-center gap-1.5 px-2 py-1 rounded" style="${estilo}">
        <span class="inline-block w-3 h-3 rounded-sm shrink-0" style="background:${color};box-shadow:0 0 8px ${color}"></span>
        <span class="font-titulo font-bold text-[#e8e8ff] text-xs truncate max-w-[72px]">${escapeHTML(j.nombre)}</span>
        <span class="font-titulo font-bold text-lg tabular-nums" style="color:${color};text-shadow:0 0 12px ${color}">${count}</span>
      </div>`;
    }).join("");
  }

  function renderTableroSync() {
    const src = rol === "host" ? (casillasHost as CasillaSync[]) : casillasSync;
    renderTableroJugadores();
    const attackable = new Set(src.map((c, i) => c.dueño === null ? i : -1).filter((i) => i >= 0));
    const grid = $("tablero-grid");
    grid.innerHTML = "";
    src.forEach((c, idx) => {
      const btn = document.createElement("button");
      const bgClass = c.dueño === null ? "floor-square-neutral" : `floor-square-p${c.dueño}`;
      const esAtacable = attackable.has(idx) && tableroAtacante === miIndice;
      btn.className = [bgClass, "aspect-square rounded flex items-center justify-center text-4xl transition-transform", esAtacable ? "floor-square-attackable hover:scale-105 cursor-pointer" : "cursor-default"].join(" ");
      btn.textContent = c.catEmoji; btn.title = c.catNombre;
      if (esAtacable) btn.addEventListener("click", () => {
        if (rol === "host") mostrarPreDuelo(idx);
        else accion("casilla", { idx });
      });
      grid.appendChild(btn);
    });
    $("tablero-instruccion").textContent = tableroAtacante === miIndice
      ? "Elige una casilla"
      : `Turno de ${nombreDe(tableroAtacante)}`;
  }

  function mostrarPreDuelo(idx: number) {
    casillaDuelo = idx;
    const c = casillasHost[idx];
    $("preduel-emoji").textContent = c.catEmoji;
    $("preduel-nombre-cat").textContent = c.catNombre;
    const hostEsAtacante = tableroAtacante === miIndice;
    $("preduel-empezar").classList.toggle("hidden", !hostEsAtacante);
    $("preduel-espera").classList.toggle("hidden", hostEsAtacante);
    $("preduel-volver").classList.toggle("hidden", !hostEsAtacante);
    $("preduel-overlay").classList.remove("hidden");
    sync({ fase: "preduel", jugadores: jugadoresSync(), casillas: casillasSync, casillaDuelo: idx, tableroAtacante, preduelEmoji: c.catEmoji, preduelNombreCat: c.catNombre });
  }

  $("preduel-empezar").addEventListener("click", () => {
    if (tableroAtacante !== miIndice) return;
    $("preduel-overlay").classList.add("hidden");
    if (rol === "host") atacarCasilla(casillaDuelo);
    else accion("iniciar-duelo");
  });
  $("preduel-volver").addEventListener("click", () => {
    if (tableroAtacante !== miIndice) return;
    $("preduel-overlay").classList.add("hidden");
    if (rol === "host") {
      casillaDuelo = -1;
      sync({ fase: "tablero", jugadores: jugadoresSync(), casillas: casillasSync, casillaDuelo: -1, tableroAtacante });
      renderTableroSync();
    } else {
      accion("cancelar-preduel");
    }
  });

  async function atacarCasilla(idx: number) {
    sync({ fase: "cargando", jugadores: jugadoresSync() });
    mostrar(pLoader);
    const c = casillasHost[idx];
    if (c.items.length === 0) {
      try {
        let raw: ItemFloor[];
        const _esM = mundoSlugsAll.includes(c.catSlug);
        if (_esM) {
          raw = await cargarCatalogoMundo(c.catSlug);
        } else if (cineSlugsMetaMezcla[c.catSlug]) {
          raw = await cargarMezclaCine(cineSlugsMetaMezcla[c.catSlug]);
        } else {
          const derivado = cineSlugsDerivados[c.catSlug];
          raw = derivado
            ? await cargarCatalogoCinePeli(c.catSlug, derivado.baseSlug)
            : await cargarCatalogoCine(c.catSlug);
        }
        c.items = barajar(raw);
        c.itemsOffset = 0;
      } catch { mostrar(pTablero); renderTableroSync(); return; }
    }
    const off = c.itemsOffset;
    items = [...c.items.slice(off), ...c.items.slice(0, off)].slice(0, 20);
    categoriaSlug = c.catSlug;
    categoriaActual = c.catNombre;
    indice = 0; turno = tableroAtacante;
    terminado = false; bloqueado = false;
    if (gameTimeout) { clearTimeout(gameTimeout); gameTimeout = null; }
    jugadores.forEach((j) => { j.decimas = DECIMAS_INICIO; j.eliminado = false; });
    $("juego-categoria-label").textContent = categoriaActual;
    mostrar(pJuego);
    iniciarRenderLoop();
    iniciarTurno();
  }

  function terminarDueloTablero() {
    // La casilla es para quien conserve más tiempo. Si hay empate en cabeza,
    // se repite el duelo; al tercer empate se sortea entre los empatados.
    const maxDec = Math.max(...jugadores.map((j) => j.decimas));
    const lideres = jugadores.map((_, i) => i).filter((i) => jugadores[i].decimas === maxDec);
    let ganadorDuelo: number | null = lideres.length === 1 ? lideres[0] : null;
    if (ganadorDuelo === null && casillaDuelo >= 0) {
      casillasHost[casillaDuelo].empateCuenta++;
      if (casillasHost[casillaDuelo].empateCuenta >= 3) {
        ganadorDuelo = lideres[Math.floor(Math.random() * lideres.length)];
        casillasHost[casillaDuelo].empateCuenta = 0;
      }
    }
    if (ganadorDuelo !== null && casillaDuelo >= 0) {
      casillasHost[casillaDuelo].empateCuenta = 0;
      casillasHost[casillaDuelo].dueño = ganadorDuelo;
    }
    tableroAtacante = (tableroAtacante + 1) % jugadores.length;
    casillasSync = casillasHost.map(({ catSlug, catEmoji, catNombre, dueño }) => ({ catSlug, catEmoji, catNombre, dueño }));
    const conquistadas = casillasHost.filter((c) => c.dueño !== null).length;
    if (conquistadas === 9) { mostrarFinalTablero(); return; }
    jugadores.forEach((j) => { j.decimas = DECIMAS_INICIO; j.eliminado = false; });
    stopRenderLoop();
    casillaDuelo = -1;
    sync({ fase: "tablero", jugadores: jugadoresSync(), casillas: casillasSync, casillaDuelo: -1, tableroAtacante });
    // Asegurar que ningún overlay queda colgado al volver al tablero
    $("preduel-overlay").classList.add("hidden");
    $("overlay-acierto").classList.add("hidden");
    $("overlay-pase").classList.add("hidden");
    renderTableroSync();
    mostrar(pTablero);
  }

  function mostrarFinalTablero() {
    const counts = jugadores.map((_, i) => casillasHost.filter((c) => c.dueño === i).length);
    const maxC = Math.max(...counts);
    const lideres = counts.map((c, i) => i).filter((i) => counts[i] === maxC);
    const marcador = [...counts].sort((a, b) => b - a).join("-");
    trackEv("tablero-completado", { variante: tableroInfantil ? "infantil" : "adultos", marcador, jugadores: jugadores.length });
    const ganadorTexto = lideres.length === 1
      ? `🥇 Gana ${jugadores[lideres[0]].nombre} (${marcador})`
      : `¡Empate a ${maxC}! 🤝`;
    const orden = jugadores.map((_, i) => i).sort((a, b) => counts[b] - counts[a]);
    const cards = orden.map((i) => ({
      nombre: jugadores[i].nombre,
      color: COLORES[i],
      valor: String(counts[i]),
      label: "casillas",
    }));
    terminado = true;
    $("texto-ganador").textContent = ganadorTexto;
    renderFinalCards(cards);
    sync({ fase: "final", jugadores: jugadoresSync(), modo, ganadorTexto, cards });
    stopRenderLoop();
    mostrar(pFinal);
    lanzarConfeti();
  }

  // ── Navegación ─────────────────────────────────────────────
  function pedirConfirmacionSalir(titulo: string, mensaje: string, textoOk: string): Promise<boolean> {
    return new Promise((resolve) => {
      const modal = $("modal-salir");
      modal.querySelector("h3")!.textContent = titulo;
      modal.querySelector("p")!.textContent = mensaje;
      $("salir-confirmar").textContent = textoOk;
      modal.classList.remove("hidden");
      const ok = () => { cleanup(); resolve(true); };
      const no = () => { cleanup(); resolve(false); };
      const cleanup = () => {
        modal.classList.add("hidden");
        $("salir-confirmar").removeEventListener("click", ok);
        $("salir-cancelar").removeEventListener("click", no);
      };
      $("salir-confirmar").addEventListener("click", ok);
      $("salir-cancelar").addEventListener("click", no);
    });
  }

  $("boton-volver").addEventListener("click", async () => {
    // Desde la pantalla de entrada (sin conexión activa), salimos a la home
    if (!pEntrada.classList.contains("hidden")) {
      pararVoz(); stopRenderLoop();
      if (gameTimeout) clearTimeout(gameTimeout);
      window.location.href = "/";
      return;
    }
    // Desde Crear/Unirse (todavía sin sala montada), volver a la pantalla de entrada
    if (!pCrear.classList.contains("hidden") || !pUnirse.classList.contains("hidden")) {
      mostrar(pEntrada);
      return;
    }
    // Durante una partida activa (tablero o juego), volver al menú con confirmación
    if (!pTablero.classList.contains("hidden") || !pJuego.classList.contains("hidden")) {
      const ok = await pedirConfirmacionSalir(
        "¿Volver al menú?",
        "La partida actual se cancelará. Podréis empezar otra desde el menú.",
        "Sí, al menú",
      );
      if (!ok) return;
      pararVoz(); stopRenderLoop();
      if (gameTimeout) clearTimeout(gameTimeout);
      terminado = true;
      $("preduel-overlay").classList.add("hidden");
      $("overlay-acierto").classList.add("hidden");
      $("overlay-pase").classList.add("hidden");
      // Host vuelve al setup (elegir modo/categoría); guests pasan a "esperando"
      if (rol === "host") {
        sync({ fase: "setup-espera", jugadores: jugadoresSync() });
        mostrar(pSetup);
      } else {
        mostrar(pSetupGuest);
      }
      return;
    }
    // Desde sala/setup/loader/final: salir de la sala por completo
    const ok = await pedirConfirmacionSalir(
      "¿Salir de la sala?",
      "Perderás el código y se desconectará a los demás jugadores.",
      "Sí, salir",
    );
    if (!ok) return;
    pararVoz(); stopRenderLoop();
    if (gameTimeout) clearTimeout(gameTimeout);
    window.location.href = "/";
  });

  $("boton-revancha").addEventListener("click", () => {
    if (rol !== "host") return;
    terminado = true;
    sync({ fase: "setup-espera", jugadores: jugadoresSync() });
    mostrar(pSetup);
  });

  $("boton-menu-final").addEventListener("click", () => {
    pararVoz(); stopRenderLoop();
    // Volver al menú de elegir modo (manteniendo la sala). Si es host, sincroniza
    // a los guests a la pantalla de espera; los guests vuelven a esperar.
    if (rol === "host") {
      sync({ fase: "setup-espera", jugadores: jugadoresSync() });
      mostrar(pSetup);
    } else {
      mostrar(pSetupGuest);
    }
  });

  // ── Confeti ────────────────────────────────────────────────
  function lanzarConfeti() {
    const colores = ["#FF5757", "#FFD93D", "#4ECDC4", "#B084EE", "#95E1D3", "#FF6B9D"];
    const cont = $("confeti"); cont.innerHTML = "";
    for (let i = 0; i < 60; i++) {
      const t = document.createElement("div");
      const tam = 8 + Math.random() * 10;
      t.style.cssText = `position:absolute;top:-20px;left:${Math.random() * 100}%;width:${tam}px;height:${tam}px;background:${colores[Math.floor(Math.random() * colores.length)]};border:2px solid #1A1A1A;border-radius:${Math.random() > 0.5 ? "50%" : "4px"};animation:confeti ${2 + Math.random() * 2}s ${Math.random() * 1.5}s linear forwards;`;
      cont.appendChild(t);
    }
  }

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible" && !pJuego.classList.contains("hidden") && turno === miIndice && !bloqueado && !terminado) {
      reco?.resetOffset();
      $("texto-voz").textContent = "🎤 Escuchando...";
    }
  });
</script>
</Base>
</content>
