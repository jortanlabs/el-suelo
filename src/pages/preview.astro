---
export const prerender = true;
import { subcategorias } from "../data/catalogoCine.ts";
import { subcategoriasMundo, bloquesMundo } from "../data/catalogoMundo.ts";

const DEPORTES_B = new Set(["futbol", "baloncesto", "tenis", "golf", "ciclismo", "motor", "multideporte"]);
const ARTE_B = new Set(["musica", "arte", "literatura", "teatro", "moda"]);
const MARCAS_B = new Set(["compras"]);
const PERSONAS_B = new Set(["personas"]);

const leafSubcats = [
  ...subcategorias
    .filter((s) => !s.esMetaCategoria && !!s.nombres && !s.pendiente)
    .map((s) => ({ slug: s.slug, nombre: s.nombre, emoji: s.emoji, bloque: s.bloque, bloqueNombre: s.bloqueNombre, seccion: s.seccion ?? null, seccionNombre: s.seccionNombre ?? null, nombres: s.nombres!, dataPath: "cine", grupo: "cine" })),
  ...subcategoriasMundo
    .filter((s) => !s.esMetaCategoria && !!s.nombres)
    .map((s) => {
      let grupo = "mundo";
      if (DEPORTES_B.has(s.bloque)) grupo = "deportes";
      else if (ARTE_B.has(s.bloque)) grupo = "arte";
      else if (MARCAS_B.has(s.bloque)) grupo = "compras";
      else if (PERSONAS_B.has(s.bloque)) grupo = "personas";
      return { slug: s.slug, nombre: s.nombre, emoji: s.emoji, bloque: s.bloque, bloqueNombre: s.bloqueNombre, seccion: s.seccion ?? null, seccionNombre: s.seccionNombre ?? null, nombres: s.nombres!, dataPath: "mundo", grupo };
    }),
];

const BUILD = Date.now();
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — El Suelo</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body { background: #050c1e; color: #e8e8ff; font-family: system-ui, sans-serif; display: flex; flex-direction: column; height: 100dvh; overflow: hidden; }

    .topbar { background: #050c1e; border-bottom: 1px solid #163575; padding: 10px 16px; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
    .topbar h1 { color: #ffcc00; font-size: 1rem; font-weight: bold; }
    .ver { color: #163575; font-size: 0.65rem; }
    .topbar-spacer { flex: 1; }
    .btn-export-cur { padding: 5px 12px; background: #ffcc00; color: #050c1e; border: none; border-radius: 4px; font-size: 0.75rem; font-weight: bold; cursor: pointer; }
    .btn-export-cur:disabled { opacity: 0.4; cursor: default; }
    .btn-publish-block { display:flex; align-items:center; gap:4px; width:100%; padding:4px 12px 6px; background:transparent; border:none; color:#163575; font-size:0.62rem; cursor:pointer; text-align:left; }
    .btn-publish-block:hover { color:#ffcc00; }
    .pub-bar { background:#0a1628; border-radius:3px; height:4px; margin:2px 12px 6px; overflow:hidden; display:none; }
    .pub-bar-fill { height:100%; background:#ffcc00; width:0%; transition:width 0.3s; }

    .layout { display: flex; flex: 1; overflow: hidden; }

    /* Sidebar */
    .sidebar { width: 200px; flex-shrink: 0; border-right: 1px solid #163575; overflow-y: auto; }
    .sidebar-bloque { padding: 8px 12px 3px; font-size: 0.6rem; font-weight: bold; color: #2a5090; text-transform: uppercase; letter-spacing: 0.08em; }
    .sidebar-seccion { padding: 6px 12px 2px 16px; font-size: 0.58rem; font-weight: bold; color: #4a6fa5; text-transform: uppercase; letter-spacing: 0.06em; }
    .sidebar-btn { display: flex; align-items: center; gap: 6px; width: 100%; padding: 6px 12px; background: transparent; border: none; color: #2a5090; font-size: 0.75rem; text-align: left; cursor: pointer; border-left: 2px solid transparent; }
    .sidebar-btn:hover { color: #e8e8ff; background: #0a1628; }
    .sidebar-btn.active { color: #ffcc00; border-left-color: #ffcc00; background: #0d1e3a; }
    .sidebar-btn .sstat { margin-left: auto; font-size: 0.58rem; }

    /* Main */
    .main { flex: 1; overflow-y: auto; padding: 14px; }
    .panel-hdr { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
    .panel-title { font-size: 1rem; font-weight: bold; }
    .panel-stats { display: flex; gap: 6px; margin-left: auto; }
    .bok { background: #0d3a1a; color: #4cff8f; border: 1px solid #1a7a3a; padding: 2px 7px; border-radius: 3px; font-size: 0.62rem; }
    .bmiss { background: #3a0d1a; color: #ff6b8a; border: 1px solid #7a1a3a; padding: 2px 7px; border-radius: 3px; font-size: 0.62rem; }
    .panel-toolbar { margin-bottom: 12px; }
    .btn-add { padding: 4px 10px; background: transparent; color: #2a5090; border: 1px solid #163575; border-radius: 4px; font-size: 0.72rem; cursor: pointer; }
    .btn-add:hover { border-color: #ffcc00; color: #ffcc00; }

    /* Dialogs */
    dialog { background: #0d1e3a; border: 1px solid #163575; border-radius: 10px; padding: 20px; color: #e8e8ff; max-width: 400px; width: 92vw; }
    dialog::backdrop { background: rgba(5,12,30,0.92); }
    .dlg-title { color: #ffcc00; font-size: 0.95rem; font-weight: bold; margin-bottom: 12px; }
    .dlg-label { color: #2a5090; font-size: 0.7rem; margin-bottom: 4px; }
    .dlg-input { width: 100%; background: #050c1e; border: 1px solid #163575; color: #e8e8ff; padding: 8px; border-radius: 5px; font-size: 0.82rem; margin-bottom: 10px; }
    .dlg-input:focus { outline: none; border-color: #ffcc00; }
    .dlg-img-prev { width: 70px; height: 70px; object-fit: cover; border-radius: 4px; border: 1px solid #163575; display: none; margin-bottom: 10px; }
    .dlg-note { color: #2a5090; font-size: 0.68rem; margin-bottom: 10px; line-height: 1.4; }
    .dlg-actions { display: flex; gap: 8px; }
    .btn-ok { flex: 1; padding: 8px; background: #ffcc00; color: #050c1e; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; font-size: 0.82rem; }
    .btn-ok:hover { background: #ffe066; }
    .btn-cancel-dlg { flex: 1; padding: 8px; background: transparent; color: #2a5090; border: 1px solid #163575; border-radius: 5px; cursor: pointer; font-size: 0.82rem; }
    .btn-cancel-dlg:hover { color: #e8e8ff; border-color: #e8e8ff; }

    .empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 50%; gap: 10px; color: #2a5090; }
  </style>
</head>
<body>

<div class="topbar">
  <h1>🎬 El Suelo — Admin</h1>
  <span class="ver">v{BUILD}</span>
  <span class="topbar-spacer"></span>
  <button id="btn-reset-token" style="padding:5px 10px;background:transparent;color:#2a5090;border:1px solid #163575;border-radius:4px;font-size:0.72rem;cursor:pointer" title="Cambiar token de GitHub">🔑 Token</button>
  <button class="btn-export-cur" id="btn-export-cur" disabled>⬇ Exportar JSON</button>
</div>

<div class="layout">
  <nav class="sidebar" id="sidebar"></nav>
  <div class="main" id="main-panel">
    <div class="empty"><div style="font-size:2.5rem">👈</div><div>Elige una categoría</div></div>
  </div>
</div>

<!-- Dialog nombre -->
<dialog id="dlg-name">
  <div class="dlg-title">✏️ Editar nombre</div>
  <div class="dlg-label">Nombre que aparece en el juego</div>
  <input id="dlg-name-val" type="text" class="dlg-input" />
  <div class="dlg-actions">
    <button class="btn-cancel-dlg" id="dlg-name-cancel">Cancelar</button>
    <button class="btn-ok" id="dlg-name-ok">Guardar</button>
  </div>
</dialog>

<!-- Dialog imagen -->
<dialog id="dlg-img">
  <div class="dlg-title">🖼 Cambiar imagen</div>
  <div class="dlg-note">Pega la URL de cualquier imagen. Clic derecho sobre una foto en Google → "Copiar dirección de imagen".</div>
  <div class="dlg-label">URL de la imagen</div>
  <input id="dlg-img-val" type="url" class="dlg-input" placeholder="https://..." />
  <img id="dlg-img-prev" class="dlg-img-prev" alt="" />
  <div class="dlg-actions">
    <button class="btn-cancel-dlg" id="dlg-img-cancel">Cancelar</button>
    <button class="btn-ok" id="dlg-img-ok">Guardar</button>
  </div>
</dialog>

<!-- Dialog token GitHub -->
<dialog id="dlg-token">
  <div class="dlg-title">🔑 Token de GitHub</div>
  <div class="dlg-note">Para publicar directamente al repo. Ejecútalo una vez en la terminal: <code style="color:#ffcc00;background:#050c1e;padding:2px 5px;border-radius:3px">gh auth token</code> y pega el resultado aquí. Se guarda en este navegador.</div>
  <div class="dlg-label">Token</div>
  <input id="dlg-token-val" type="password" class="dlg-input" placeholder="gho_..." />
  <div class="dlg-actions">
    <button class="btn-cancel-dlg" id="dlg-token-cancel">Cancelar</button>
    <button class="btn-ok" id="dlg-token-ok">Guardar y publicar</button>
  </div>
</dialog>

<!-- Dialog progreso publicación -->
<dialog id="dlg-pub">
  <div class="dlg-title">🚀 Publicando...</div>
  <div id="dlg-pub-msg" style="color:#2a5090;font-size:0.78rem;margin-bottom:10px">Preparando...</div>
  <div style="background:#050c1e;border-radius:4px;height:6px;overflow:hidden;margin-bottom:12px">
    <div id="dlg-pub-bar" style="height:100%;background:#ffcc00;width:0%;transition:width 0.3s"></div>
  </div>
  <div id="dlg-pub-log" style="font-size:0.65rem;color:#2a5090;max-height:120px;overflow-y:auto;line-height:1.6"></div>
  <div class="dlg-actions" style="margin-top:12px">
    <button class="btn-ok" id="dlg-pub-close" style="display:none">✓ Cerrar</button>
  </div>
</dialog>

<!-- Dialog añadir -->
<dialog id="dlg-add">
  <div class="dlg-title">➕ Añadir item</div>
  <div class="dlg-label">Nombre</div>
  <input id="dlg-add-name" type="text" class="dlg-input" placeholder="Nombre del personaje / película" />
  <div class="dlg-label">URL de imagen (opcional)</div>
  <input id="dlg-add-img" type="url" class="dlg-input" placeholder="https://..." />
  <div class="dlg-actions">
    <button class="btn-cancel-dlg" id="dlg-add-cancel">Cancelar</button>
    <button class="btn-ok" id="dlg-add-ok">Añadir</button>
  </div>
</dialog>

<script define:vars={{ leafSubcats }}>
  // ── Constants ──────────────────────────────────────────────────
  const SZ = 60; // card image size in px
  const STORAGE_KEY = 'el-suelo:admin-edits-v3';
  let edits = {};
  // Load from current key, then migrate data from any old keys
  const OLD_KEYS = ['el-suelo:admin-v4', 'el-suelo:preview-edits-v2', 'el-suelo:preview-edits'];
  try {
    const s = localStorage.getItem(STORAGE_KEY);
    if (s) edits = JSON.parse(s);
    // Merge any edits saved under old keys
    for (const oldKey of OLD_KEYS) {
      const old = localStorage.getItem(oldKey);
      if (!old) continue;
      const oldEdits = JSON.parse(old);
      for (const [slug, slugData] of Object.entries(oldEdits)) {
        if (!edits[slug]) edits[slug] = {};
        Object.assign(edits[slug], slugData);
      }
      localStorage.removeItem(oldKey); // clean up old key
    }
    localStorage.setItem(STORAGE_KEY, JSON.stringify(edits));
  } catch {}
  const saveEdits = () => { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(edits)); } catch {} };

  const resolved = {};
  let currentSlug = null;
  let dialogCtx = null;
  let addSlug = null;
  let pendingPublishBloque = null;

  const GH_TOKEN_KEY = 'el-suelo:gh-token';
  const REPO = 'tanKobra/el-suelo';
  const BRANCH = 'master';

  // Global bloque registry (populated by buildSidebarGroup)
  const allGroups = {};

  // ── Sidebar ────────────────────────────────────────────────────
  const sidebar = document.getElementById('sidebar');

  function buildSidebarGroup(grupoSlug, grupoLabel, grupoEmoji, subcats) {
    // Collapsible section header
    const grupoWrap = document.createElement('div');
    let collapsed = false;
    const grupoBtn = document.createElement('button');
    grupoBtn.style.cssText = 'width:100%;padding:8px 12px;background:#0a1628;border:none;border-bottom:1px solid #163575;color:#ffcc00;font-size:0.75rem;font-weight:bold;text-align:left;cursor:pointer;display:flex;align-items:center;gap:6px;';
    grupoBtn.innerHTML = `<span>${grupoEmoji}</span><span style="flex:1">${grupoLabel}</span><span id="arr-${grupoSlug}" style="font-size:0.6rem">▾</span>`;
    const grupoBody = document.createElement('div');
    grupoBody.id = `grupo-body-${grupoSlug}`;
    grupoBtn.addEventListener('click', () => {
      collapsed = !collapsed;
      grupoBody.style.display = collapsed ? 'none' : '';
      document.getElementById(`arr-${grupoSlug}`).textContent = collapsed ? '▸' : '▾';
    });
    grupoWrap.appendChild(grupoBtn);
    grupoWrap.appendChild(grupoBody);

    // Group items by bloque and register globally
    const groups = {};
    for (const s of subcats) {
      if (!groups[s.bloque]) groups[s.bloque] = { nombre: s.bloqueNombre, items: [], dataPath: s.dataPath };
      groups[s.bloque].items.push(s);
    }
    Object.assign(allGroups, groups);
    const numBloques = Object.keys(groups).length;
    for (const [bloqueSlug, group] of Object.entries(groups)) {
      const sec = document.createElement('div');
      // Si solo hay un bloque en el grupo (caso compras/personas) y todos los items tienen seccion,
      // omitimos el label del bloque (sería redundante con el grupoLabel).
      const conSeccion = group.items.some(s => s.seccion);
      if (!(numBloques === 1 && conSeccion)) {
        const lbl = document.createElement('div');
        lbl.className = 'sidebar-bloque';
        lbl.textContent = group.nombre;
        sec.appendChild(lbl);
      }
      if (conSeccion) {
        // Agrupar items por sección, mantener orden de aparición
        const porSeccion = {};
        const ordenSecciones = [];
        for (const s of group.items) {
          const k = s.seccion ?? '_';
          if (!porSeccion[k]) { porSeccion[k] = { nombre: s.seccionNombre ?? '', items: [] }; ordenSecciones.push(k); }
          porSeccion[k].items.push(s);
        }
        for (const k of ordenSecciones) {
          const sg = porSeccion[k];
          if (sg.nombre) {
            const secLbl = document.createElement('div');
            secLbl.className = 'sidebar-seccion';
            secLbl.textContent = sg.nombre;
            sec.appendChild(secLbl);
          }
          for (const s of sg.items) {
            const btn = document.createElement('button');
            btn.className = 'sidebar-btn';
            btn.dataset.slug = s.slug;
            btn.innerHTML = `<span>${s.emoji} ${s.nombre}</span><span class="sstat" id="ss-${s.slug}" style="color:#163575"></span>`;
            btn.addEventListener('click', () => selectSlug(s.slug));
            sec.appendChild(btn);
          }
          // Botón de publicar por sección (p.ej. "Publicar Marcas" dentro del bloque Compras)
          if (sg.nombre) {
            const seccionId = `${bloqueSlug}__${k}`;
            allGroups[seccionId] = { nombre: sg.nombre, items: sg.items, dataPath: group.dataPath };
            const pubSecBtn = document.createElement('button');
            pubSecBtn.className = 'btn-publish-block';
            pubSecBtn.dataset.bloque = seccionId;
            pubSecBtn.textContent = `🚀 Publicar ${sg.nombre}`;
            pubSecBtn.addEventListener('click', () => iniciarPublicar(seccionId));
            const pubSecBar = document.createElement('div');
            pubSecBar.className = 'pub-bar';
            pubSecBar.id = `pubbar-${seccionId}`;
            pubSecBar.innerHTML = `<div class="pub-bar-fill" id="pubfill-${seccionId}"></div>`;
            sec.appendChild(pubSecBtn);
            sec.appendChild(pubSecBar);
          }
        }
      } else {
        for (const s of group.items) {
          const btn = document.createElement('button');
          btn.className = 'sidebar-btn';
          btn.dataset.slug = s.slug;
          btn.innerHTML = `<span>${s.emoji} ${s.nombre}</span><span class="sstat" id="ss-${s.slug}" style="color:#163575"></span>`;
          btn.addEventListener('click', () => selectSlug(s.slug));
          sec.appendChild(btn);
        }
      }
      const pubBtn = document.createElement('button');
      pubBtn.className = 'btn-publish-block';
      pubBtn.dataset.bloque = bloqueSlug;
      pubBtn.textContent = `🚀 Publicar ${group.nombre}`;
      pubBtn.addEventListener('click', () => iniciarPublicar(bloqueSlug));
      const pubBarWrap = document.createElement('div');
      pubBarWrap.className = 'pub-bar';
      pubBarWrap.id = `pubbar-${bloqueSlug}`;
      pubBarWrap.innerHTML = `<div class="pub-bar-fill" id="pubfill-${bloqueSlug}"></div>`;
      sec.appendChild(pubBtn);
      sec.appendChild(pubBarWrap);
      grupoBody.appendChild(sec);
    }
    sidebar.appendChild(grupoWrap);
  }

  const cineSubcats = leafSubcats.filter(s => s.grupo === 'cine');
  const mundoSubcats = leafSubcats.filter(s => s.grupo === 'mundo');
  const deportesSubcats = leafSubcats.filter(s => s.grupo === 'deportes');
  const arteSubcats = leafSubcats.filter(s => s.grupo === 'arte');
  const comprasSubcats = leafSubcats.filter(s => s.grupo === 'compras');
  const personasSubcats = leafSubcats.filter(s => s.grupo === 'personas');
  buildSidebarGroup('cine', 'Cine y Series', '🎬', cineSubcats);
  buildSidebarGroup('mundo', 'El Mundo', '🌍', mundoSubcats);
  buildSidebarGroup('deportes', 'Deportes', '⚽', deportesSubcats);
  buildSidebarGroup('arte', 'Arte', '🎨', arteSubcats);
  buildSidebarGroup('compras', 'Compras', '🛒', comprasSubcats);
  buildSidebarGroup('personas', 'Personas', '🧑', personasSubcats);

  // ── Select ─────────────────────────────────────────────────────
  async function selectSlug(slug) {
    currentSlug = slug;
    document.querySelectorAll('.sidebar-btn').forEach(b => b.classList.toggle('active', b.dataset.slug === slug));
    document.getElementById('btn-export-cur').disabled = false;
    if (!resolved[slug]) {
      renderMain(slug, null);
      const dp = (leafSubcats.find(s => s.slug === slug) || {}).dataPath || 'cine';
      try { const r = await fetch(`/data/${dp}/${slug}.json`); resolved[slug] = r.ok ? await r.json() : []; }
      catch { resolved[slug] = []; }
    }
    renderMain(slug, resolved[slug]);
    updateStat(slug);
  }

  // ── Render main ────────────────────────────────────────────────
  function renderMain(slug, items) {
    const panel = document.getElementById('main-panel');
    const subcat = leafSubcats.find(s => s.slug === slug);
    const slugEdits = edits[slug] || {};
    const resMap = {};
    if (items) for (const it of items) resMap[it.nombre] = it.imagen;

    const addedKeys = Object.keys(slugEdits).filter(k => k.startsWith('__new__'));
    // Nombres que están en el JSON publicado pero NO en subcat.nombres (sumados al JSON
    // sin actualizar nombres.ts). Aparecen igual aquí para poderles subir imagen.
    const subcatNombresSet = new Set(subcat.nombres);
    const extraFromJson = items
      ? items.map((it) => it.nombre).filter((n) => n && !subcatNombresSet.has(n))
      : [];
    // Dedup por key: si un nombre aparece dos veces (en subcat.nombres o por duplicado en
    // el JSON), se renderiza un solo card. Antes compartían key y al editar uno se
    // afectaba el otro.
    const seenKeys = new Set();
    const allEntries = [
      ...subcat.nombres.map(n => ({ key: n, orig: n })),
      ...extraFromJson.map(n => ({ key: n, orig: n })),
      ...addedKeys.map(k => ({ key: k, orig: slugEdits[k].nombre ?? k })),
    ].filter(({ key }) => {
      if (seenKeys.has(key)) return false;
      seenKeys.add(key);
      return true;
    });

    let nImg = 0;

    // Grid — inline styles for guaranteed sizing
    const grid = document.createElement('div');
    grid.style.cssText = `display:flex; flex-wrap:wrap; gap:6px;`;

    for (const { key, orig } of allEntries) {
      const e = slugEdits[key] || {};
      const deleted = !!e.deleted;
      const nombre = e.nombre ?? orig;
      const imagen = e.imagen !== undefined ? e.imagen : (resMap[orig] ?? null);
      if (imagen && !deleted) nImg++;

      // Card
      const card = document.createElement('div');
      card.style.cssText = `width:${SZ}px; border-radius:4px; overflow:hidden; background:#0a1628; border:1px solid ${imagen ? (Object.keys(e).length ? '#ffcc0066' : '#163575') : '#ff1dce33'}; ${deleted ? 'opacity:0.3;' : ''}`;
      card.dataset.slug = slug;
      card.dataset.key = key;

      // Image wrapper
      const wrap = document.createElement('div');
      wrap.style.cssText = `position:relative; width:${SZ}px; height:${SZ}px; overflow:hidden; background:#050c1e; cursor:pointer;`;
      wrap.dataset.action = 'img';

      if (imagen) {
        const img = document.createElement('img');
        img.src = imagen;
        img.style.cssText = `width:${SZ}px; height:${SZ}px; object-fit:cover; display:block;`;
        img.onerror = () => { img.style.display = 'none'; ph.style.display = 'flex'; };
        wrap.appendChild(img);
      }

      const ph = document.createElement('div');
      ph.style.cssText = `width:${SZ}px; height:${SZ}px; display:${imagen ? 'none' : 'flex'}; align-items:center; justify-content:center; font-size:1.2rem; color:#163575;`;
      ph.textContent = items ? '📷' : '⏳';
      wrap.appendChild(ph);

      // Hover overlay
      const overlay = document.createElement('div');
      overlay.style.cssText = `position:absolute; inset:0; background:rgba(5,12,30,0.82); color:#ffcc00; font-size:0.55rem; font-weight:bold; display:flex; align-items:center; justify-content:center; text-align:center; padding:4px; opacity:0; transition:opacity 0.15s; pointer-events:none;`;
      overlay.textContent = imagen ? '🖼 Cambiar' : '📷 Añadir';
      wrap.appendChild(overlay);
      wrap.addEventListener('mouseenter', () => overlay.style.opacity = '1');
      wrap.addEventListener('mouseleave', () => overlay.style.opacity = '0');
      card.appendChild(wrap);

      // Name
      const nameRow = document.createElement('div');
      nameRow.style.cssText = `display:flex; align-items:flex-start; gap:2px; padding:3px 3px 1px;`;
      const nameSpan = document.createElement('span');
      nameSpan.style.cssText = `font-size:0.52rem; color:#e8e8ff; flex:1; line-height:1.2; overflow:hidden;`;
      nameSpan.textContent = nombre;
      const pencil = document.createElement('button');
      pencil.style.cssText = `background:transparent; border:none; color:#2a5090; font-size:0.58rem; cursor:pointer; padding:0; flex-shrink:0;`;
      pencil.textContent = '✏';
      pencil.dataset.action = 'name';
      nameRow.appendChild(nameSpan);
      nameRow.appendChild(pencil);
      card.appendChild(nameRow);

      // Delete button
      const delBtn = document.createElement('button');
      delBtn.style.cssText = `display:block; width:100%; padding:2px; background:transparent; border:none; border-top:1px solid #163575; color:#2a5090; font-size:0.5rem; cursor:pointer;`;
      delBtn.textContent = deleted ? '↩' : '✕';
      delBtn.title = deleted ? 'Restaurar' : 'Quitar del juego';
      delBtn.dataset.action = 'del';
      card.appendChild(delBtn);

      grid.appendChild(card);
    }

    const nMissing = allEntries.length - nImg;
    const statsHtml = items
      ? `<span class="bok">✓ ${nImg}</span>${nMissing > 0 ? ` <span class="bmiss">⚠ ${nMissing} sin foto</span>` : ''}`
      : `<span style="color:#2a5090;font-size:0.72rem">Cargando…</span>`;

    panel.innerHTML = `
      <div class="panel-hdr">
        <span style="font-size:1.2rem">${subcat.emoji}</span>
        <span class="panel-title">${subcat.nombre}</span>
        <div class="panel-stats">${statsHtml}</div>
      </div>
      <div class="panel-toolbar" style="display:flex;gap:8px;align-items:center;">
        <button class="btn-add" id="btn-add-item">+ Añadir item</button>
        ${nMissing > 0 ? `<button class="btn-add" id="btn-filter-missing" style="border-color:#ff6b8a;color:#ff6b8a;">⚠ Ver ${nMissing} sin foto</button>` : ''}
      </div>
    `;
    panel.appendChild(grid);
    document.getElementById('btn-add-item').addEventListener('click', () => openAddDialog(slug));

    const btnFilter = document.getElementById('btn-filter-missing');
    if (btnFilter) {
      let filtered = false;
      btnFilter.addEventListener('click', () => {
        filtered = !filtered;
        btnFilter.textContent = filtered ? '✕ Ver todas' : `⚠ Ver ${nMissing} sin foto`;
        btnFilter.style.borderColor = filtered ? '#ffcc00' : '#ff6b8a';
        btnFilter.style.color = filtered ? '#ffcc00' : '#ff6b8a';
        grid.querySelectorAll('[data-slug]').forEach(card => {
          const key = card.dataset.key;
          const e = (edits[slug] || {})[key] || {};
          const orig = key.startsWith('__new__') ? (e.nombre ?? key) : key;
          const imagen = e.imagen !== undefined ? e.imagen : (resMap[orig] ?? null);
          card.style.display = (!filtered || !imagen) ? '' : 'none';
        });
      });
    }
  }

  // ── Event delegation ───────────────────────────────────────────
  document.getElementById('main-panel').addEventListener('click', e => {
    const target = e.target.closest('[data-action]');
    if (!target) return;
    const card = target.closest('[data-slug]');
    if (!card) return;
    const { slug, key } = card.dataset;
    const action = target.dataset.action;
    if (action === 'img') openImgDialog(slug, key);
    else if (action === 'name') openNameDialog(slug, key);
    else if (action === 'del') toggleDelete(slug, key);
  });

  // ── Sidebar stat ───────────────────────────────────────────────
  function updateStat(slug) {
    const el = document.getElementById(`ss-${slug}`);
    if (!el) return;
    const resMap = {};
    for (const it of (resolved[slug] || [])) resMap[it.nombre] = it.imagen;
    const slugEdits = edits[slug] || {};
    const subcat = leafSubcats.find(s => s.slug === slug);
    // Lista completa: nombres de subcat + extras que vienen del JSON
    const subcatNombresSet = new Set(subcat.nombres);
    const extraFromJson = (resolved[slug] || [])
      .map((it) => it.nombre)
      .filter((nn) => nn && !subcatNombresSet.has(nn));
    const todos = [...new Set([...subcat.nombres, ...extraFromJson])];
    let n = 0;
    for (const nombre of todos) {
      const ee = slugEdits[nombre] || {};
      if (!ee.deleted && (ee.imagen !== undefined ? ee.imagen : resMap[nombre])) n++;
    }
    const total = todos.length;
    el.textContent = ` ${n}/${total}`;
    el.style.color = n >= total ? '#4cff8f' : n > 0 ? '#ffcc00' : '#ff1dce88';
  }

  // ── Name dialog ────────────────────────────────────────────────
  function openNameDialog(slug, key) {
    const e = (edits[slug] || {})[key] || {};
    dialogCtx = { type: 'name', slug, key };
    const inp = document.getElementById('dlg-name-val');
    inp.value = e.nombre ?? (key.startsWith('__new__') ? '' : key);
    document.getElementById('dlg-name').showModal();
    setTimeout(() => inp.select(), 50);
  }
  document.getElementById('dlg-name-ok').addEventListener('click', () => {
    if (!dialogCtx || dialogCtx.type !== 'name') return;
    const { slug, key } = dialogCtx;
    const val = document.getElementById('dlg-name-val').value.trim();
    if (!val) return;
    if (!edits[slug]) edits[slug] = {};
    edits[slug][key] = { ...(edits[slug][key] || {}), nombre: val };
    saveEdits(); document.getElementById('dlg-name').close(); renderMain(slug, resolved[slug] || null);
  });
  document.getElementById('dlg-name-cancel').addEventListener('click', () => document.getElementById('dlg-name').close());
  document.getElementById('dlg-name-val').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('dlg-name-ok').click(); });

  // ── Img dialog ─────────────────────────────────────────────────
  function openImgDialog(slug, key) {
    const e = (edits[slug] || {})[key] || {};
    const resMap = {};
    for (const it of (resolved[slug] || [])) resMap[it.nombre] = it.imagen;
    const orig = key.startsWith('__new__') ? (e.nombre ?? '') : key;
    dialogCtx = { type: 'img', slug, key };
    const inp = document.getElementById('dlg-img-val');
    inp.value = e.imagen !== undefined ? (e.imagen ?? '') : (resMap[orig] ?? '');
    refreshPrev();
    document.getElementById('dlg-img').showModal();
    setTimeout(() => inp.select(), 50);
  }
  function refreshPrev() {
    const url = document.getElementById('dlg-img-val').value.trim();
    const prev = document.getElementById('dlg-img-prev');
    prev.style.display = url ? 'block' : 'none';
    if (url) prev.src = url;
  }
  document.getElementById('dlg-img-val').addEventListener('input', refreshPrev);
  document.getElementById('dlg-img-ok').addEventListener('click', () => {
    if (!dialogCtx || dialogCtx.type !== 'img') return;
    const { slug, key } = dialogCtx;
    const url = document.getElementById('dlg-img-val').value.trim();
    if (!edits[slug]) edits[slug] = {};
    edits[slug][key] = { ...(edits[slug][key] || {}), imagen: url || null };
    saveEdits(); document.getElementById('dlg-img').close();
    renderMain(slug, resolved[slug] || null); updateStat(slug);
  });
  document.getElementById('dlg-img-cancel').addEventListener('click', () => document.getElementById('dlg-img').close());

  // ── Delete ─────────────────────────────────────────────────────
  function toggleDelete(slug, key) {
    if (!edits[slug]) edits[slug] = {};
    edits[slug][key] = { ...(edits[slug][key] || {}), deleted: !edits[slug][key]?.deleted };
    saveEdits(); renderMain(slug, resolved[slug] || null); updateStat(slug);
  }

  // ── Add dialog ─────────────────────────────────────────────────
  function openAddDialog(slug) {
    addSlug = slug;
    document.getElementById('dlg-add-name').value = '';
    document.getElementById('dlg-add-img').value = '';
    document.getElementById('dlg-add').showModal();
    setTimeout(() => document.getElementById('dlg-add-name').focus(), 50);
  }
  document.getElementById('dlg-add-ok').addEventListener('click', () => {
    if (!addSlug) return;
    const nombre = document.getElementById('dlg-add-name').value.trim();
    const imagen = document.getElementById('dlg-add-img').value.trim();
    if (!nombre) return;
    if (!edits[addSlug]) edits[addSlug] = {};
    edits[addSlug]['__new__' + Date.now()] = { nombre, imagen: imagen || null };
    saveEdits(); document.getElementById('dlg-add').close();
    renderMain(addSlug, resolved[addSlug] || null);
  });
  document.getElementById('dlg-add-cancel').addEventListener('click', () => document.getElementById('dlg-add').close());

  // ── GitHub publish ─────────────────────────────────────────────
  function buildFinalItems(slug) {
    const subcat = leafSubcats.find(s => s.slug === slug);
    const resMap = {};
    for (const it of (resolved[slug] || [])) resMap[it.nombre] = it.imagen;
    const slugEdits = edits[slug] || {};
    const addedKeys = Object.keys(slugEdits).filter(k => k.startsWith('__new__'));
    const subcatNombresSet = new Set(subcat.nombres);
    const extraFromJson = (resolved[slug] || [])
      .map((it) => it.nombre)
      .filter((n) => n && !subcatNombresSet.has(n));
    const seenKeys = new Set();
    const allEntries = [
      ...subcat.nombres.map(n => ({ key: n, orig: n })),
      ...extraFromJson.map(n => ({ key: n, orig: n })),
      ...addedKeys.map(k => ({ key: k, orig: slugEdits[k].nombre ?? k })),
    ].filter(({ key }) => {
      if (seenKeys.has(key)) return false;
      seenKeys.add(key);
      return true;
    });
    const result = [];
    for (const { key, orig } of allEntries) {
      const e = slugEdits[key] || {};
      if (e.deleted) continue;
      const nombre = e.nombre ?? orig;
      const imagen = e.imagen !== undefined ? e.imagen : (resMap[orig] ?? null);
      // Antes filtrábamos items sin imagen (continue) y se perdían al publicar.
      // Ahora los guardamos con imagen vacía para conservar el slot — el juego
      // ya filtra los items sin imagen al cargarlos.
      result.push({ nombre, imagen: imagen || "" });
    }
    return result;
  }

  async function commitFile(slug, items, token, dataPath = 'cine') {
    const path = `public/data/${dataPath}/${slug}.json`;
    const apiBase = `https://api.github.com/repos/${REPO}/contents/${path}`;
    const headers = { Authorization: `token ${token}`, Accept: 'application/vnd.github.v3+json', 'Content-Type': 'application/json' };
    const content = btoa(unescape(encodeURIComponent(JSON.stringify(items, null, 2))));

    // Intentar hasta 3 veces: si GitHub devuelve un SHA "stale", re-fetcheamos y
    // reintentamos. Cada try añade un cache-buster para forzar GitHub a no servir caché.
    let lastError = null;
    for (let intento = 0; intento < 3; intento++) {
      let sha;
      try {
        const r = await fetch(`${apiBase}?ref=${BRANCH}&_=${Date.now()}`, { headers, cache: 'no-store' });
        if (r.ok) { const d = await r.json(); sha = d.sha; }
      } catch {}
      const body = { message: `admin: update ${slug}.json [skip ci]`, content, branch: BRANCH, ...(sha ? { sha } : {}) };
      const res = await fetch(apiBase, { method: 'PUT', headers, body: JSON.stringify(body) });
      if (res.ok) return;
      const err = await res.json().catch(() => ({}));
      const msg = err.message || String(res.status);
      lastError = new Error(msg);
      // Si es conflicto de SHA, esperamos 600 ms y reintentamos
      if (/does not match|sha/i.test(msg) && intento < 2) {
        await new Promise((r) => setTimeout(r, 600));
        continue;
      }
      throw lastError;
    }
    throw lastError ?? new Error('No se pudo publicar tras varios intentos');
  }

  function iniciarPublicar(bloqueSlug) {
    const token = localStorage.getItem(GH_TOKEN_KEY);
    if (token) {
      ejecutarPublicar(bloqueSlug, token);
    } else {
      pendingPublishBloque = bloqueSlug;
      document.getElementById('dlg-token-val').value = '';
      document.getElementById('dlg-token').showModal();
      setTimeout(() => document.getElementById('dlg-token-val').focus(), 50);
    }
  }

  document.getElementById('dlg-token-ok').addEventListener('click', () => {
    const token = document.getElementById('dlg-token-val').value.trim();
    if (!token) return;
    localStorage.setItem(GH_TOKEN_KEY, token);
    document.getElementById('dlg-token').close();
    if (pendingPublishBloque) ejecutarPublicar(pendingPublishBloque, token);
  });
  document.getElementById('dlg-token-cancel').addEventListener('click', () => document.getElementById('dlg-token').close());
  document.getElementById('btn-reset-token').addEventListener('click', () => {
    localStorage.removeItem(GH_TOKEN_KEY);
    document.getElementById('dlg-token-val').value = '';
    document.getElementById('dlg-token').showModal();
    setTimeout(() => document.getElementById('dlg-token-val').focus(), 50);
  });

  async function ejecutarPublicar(bloqueSlug, token) {
    const group = allGroups[bloqueSlug];
    const slugs = group.items.map(s => s.slug);
    const dataPath = group.dataPath || 'cine';
    const dlg = document.getElementById('dlg-pub');
    const msg = document.getElementById('dlg-pub-msg');
    const bar = document.getElementById('dlg-pub-bar');
    const log = document.getElementById('dlg-pub-log');
    const closeBtn = document.getElementById('dlg-pub-close');
    log.innerHTML = ''; closeBtn.style.display = 'none'; bar.style.width = '0%';
    dlg.showModal();

    // Load any unresolved JSONs first
    for (const slug of slugs) {
      if (!resolved[slug]) {
        msg.textContent = `Cargando ${slug}...`;
        try { const r = await fetch(`/data/${dataPath}/${slug}.json`); resolved[slug] = r.ok ? await r.json() : []; }
        catch { resolved[slug] = []; }
      }
    }

    let done = 0;
    const publishedSlugs = [];
    for (const slug of slugs) {
      msg.textContent = `Subiendo ${slug}... (${done + 1}/${slugs.length})`;
      bar.style.width = `${Math.round((done / slugs.length) * 100)}%`;
      try {
        const items = buildFinalItems(slug);
        await commitFile(slug, items, token, dataPath);
        publishedSlugs.push(slug);
        log.innerHTML += `<div style="color:#4cff8f">✓ ${slug} (${items.length} items)</div>`;
      } catch (e) {
        log.innerHTML += `<div style="color:#ff6b8a">✗ ${slug}: ${e.message}</div>`;
      }
      done++;
      log.scrollTop = log.scrollHeight;
    }

    // Update publicadas.json with newly published slugs
    if (publishedSlugs.length > 0) {
      try {
        msg.textContent = 'Actualizando lista de categorías publicadas...';
        const pubPath = 'public/data/publicadas.json';
        const apiBase = `https://api.github.com/repos/${REPO}/contents/${pubPath}`;
        const headers = { Authorization: `token ${token}`, Accept: 'application/vnd.github.v3+json', 'Content-Type': 'application/json' };
        let existing = [], sha;
        try {
          const r = await fetch(`${apiBase}?ref=${BRANCH}`, { headers });
          if (r.ok) { const d = await r.json(); sha = d.sha; existing = JSON.parse(atob(d.content.replace(/\n/g,''))); }
        } catch {}
        const merged = [...new Set([...existing, ...publishedSlugs])];
        const content = btoa(unescape(encodeURIComponent(JSON.stringify(merged, null, 2) + '\n')));
        await fetch(apiBase, { method: 'PUT', headers, body: JSON.stringify({ message: `admin: update publicadas.json`, content, branch: BRANCH, ...(sha ? { sha } : {}) }) });
        log.innerHTML += `<div style="color:#4cff8f">✓ publicadas.json actualizado (${merged.length} categorías)</div>`;
      } catch (e) {
        log.innerHTML += `<div style="color:#ff6b8a">✗ publicadas.json: ${e.message}</div>`;
      }
    }

    bar.style.width = '100%';
    msg.textContent = `✅ Publicado. Vercel está desplegando (~1 min)...`;
    msg.style.color = '#4cff8f';
    closeBtn.style.display = 'block';
  }

  document.getElementById('dlg-pub-close').addEventListener('click', () => {
    document.getElementById('dlg-pub').close();
    document.getElementById('dlg-pub-msg').style.color = '#2a5090';
  });

  // ── Export ─────────────────────────────────────────────────────
  function exportSlug(slug) {
    const subcat = leafSubcats.find(s => s.slug === slug);
    const resMap = {};
    for (const it of (resolved[slug] || [])) resMap[it.nombre] = it.imagen;
    const slugEdits = edits[slug] || {};
    const addedKeys = Object.keys(slugEdits).filter(k => k.startsWith('__new__'));
    const subcatNombresSet = new Set(subcat.nombres);
    const extraFromJson = (resolved[slug] || [])
      .map((it) => it.nombre)
      .filter((n) => n && !subcatNombresSet.has(n));
    const seenKeys = new Set();
    const allEntries = [
      ...subcat.nombres.map(n => ({ key: n, orig: n })),
      ...extraFromJson.map(n => ({ key: n, orig: n })),
      ...addedKeys.map(k => ({ key: k, orig: slugEdits[k].nombre ?? k })),
    ].filter(({ key }) => {
      if (seenKeys.has(key)) return false;
      seenKeys.add(key);
      return true;
    });
    const result = [];
    for (const { key, orig } of allEntries) {
      const e = slugEdits[key] || {};
      if (e.deleted) continue;
      const nombre = e.nombre ?? orig;
      const imagen = e.imagen !== undefined ? e.imagen : (resMap[orig] ?? null);
      if (!imagen) continue;
      result.push({ nombre, imagen });
    }
    const blob = new Blob([JSON.stringify(result, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = slug + '.json'; a.click();
    URL.revokeObjectURL(url);
  }
  document.getElementById('btn-export-cur').addEventListener('click', () => { if (currentSlug) exportSlug(currentSlug); });
</script>
</body>
