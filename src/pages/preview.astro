---
export const prerender = true;
import { subcategorias } from "../data/catalogoCine.ts";

// Only leaf subcategories (with names arrays, not metas)
const leafSubcats = subcategorias
  .filter((s) => !s.esMetaCategoria && !!s.nombres && !s.pendiente)
  .map((s) => ({ slug: s.slug, nombre: s.nombre, emoji: s.emoji, nombres: s.nombres! }));
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Preview — El Suelo Admin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      background: #050c1e;
      color: #e8e8ff;
      font-family: system-ui, sans-serif;
      margin: 0;
      padding: 16px;
    }
    h1 { color: #ffcc00; font-size: 1.5rem; margin: 0 0 4px; }
    .subtitle { color: #2a5090; font-size: 0.8rem; margin: 0 0 24px; }
    .subcat-section {
      background: #0a1628;
      border: 1px solid #163575;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 20px;
    }
    .subcat-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
    }
    .subcat-title { font-size: 1rem; font-weight: bold; color: #e8e8ff; }
    .subcat-slug { color: #2a5090; font-size: 0.7rem; }
    .subcat-stats { color: #2a5090; font-size: 0.75rem; margin-left: auto; }
    .items-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 8px;
    }
    .item-card {
      background: #050c1e;
      border: 1px solid #163575;
      border-radius: 6px;
      overflow: hidden;
      position: relative;
    }
    .item-card.no-img { border-color: #ff1dce44; }
    .item-card.edited { border-color: #ffcc00; }
    .item-card.deleted { opacity: 0.3; border-style: dashed; }
    .item-img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      display: block;
      background: #0a1628;
      cursor: pointer;
    }
    .item-img-placeholder {
      width: 100%;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0a1628;
      cursor: pointer;
      font-size: 2rem;
      color: #2a5090;
      border-bottom: 1px solid #163575;
    }
    .item-name {
      padding: 4px 6px;
      font-size: 0.65rem;
      color: #e8e8ff;
      cursor: pointer;
      border-top: 1px solid #163575;
      min-height: 28px;
      display: flex;
      align-items: center;
    }
    .item-name:hover { background: #0d1e3a; color: #ffcc00; }
    .item-actions {
      display: flex;
      gap: 2px;
      padding: 2px 4px 4px;
    }
    .btn-small {
      flex: 1;
      padding: 2px 4px;
      font-size: 0.6rem;
      background: #0a1628;
      border: 1px solid #163575;
      color: #2a5090;
      border-radius: 3px;
      cursor: pointer;
    }
    .btn-small:hover { border-color: #ffcc00; color: #ffcc00; }
    .btn-small.danger:hover { border-color: #ff1dce; color: #ff1dce; }
    .toolbar {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }
    .btn-export {
      padding: 4px 10px;
      background: #ffcc00;
      color: #050c1e;
      border: none;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: bold;
      cursor: pointer;
    }
    .btn-export:hover { background: #ffe066; }
    .btn-add {
      padding: 4px 10px;
      background: transparent;
      color: #2a5090;
      border: 1px solid #163575;
      border-radius: 4px;
      font-size: 0.75rem;
      cursor: pointer;
    }
    .btn-add:hover { border-color: #ffcc00; color: #ffcc00; }
    .loading-indicator { color: #2a5090; font-size: 0.75rem; }
    .badge-resolved { background: #0d3a1a; color: #4cff8f; border: 1px solid #1a7a3a; padding: 2px 6px; border-radius: 3px; font-size: 0.65rem; }
    .badge-missing { background: #3a0d1a; color: #ff6b8a; border: 1px solid #7a1a3a; padding: 2px 6px; border-radius: 3px; font-size: 0.65rem; }
    .top-bar {
      position: sticky;
      top: 0;
      background: #050c1e;
      padding: 8px 0 12px;
      z-index: 100;
      border-bottom: 1px solid #163575;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .filter-input {
      background: #0a1628;
      border: 1px solid #163575;
      color: #e8e8ff;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.8rem;
      width: 200px;
    }
    .filter-input:focus { outline: none; border-color: #ffcc00; }
    .btn-export-all {
      padding: 6px 14px;
      background: transparent;
      color: #ffcc00;
      border: 1px solid #ffcc00;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: bold;
      cursor: pointer;
    }
    .btn-export-all:hover { background: #ffcc0022; }
    dialog {
      background: #0a1628;
      border: 1px solid #163575;
      border-radius: 8px;
      padding: 20px;
      color: #e8e8ff;
      max-width: 400px;
      width: 90vw;
    }
    dialog::backdrop { background: rgba(5,12,30,0.9); }
    .dialog-title { color: #ffcc00; font-size: 1rem; font-weight: bold; margin: 0 0 12px; }
    .dialog-input {
      width: 100%;
      background: #050c1e;
      border: 1px solid #163575;
      color: #e8e8ff;
      padding: 8px;
      border-radius: 4px;
      font-size: 0.85rem;
      margin-bottom: 8px;
    }
    .dialog-input:focus { outline: none; border-color: #ffcc00; }
    .dialog-preview-img {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 4px;
      border: 1px solid #163575;
      margin-bottom: 8px;
    }
    .dialog-actions { display: flex; gap: 8px; margin-top: 12px; }
    .btn-confirm { flex: 1; padding: 8px; background: #ffcc00; color: #050c1e; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }
    .btn-cancel { flex: 1; padding: 8px; background: transparent; color: #2a5090; border: 1px solid #163575; border-radius: 4px; cursor: pointer; }
    #edit-img-preview { display: none; }
  </style>
</head>
<body>

<div class="top-bar">
  <div>
    <h1>🎬 Preview — El Suelo</h1>
    <p class="subtitle">Haz clic en un nombre para editarlo · clic en imagen para cambiarla · los cambios se guardan localmente</p>
  </div>
  <input type="text" class="filter-input" id="filter-input" placeholder="Buscar categoría..." />
  <button class="btn-export-all" onclick="exportarTodo()">⬇ Exportar todo</button>
</div>

<div id="categories-container"></div>

<!-- Diálogo de edición de nombre -->
<dialog id="dialog-name">
  <p class="dialog-title">✏️ Editar nombre</p>
  <input type="text" class="dialog-input" id="edit-name-input" placeholder="Nombre del item" />
  <div class="dialog-actions">
    <button class="btn-cancel" onclick="document.getElementById('dialog-name').close()">Cancelar</button>
    <button class="btn-confirm" onclick="confirmarNombre()">Guardar</button>
  </div>
</dialog>

<!-- Diálogo de edición de imagen -->
<dialog id="dialog-img">
  <p class="dialog-title">🖼 Cambiar imagen</p>
  <input type="text" class="dialog-input" id="edit-img-input" placeholder="URL de la imagen" oninput="previewImgChange()" />
  <img id="edit-img-preview" class="dialog-preview-img" alt="" />
  <div class="dialog-actions">
    <button class="btn-cancel" onclick="document.getElementById('dialog-img').close()">Cancelar</button>
    <button class="btn-confirm" onclick="confirmarImagen()">Guardar</button>
  </div>
</dialog>

<!-- Diálogo de añadir item -->
<dialog id="dialog-add">
  <p class="dialog-title">➕ Añadir item</p>
  <input type="text" class="dialog-input" id="add-name-input" placeholder="Nombre" />
  <input type="text" class="dialog-input" id="add-img-input" placeholder="URL de imagen (opcional)" />
  <div class="dialog-actions">
    <button class="btn-cancel" onclick="document.getElementById('dialog-add').close()">Cancelar</button>
    <button class="btn-confirm" onclick="confirmarAdd()">Añadir</button>
  </div>
</dialog>

<script define:vars={{ leafSubcats }}>
  // ── Data ──────────────────────────────────────────────────────
  // resolvedData[slug] = array of {nombre, imagen}
  const resolvedData = {};
  // edits[slug] = array of {nombre, imagen, deleted} (overrides)
  let edits = {};

  const STORAGE_KEY = 'el-suelo:preview-edits';
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) edits = JSON.parse(saved);
  } catch {}

  function saveEdits() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(edits)); } catch {}
  }

  // ── Build UI ──────────────────────────────────────────────────
  const container = document.getElementById('categories-container');

  for (const subcat of leafSubcats) {
    const section = document.createElement('div');
    section.className = 'subcat-section';
    section.dataset.slug = subcat.slug;
    section.innerHTML = `
      <div class="subcat-header">
        <span>${subcat.emoji}</span>
        <span class="subcat-title">${subcat.nombre}</span>
        <span class="subcat-slug">${subcat.slug}</span>
        <span class="subcat-stats" id="stats-${subcat.slug}">
          <span class="loading-indicator">Cargando...</span>
        </span>
      </div>
      <div class="toolbar">
        <button class="btn-export" onclick="exportarCategoria('${subcat.slug}')">⬇ Exportar JSON</button>
        <button class="btn-add" onclick="abrirAdd('${subcat.slug}')">+ Añadir item</button>
      </div>
      <div class="items-grid" id="grid-${subcat.slug}"></div>
    `;
    container.appendChild(section);

    // Load resolved JSON
    fetch(`/data/cine/${subcat.slug}.json`)
      .then(r => r.ok ? r.json() : [])
      .catch(() => [])
      .then(items => {
        resolvedData[subcat.slug] = items;
        renderGrid(subcat.slug, subcat.nombres);
      });
  }

  // ── Render grid ───────────────────────────────────────────────
  function renderGrid(slug, allNames) {
    const grid = document.getElementById(`grid-${slug}`);
    const resolved = resolvedData[slug] || [];
    const slugEdits = edits[slug] || {};
    const statsEl = document.getElementById(`stats-${slug}`);

    // Build a map: nombre -> imagen from resolved
    const resolvedMap = {};
    for (const it of resolved) {
      resolvedMap[it.nombre] = it.imagen;
    }

    // Merge: all names + any added in edits
    const addedNames = Object.keys(slugEdits).filter(k => k.startsWith('__new__'));
    const allItems = [...allNames, ...addedNames.map(k => slugEdits[k].nombre)];
    // Remove duplicates
    const seen = new Set();
    const unique = allItems.filter(n => {
      if (seen.has(n)) return false;
      seen.add(n);
      return true;
    });

    let resolvedCount = 0;
    let totalCount = 0;
    grid.innerHTML = '';

    for (const nombre of unique) {
      const editKey = nombre;
      const edit = slugEdits[editKey];
      const deleted = edit?.deleted;
      const editedNombre = edit?.nombre ?? nombre;
      const imagen = edit?.imagen ?? resolvedMap[nombre] ?? null;
      const hasImg = !!imagen;
      if (hasImg) resolvedCount++;
      totalCount++;

      const card = document.createElement('div');
      card.className = `item-card${!hasImg ? ' no-img' : ''}${edit ? ' edited' : ''}${deleted ? ' deleted' : ''}`;
      card.dataset.key = editKey;
      card.dataset.slug = slug;

      if (hasImg) {
        card.innerHTML = `
          <img class="item-img" src="${imagen}" alt="${editedNombre}"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            onclick="abrirEditImg('${slug}','${CSS.escape(editKey)}')" />
          <div class="item-img-placeholder" style="display:none" onclick="abrirEditImg('${slug}','${CSS.escape(editKey)}')">📷</div>
        `;
      } else {
        card.innerHTML = `
          <div class="item-img-placeholder" onclick="abrirEditImg('${slug}','${CSS.escape(editKey)}')">📷</div>
        `;
      }

      card.innerHTML += `
        <div class="item-name" onclick="abrirEditNombre('${slug}','${CSS.escape(editKey)}')">${editedNombre}</div>
        <div class="item-actions">
          <button class="btn-small danger" onclick="eliminarItem('${slug}','${CSS.escape(editKey)}')">${deleted ? '↩ Restaurar' : '✕'}</button>
        </div>
      `;
      grid.appendChild(card);
    }

    const resolvedBadge = `<span class="badge-resolved">✓ ${resolvedCount} con imagen</span>`;
    const missingBadge = totalCount - resolvedCount > 0
      ? ` <span class="badge-missing">⚠ ${totalCount - resolvedCount} sin imagen</span>`
      : '';
    statsEl.innerHTML = resolvedBadge + missingBadge;
  }

  // ── Edit nombre ───────────────────────────────────────────────
  let editCtx = null;
  function abrirEditNombre(slug, key) {
    const slugEdits = edits[slug] || {};
    const edit = slugEdits[key];
    const currentName = edit?.nombre ?? key;
    editCtx = { slug, key };
    const input = document.getElementById('edit-name-input');
    input.value = currentName;
    document.getElementById('dialog-name').showModal();
    setTimeout(() => { input.select(); }, 50);
  }
  function confirmarNombre() {
    if (!editCtx) return;
    const { slug, key } = editCtx;
    const newName = document.getElementById('edit-name-input').value.trim();
    if (!newName) return;
    if (!edits[slug]) edits[slug] = {};
    edits[slug][key] = { ...edits[slug][key], nombre: newName };
    saveEdits();
    document.getElementById('dialog-name').close();
    renderGrid(slug, leafSubcats.find(s => s.slug === slug)?.nombres || []);
  }

  // ── Edit imagen ───────────────────────────────────────────────
  function abrirEditImg(slug, key) {
    const slugEdits = edits[slug] || {};
    const edit = slugEdits[key];
    const resolved = resolvedData[slug] || [];
    const resolvedMap = {};
    for (const it of resolved) resolvedMap[it.nombre] = it.imagen;
    const currentImg = edit?.imagen ?? resolvedMap[key] ?? '';
    editCtx = { slug, key };
    const input = document.getElementById('edit-img-input');
    input.value = currentImg;
    previewImgChange();
    document.getElementById('dialog-img').showModal();
    setTimeout(() => { input.select(); }, 50);
  }
  function previewImgChange() {
    const url = document.getElementById('edit-img-input').value.trim();
    const prev = document.getElementById('edit-img-preview');
    if (url) { prev.src = url; prev.style.display = 'block'; }
    else prev.style.display = 'none';
  }
  function confirmarImagen() {
    if (!editCtx) return;
    const { slug, key } = editCtx;
    const newImg = document.getElementById('edit-img-input').value.trim();
    if (!edits[slug]) edits[slug] = {};
    edits[slug][key] = { ...edits[slug][key], imagen: newImg || null };
    saveEdits();
    document.getElementById('dialog-img').close();
    renderGrid(slug, leafSubcats.find(s => s.slug === slug)?.nombres || []);
  }

  // ── Eliminar / restaurar ──────────────────────────────────────
  function eliminarItem(slug, key) {
    if (!edits[slug]) edits[slug] = {};
    const current = edits[slug][key]?.deleted;
    edits[slug][key] = { ...edits[slug][key], deleted: !current };
    saveEdits();
    renderGrid(slug, leafSubcats.find(s => s.slug === slug)?.nombres || []);
  }

  // ── Añadir item ───────────────────────────────────────────────
  let addCtx = null;
  function abrirAdd(slug) {
    addCtx = slug;
    document.getElementById('add-name-input').value = '';
    document.getElementById('add-img-input').value = '';
    document.getElementById('dialog-add').showModal();
  }
  function confirmarAdd() {
    if (!addCtx) return;
    const slug = addCtx;
    const nombre = document.getElementById('add-name-input').value.trim();
    const imagen = document.getElementById('add-img-input').value.trim();
    if (!nombre) return;
    if (!edits[slug]) edits[slug] = {};
    const newKey = `__new__${Date.now()}`;
    edits[slug][newKey] = { nombre, imagen: imagen || null };
    saveEdits();
    document.getElementById('dialog-add').close();
    renderGrid(slug, leafSubcats.find(s => s.slug === slug)?.nombres || []);
  }

  // ── Exportar ──────────────────────────────────────────────────
  function buildExportData(slug) {
    const resolved = resolvedData[slug] || [];
    const slugEdits = edits[slug] || {};
    const allNames = leafSubcats.find(s => s.slug === slug)?.nombres || [];

    const resolvedMap = {};
    for (const it of resolved) resolvedMap[it.nombre] = it.imagen;

    const addedKeys = Object.keys(slugEdits).filter(k => k.startsWith('__new__'));
    const allItems = [...allNames, ...addedKeys.map(k => slugEdits[k].nombre)];
    const seen = new Set();
    const unique = allItems.filter(n => { if (seen.has(n)) return false; seen.add(n); return true; });

    const result = [];
    for (const nombre of unique) {
      const edit = slugEdits[nombre];
      if (edit?.deleted) continue;
      const editedNombre = edit?.nombre ?? nombre;
      const imagen = edit?.imagen ?? resolvedMap[nombre] ?? null;
      if (!imagen) continue; // only export items with images
      result.push({ nombre: editedNombre, imagen });
    }
    return result;
  }

  function exportarCategoria(slug) {
    const data = buildExportData(slug);
    const json = JSON.stringify(data, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${slug}.json`;
    a.click();
    URL.revokeObjectURL(url);
  }

  function exportarTodo() {
    for (const subcat of leafSubcats) {
      setTimeout(() => exportarCategoria(subcat.slug), 100 * leafSubcats.indexOf(subcat));
    }
  }

  // ── Filtro ────────────────────────────────────────────────────
  document.getElementById('filter-input').addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('.subcat-section').forEach(el => {
      const slug = el.dataset.slug;
      const subcat = leafSubcats.find(s => s.slug === slug);
      const visible = !q || subcat.nombre.toLowerCase().includes(q) || slug.includes(q);
      el.style.display = visible ? '' : 'none';
    });
  });
</script>
</body>
</html>
