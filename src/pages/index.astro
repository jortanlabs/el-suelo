---
export const prerender = true;
import Base from "../layouts/Base.astro";
import { categoriasFloor } from "../data/categoriasFloor.ts";
import { bloques, subcategorias } from "../data/catalogoCine.ts";

// Categorías "otras" (todo excepto la antigua 'actores' que sustituimos con Cine y Series)
const otrasFloor = categoriasFloor
  .filter((c) => c.slug !== "actores")
  .map((c) => ({ slug: c.slug, nombre: c.nombre, emoji: c.emoji, tipo: "otras" as const }));

// Jerarquía Cine y Series para el picker (excluye pendientes)
const cineBloques = bloques.map((b) => ({
  slug: b.slug,
  nombre: b.nombre,
  emoji: b.emoji,
  subcats: subcategorias
    .filter((s) => s.bloque === b.slug && !s.pendiente)
    .map((s) => ({
      slug: s.slug,
      nombre: s.nombre,
      emoji: s.emoji,
      esMeta: !!s.esMetaCategoria,
      subslugs: s.subcategorias ?? null,
    })),
}));

// Todos los slugs disponibles — el filtro por "publicadas" ocurre en runtime (cargarPublicadas)
import { subcategoriasMundo, bloquesMundo } from "../data/catalogoMundo.ts";

// Cine: slug → nombre para todos los slugs directos + derivados + mezclas
const cineSlugsNombres: Record<string, string> = Object.fromEntries(
  subcategorias
    .filter((s) => !s.esMetaCategoria && !s.pendiente && !s.derivadoDe && !!s.nombres)
    .map((s) => [s.slug, s.nombre])
);

const cineSlugsDerivados: Record<string, { baseSlug: string }> = {};
for (const s of subcategorias) {
  if (s.derivadoDe && s.modoDerivado === "pelicula") {
    cineSlugsDerivados[s.slug] = { baseSlug: s.derivadoDe };
    cineSlugsNombres[s.slug] = s.nombre;
  }
}

const cineSlugsMetaMezcla: Record<string, string[]> = {};
for (const s of subcategorias) {
  if (!s.esMetaCategoria && s.subcategorias?.length && !s.derivadoDe && !s.pendiente) {
    cineSlugsMetaMezcla[s.slug] = s.subcategorias;
    cineSlugsNombres[s.slug] = s.nombre;
  }
}

// Mundo: slug → nombre para todos los slugs disponibles
const mundoSlugsNombres: Record<string, string> = Object.fromEntries(
  subcategoriasMundo
    .filter((s) => !s.esMetaCategoria && !!s.nombres)
    .map((s) => [s.slug, s.nombre])
);

// Mundo: slug → grupo macro (mundo | deportes | arte | marcas | personas)
const DEPORTES_BLOQUES = new Set(["futbol", "baloncesto", "tenis", "golf", "ciclismo", "motor", "multideporte"]);
const ARTE_BLOQUES = new Set(["musica", "arte", "literatura", "teatro", "moda"]);
const MARCAS_BLOQUES = new Set(["compras"]);
const PERSONAS_BLOQUES = new Set(["personas"]);
const mundoSlugsGrupo: Record<string, string> = Object.fromEntries(
  subcategoriasMundo
    .filter((s) => !s.esMetaCategoria && !!s.nombres)
    .map((s) => {
      let grupo = "mundo";
      if (DEPORTES_BLOQUES.has(s.bloque)) grupo = "deportes";
      else if (ARTE_BLOQUES.has(s.bloque)) grupo = "arte";
      else if (MARCAS_BLOQUES.has(s.bloque)) grupo = "compras";
      else if (PERSONAS_BLOQUES.has(s.bloque)) grupo = "personas";
      return [s.slug, grupo];
    })
);

const bloqueEmojiMap: Record<string, string> = Object.fromEntries(
  bloquesMundo.map((b) => [b.slug, b.emoji])
);
const mundoSlugsEmoji: Record<string, string> = Object.fromEntries(
  subcategoriasMundo
    .filter((s) => !s.esMetaCategoria && !!s.nombres)
    .map((s) => [s.slug, bloqueEmojiMap[s.bloque] ?? "🌍"])
);

// Slugs marcados como aptos para el modo infantil (chip "🧒 Infantil")
const slugsInfantiles: string[] = [
  ...subcategorias.filter((s) => s.paraNinos && !!s.nombres && !s.esMetaCategoria).map((s) => s.slug),
  ...subcategoriasMundo.filter((s) => s.paraNinos && !!s.nombres && !s.esMetaCategoria).map((s) => s.slug),
];
---

<Base titulo="El Suelo" descripcion="Adivina más rápido que el rival. Gana al reloj.">
  <!-- Datos para JS (no visibles) -->
  <div id="datos-otras" data-json={JSON.stringify(otrasFloor)} class="hidden"></div>
  <div id="datos-cine" data-json={JSON.stringify(cineBloques)} class="hidden"></div>
  <div id="datos-cine-nombres" data-json={JSON.stringify(cineSlugsNombres)} class="hidden"></div>
  <div id="datos-cine-derivados" data-json={JSON.stringify(cineSlugsDerivados)} class="hidden"></div>
  <div id="datos-cine-mezcla" data-json={JSON.stringify(cineSlugsMetaMezcla)} class="hidden"></div>
  <div id="datos-mundo-nombres" data-json={JSON.stringify(mundoSlugsNombres)} class="hidden"></div>
  <div id="datos-mundo-grupo" data-json={JSON.stringify(mundoSlugsGrupo)} class="hidden"></div>
  <div id="datos-mundo-emoji" data-json={JSON.stringify(mundoSlugsEmoji)} class="hidden"></div>
  <div id="datos-infantiles" data-json={JSON.stringify(slugsInfantiles)} class="hidden"></div>

  <main id="floor-root" class="h-dvh flex flex-col overflow-hidden">
    <nav class="px-4 pb-3 flex items-center border-b-2 border-[#2a5090]" style="padding-top: max(0.75rem, env(safe-area-inset-top))">
      <button id="boton-volver" class="font-titulo text-lg font-bold text-[#a8c5ff] hover:text-[#e8e8ff] transition py-1 px-2" aria-label="Volver atrás">
        ← Volver
      </button>
      <button id="boton-ajustes" class="ml-auto font-titulo text-3xl text-[#a8c5ff] hover:text-[#ffcc00] transition py-1 px-2" title="Ajustes" aria-label="Ajustes">⚙️</button>
    </nav>

    <!-- BIENVENIDA -->
    <section id="pantalla-bienvenida" class="flex-1 flex flex-col items-center justify-center px-6 py-6 overflow-y-auto gap-8">
      <div class="text-center">
        <div class="inline-block relative px-12 py-4 mb-4">
          <span class="floor-corner floor-corner-tl"></span>
          <span class="floor-corner floor-corner-tr"></span>
          <span class="floor-corner floor-corner-bl"></span>
          <span class="floor-corner floor-corner-br"></span>
          <h1 class="font-titulo text-5xl font-bold neon-gold uppercase tracking-[0.3em]">El suelo</h1>
        </div>
        <p class="text-[#a8c5ff] font-titulo text-lg mt-2">Adivina más rápido que el rival. Gana al reloj.</p>
      </div>

      <div class="w-full max-w-xs flex flex-col items-center gap-4">
        <button id="boton-jugar" class="floor-btn floor-btn-gold w-full font-titulo font-bold text-3xl py-6 tracking-widest uppercase">
          ¡Jugar!
        </button>

        <a id="link-multi" href="/multi" data-astro-prefetch="viewport" class="floor-btn w-full font-titulo font-bold text-xl py-4 tracking-widest uppercase text-center" style="color:#a8c5ff;border-color:#a8c5ff;">
          📱 2 Móviles
        </a>

        <button id="banner-reto" class="hidden font-titulo font-bold text-sm px-4 py-2.5 mt-1 rounded transition-colors" style="color:#ff1dce;background:rgba(255,29,206,0.08);border:1px solid #ff1dce66">
          <span id="banner-reto-texto">🎯 Reto de hoy</span>
        </button>
      </div>
    </section>

    <!-- RETO DIARIO — INTRO -->
    <section id="pantalla-reto-intro" class="flex-1 flex flex-col items-center justify-center px-6 py-6 hidden gap-6">
      <p class="font-titulo text-sm text-[#7b9ef5] uppercase tracking-widest">Reto del día · <span id="reto-fecha"></span></p>
      <div id="reto-intro-emoji" class="text-8xl"></div>
      <h2 id="reto-intro-cat" class="font-titulo text-4xl font-bold text-[#ffcc00] uppercase tracking-wider text-center leading-tight"></h2>
      <div class="floor-card-small px-6 py-4 max-w-xs">
        <p class="font-titulo text-base text-[#e8e8ff] text-center">⏱ 30 segundos · 🎯 hasta 20 aciertos</p>
        <p class="font-titulo text-xs text-[#7b9ef5] text-center mt-1">Pasar resta 3 segundos.</p>
      </div>
      <button id="reto-empezar" class="floor-btn floor-btn-gold font-titulo font-bold text-2xl px-12 py-5 uppercase tracking-wider">¡Empezar! →</button>
    </section>

    <!-- RETO DIARIO — JUEGO -->
    <section id="pantalla-reto-juego" class="flex-1 hidden flex-col items-center justify-center gap-4 px-4 py-4 relative">
      <div class="absolute top-3 left-4 right-4 flex items-center justify-between">
        <span id="reto-juego-cat" class="font-titulo text-xs text-[#7b9ef5] uppercase tracking-wider"></span>
        <span id="reto-juego-aciertos" class="font-titulo text-base font-bold text-[#ffcc00]">0 / 20</span>
      </div>
      <div id="reto-juego-tiempo" class="font-titulo text-6xl font-bold neon-gold tabular-nums">30.0</div>
      <div class="relative w-full max-w-sm aspect-square floor-card overflow-hidden flex items-center justify-center bg-[#050c1e]">
        <img id="reto-imagen" alt="" class="hidden w-full h-full object-contain" />
        <div id="reto-imagen-ph" class="text-4xl text-[#163575]">📷</div>
        <div id="reto-overlay-respuesta" class="hidden absolute inset-0 flex flex-col items-center justify-center px-4 text-center" style="background:rgba(255,29,206,0.92)">
          <p class="font-titulo text-xs text-[#07070f] uppercase tracking-widest font-bold">⏭ Paso · Era</p>
          <p id="reto-overlay-nombre" class="font-titulo text-2xl font-bold text-[#07070f] mt-2"></p>
        </div>
      </div>
      <p id="reto-texto-voz" class="font-titulo text-sm text-[#a8c5ff] text-center min-h-[1.5rem]"></p>
      <button id="reto-pasar" class="floor-btn font-titulo font-bold text-lg px-8 py-3" style="color:#a8c5ff;border-color:#a8c5ff">⏭ Paso (–3s)</button>
    </section>

    <!-- RETO DIARIO — FINAL -->
    <section id="pantalla-reto-final" class="flex-1 hidden flex-col items-center justify-center gap-5 px-6 py-6 overflow-y-auto">
      <p class="font-titulo text-sm text-[#7b9ef5] uppercase tracking-widest">Reto del día · <span id="reto-final-fecha"></span></p>
      <div id="reto-final-emoji" class="text-6xl"></div>
      <p id="reto-final-cat" class="font-titulo text-2xl font-bold text-[#e8e8ff] text-center"></p>
      <div class="floor-card px-10 py-6">
        <p class="font-titulo text-sm text-[#7b9ef5] uppercase tracking-widest text-center">Aciertos</p>
        <p id="reto-final-score" class="font-titulo text-7xl font-bold neon-gold text-center tabular-nums">0</p>
        <p id="reto-final-de" class="font-titulo text-xs text-[#7b9ef5] text-center">de 20</p>
      </div>
      <button id="reto-compartir" class="floor-btn floor-btn-gold font-titulo font-bold text-lg px-8 py-3">📤 Compartir resultado</button>
      <div id="reto-historial" class="w-full max-w-xs hidden">
        <p class="font-titulo text-xs text-[#7b9ef5] uppercase tracking-widest mb-2 text-center">Tus últimos retos</p>
        <div id="reto-historial-lista" class="space-y-1"></div>
      </div>
      <p class="font-titulo text-sm text-[#a8c5ff] text-center">Vuelve mañana para el nuevo reto.</p>
    </section>

    <!-- SETUP -->
    <section id="pantalla-setup" class="flex-1 overflow-y-auto px-4 py-4 hidden flex flex-col items-center justify-center gap-4">
      <div class="text-center">
        <div class="inline-block relative px-8 py-2">
          <span class="floor-corner floor-corner-tl"></span>
          <span class="floor-corner floor-corner-tr"></span>
          <span class="floor-corner floor-corner-bl"></span>
          <span class="floor-corner floor-corner-br"></span>
          <h1 class="font-titulo text-4xl font-bold neon-gold uppercase tracking-[0.3em]">El suelo</h1>
        </div>
      </div>

      <div class="w-full max-w-sm flex flex-col items-center gap-6">
        <h2 class="font-titulo text-3xl font-bold text-[#ffcc00] uppercase tracking-wider text-center leading-tight">¿Quién juega?</h2>
        <div class="w-full space-y-4">
          <div>
            <label class="font-titulo font-bold text-[#ff1dce] text-sm block mb-1 uppercase tracking-widest">Jugador 1</label>
            <input id="nombre-a" type="text" placeholder="Tu nombre" maxlength="20" class="floor-input floor-input-a py-3 text-lg" />
          </div>
          <div>
            <label class="font-titulo font-bold text-[#ffe100] text-sm block mb-1 uppercase tracking-widest">Jugador 2</label>
            <input id="nombre-b" type="text" placeholder="Tu nombre" maxlength="20" class="floor-input floor-input-b py-3 text-lg" />
          </div>
        </div>
        <button id="boton-nombres-siguiente" class="floor-btn floor-btn-a w-full font-titulo font-bold text-xl px-4 py-4">Continuar →</button>
        <p id="error-setup" class="hidden text-sm text-[#ff1dce] text-center font-bold"></p>
      </div>
    </section>

    <!-- ELEGIR MODO (entre bienvenida y nombres) -->
    <section id="pantalla-modo" class="flex-1 flex flex-col items-center justify-center px-6 py-6 hidden gap-8">
      <h2 class="font-titulo text-3xl font-bold text-[#ffcc00] uppercase tracking-wider text-center leading-tight">¿Cómo jugáis?</h2>
      <div class="w-full max-w-xs flex flex-col gap-4">
        <button id="modo-rapida-elegir" class="floor-btn floor-btn-a w-full font-titulo font-bold text-2xl py-6 uppercase">⚡ Partida rápida</button>
        <p class="text-sm text-[#a8c5ff] font-titulo text-center -mt-2">Un tema. Dura hasta que se acaba el tiempo de uno.</p>
        <button id="modo-tablero-elegir" class="floor-btn floor-btn-gold w-full font-titulo font-bold text-2xl py-6 uppercase">🏁 Tablero</button>
        <p class="text-sm text-[#a8c5ff] font-titulo text-center -mt-2">9 casillas con temas sorpresa. Gana quien más conquiste.</p>
      </div>
    </section>

    <!-- VARIANTE DEL TABLERO (Adultos / Infantil) -->
    <section id="pantalla-tablero-variante" class="flex-1 flex flex-col items-center justify-center px-6 py-6 hidden gap-8">
      <h2 class="font-titulo text-3xl font-bold text-[#ffcc00] uppercase tracking-wider text-center leading-tight">¿Qué tablero?</h2>
      <div class="w-full max-w-xs flex flex-col gap-4">
        <button id="tablero-adultos" class="floor-btn floor-btn-gold w-full font-titulo font-bold text-2xl py-6 uppercase">🎯 Adultos</button>
        <p class="text-sm text-[#a8c5ff] font-titulo text-center -mt-2">9 casillas de cualquier tema publicado.</p>
        <button id="tablero-infantil" class="floor-btn w-full font-titulo font-bold text-2xl py-6 uppercase text-[#a8c5ff]" style="border-color:#a8c5ff">🧒 Infantil</button>
        <p class="text-sm text-[#a8c5ff] font-titulo text-center -mt-2">Solo temas aptos para niños (Disney, animales, banderas…).</p>
      </div>
      <p id="error-tablero-variante" class="hidden text-sm text-[#ff1dce] text-center font-bold"></p>
    </section>

    <!-- ELEGIR CATEGORÍA (solo para modo rápida) -->
    <section id="pantalla-categoria" class="flex-1 flex flex-col items-center justify-center px-6 py-6 hidden gap-6">
      <h2 class="font-titulo text-3xl font-bold text-[#ffcc00] uppercase tracking-wider text-center leading-tight">Elige tema</h2>
      <div class="w-full max-w-sm grid grid-cols-2 gap-3">
        <button data-filtro="cine" class="floor-btn px-3 py-5 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🎬<br>Cine y Series</button>
        <button data-filtro="mundo" class="floor-btn px-3 py-5 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🌍<br>El Mundo</button>
        <button data-filtro="deportes" class="floor-btn px-3 py-5 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">⚽<br>Deportes</button>
        <button data-filtro="arte" class="floor-btn px-3 py-5 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🎨<br>Arte</button>
        <button data-filtro="compras" class="floor-btn px-3 py-5 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🛒<br>Compras</button>
        <button data-filtro="personas" class="floor-btn px-3 py-5 text-base font-titulo text-[#a8c5ff] leading-tight" style="border-color:#a8c5ff">🧑<br>Personas</button>
        <button data-filtro="aleatorio" class="floor-btn floor-btn-gold col-span-2 px-3 py-5 text-xl font-titulo font-bold">🎲 Aleatorio</button>
        <button data-filtro="infantil" class="floor-btn col-span-2 px-3 py-4 text-lg font-titulo font-bold text-[#a8c5ff]" style="border-color:#a8c5ff">🧒 Infantil</button>
      </div>
      <p id="error-categoria" class="hidden text-sm text-[#ff1dce] text-center font-bold"></p>
    </section>

    <!-- LOADER -->
    <section id="pantalla-loader" class="flex-1 flex items-center justify-center px-4 py-8 hidden">
      <div class="text-center">
        <div class="text-6xl mb-4 wiggle inline-block">🔍</div>
        <p id="loader-cat-name" class="font-titulo text-xl font-bold text-[#ffcc00] mb-1"></p>
        <h2 class="font-titulo text-2xl font-bold text-[#e8e8ff] mb-2">Cargando imágenes...</h2>
        <p id="loader-progreso" class="text-[#7b9ef5] text-sm font-titulo">Un momento.</p>
      </div>
    </section>

    <!-- TABLERO -->
    <section id="pantalla-tablero" class="flex-1 flex flex-col overflow-hidden hidden relative" style="touch-action:none;overscroll-behavior:none">
      <div class="px-4 py-3 flex items-center justify-center gap-3 border-b-2 border-[#163575] shrink-0">
        <span class="inline-block w-4 h-4 rounded-sm bg-[#ff1dce]" style="box-shadow:0 0 10px #ff1dce"></span>
        <span id="tablero-nombre-a" class="font-titulo font-bold text-[#e8e8ff] text-sm"></span>
        <span id="tablero-count-a" class="font-titulo font-bold text-xl tabular-nums neon-a"></span>
        <span class="font-titulo text-[#7b9ef5] text-sm px-2 font-bold">VS</span>
        <span id="tablero-count-b" class="font-titulo font-bold text-xl tabular-nums neon-b"></span>
        <span id="tablero-nombre-b" class="font-titulo font-bold text-[#e8e8ff] text-sm"></span>
        <span class="inline-block w-4 h-4 rounded-sm bg-[#ffe100]" style="box-shadow:0 0 10px #ffe100"></span>
      </div>

      <div class="flex-1 flex flex-col items-center justify-center px-4 py-4 min-h-0">
        <div id="tablero-grid" class="grid grid-cols-3 gap-3 w-full max-w-sm"></div>
      </div>

      <div class="px-4 py-3 text-center shrink-0">
        <p id="tablero-instruccion" class="font-titulo text-sm font-bold text-[#7b9ef5] uppercase tracking-wider"></p>
        <button id="boton-reportar-tablero" onclick="abrirModalReportar()" class="hidden mt-2 font-titulo text-xs text-[#7b9ef5] hover:text-[#ff4444] transition-colors underline">🚩 Reportar categoría anterior</button>
      </div>

      <div id="preduel-overlay" class="hidden absolute inset-0 flex flex-col items-center justify-center z-20 px-8" style="background:#07070fee">
        <p class="text-xs text-[#7b9ef5] font-titulo uppercase tracking-widest mb-2">Categoría del duelo</p>
        <div id="preduel-emoji" class="text-6xl my-2"></div>
        <p id="preduel-nombre-cat" class="font-titulo font-bold text-2xl text-[#e8e8ff] text-center mb-8"></p>
        <button id="preduel-empezar" class="floor-btn floor-btn-a font-titulo font-bold text-xl px-8 py-4">¡A jugar! →</button>
        <button id="preduel-volver" class="mt-4 font-titulo text-sm text-[#7b9ef5] hover:text-[#e8e8ff] transition-colors underline">← Volver al tablero</button>
      </div>
    </section>

    <!-- JUEGO -->
    <section id="pantalla-juego" class="flex-1 flex flex-col hidden select-none min-h-0 overflow-hidden" style="touch-action:none;overscroll-behavior:none">
      <div class="flex-1 flex items-stretch min-h-0 px-2 pt-2 pb-1 gap-2">
        <div id="zona-a" class="shrink-0 w-16 flex flex-col items-center justify-center rounded transition-all">
          <span id="timer-a" class="font-titulo font-bold tabular-nums text-4xl leading-none text-center floor-timer"></span>
          <span id="nombre-a-display" class="font-titulo text-sm font-bold mt-1 text-center truncate w-full px-1"></span>
        </div>

        <div class="flex-1 flex flex-col items-center min-w-0 min-h-0 relative">
          <p id="juego-cat-label" class="text-xl text-[#ffcc00] font-titulo text-center max-w-xs px-2 pt-1 font-bold uppercase tracking-wider leading-tight shrink-0"></p>
          <div class="flex-1 w-full flex flex-col items-center justify-center gap-2">
            <div class="w-full max-w-xs">
              <div class="floor-image-box">
                <img id="imagen-item" src="" alt="" class="absolute inset-0 w-full h-full object-contain hidden" />
                <span id="imagen-placeholder" class="absolute inset-0 flex items-center justify-center text-5xl text-[#163575] font-titulo font-bold text-center px-2">📷</span>
                <div id="overlay-acierto" class="floor-overlay-ok hidden">
                  <span class="font-titulo text-6xl font-bold text-[#07070f]">✓</span>
                  <span id="overlay-nombre" class="font-titulo text-sm font-bold text-[#07070f] mt-1 text-center px-2"></span>
                </div>
                <div id="overlay-pase" class="floor-overlay-pass hidden">
                  <span class="font-titulo text-2xl font-bold text-[#07070f]">Pasado →</span>
                  <span id="overlay-pase-nombre" class="font-titulo text-sm font-bold text-[#07070f] mt-1 text-center px-2"></span>
                </div>
              </div>
            </div>
            <p id="texto-voz" class="text-sm text-[#a8c5ff] font-titulo text-center max-w-xs px-2 min-h-[24px]"></p>
            <button id="boton-pasar" class="floor-btn floor-btn-gold font-titulo font-bold py-3 text-base w-full max-w-xs">Pasar (−3 s)</button>
          </div>
