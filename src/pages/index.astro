<script>
  import {
    generarFloorPredefinida,
    type ItemFloor,
    crearReconocedor,
    navegadorSoportaVoz,
    type ReconocedorVoz,
    aciertoFlexible,
    cargarCatalogoCine,
    cargarCatalogoCinePeli,
    cargarCatalogoMundo,
    cargarMezclaCine,
    cargarPublicadas,
  } from "../lib/floor-client.ts";
  import {
    TIEMPO_RETO_S,
    MAX_ITEMS_RETO,
    PENALIZACION_PASE_S,
    diaHoy,
    categoriaRetoHoy,
    subsetReto,
    leerResultadoHoy,
    guardarResultado,
    leerHistorial,
    textoCompartir,
    type ResultadoReto,
  } from "../lib/reto-diario.ts";
  import { categoriasFloor as todasCatsOtras } from "../data/categoriasFloor.ts";

  // ── Analytics helper ────────────────────────────────────────
  // Envía un custom event a Vercel Analytics. El script (_vercel/insights/
  // script.js) se carga desde Base.astro y expone window.va.
  function trackEv(nombre: string, props?: Record<string, string | number | boolean>) {
    try {
      (window as unknown as { va?: (a: string, b: Record<string, unknown>) => void }).va?.("event", { name: nombre, ...(props ?? {}) });
    } catch {}
  }

  // ── Datos del servidor ───────────────────────────────────────
  interface SubcatMeta {
    slug: string;
    nombre: string;
    emoji: string;
    esMeta: boolean;
    subslugs: string[] | null;
  }
  interface BloqueMeta {
    slug: string;
    nombre: string;
    emoji: string;
    subcats: SubcatMeta[];
  }
  interface OtrasCat {
    slug: string;
    nombre: string;
    emoji: string;
    tipo: "otras";
  }

  const cineBloques: BloqueMeta[] = JSON.parse(
    (document.getElementById("datos-cine") as HTMLElement).dataset.json!,
  );
  const otrasFloor: OtrasCat[] = JSON.parse(
    (document.getElementById("datos-otras") as HTMLElement).dataset.json!,
  );
  const cineSlugsNombres: Record<string, string> = JSON.parse(
    (document.getElementById("datos-cine-nombres") as HTMLElement).dataset.json!,
  );
  const cineSlugsDerivados: Record<string, { baseSlug: string }> = JSON.parse(
    (document.getElementById("datos-cine-derivados") as HTMLElement).dataset.json!,
  );
  const cineSlugsMetaMezcla: Record<string, string[]> = JSON.parse(
    (document.getElementById("datos-cine-mezcla") as HTMLElement).dataset.json!,
  );
  const mundoSlugsNombres: Record<string, string> = JSON.parse(
    (document.getElementById("datos-mundo-nombres") as HTMLElement).dataset.json!,
  );
  const mundoSlugsGrupo: Record<string, string> = JSON.parse(
    (document.getElementById("datos-mundo-grupo") as HTMLElement).dataset.json!,
  );
  const mundoSlugsEmoji: Record<string, string> = JSON.parse(
    (document.getElementById("datos-mundo-emoji") as HTMLElement).dataset.json!,
  );

  // Construye el pool jugable filtrando por la lista publicada (cargada en runtime)
  function construirPool(pub: string[]): string[] {
    const pool: string[] = [];
    for (const slug of Object.keys(cineSlugsNombres)) {
      const d = cineSlugsDerivados[slug];
      const m = cineSlugsMetaMezcla[slug];
      if (d) { if (pub.includes(d.baseSlug)) pool.push(slug); }
      else if (m) { if (m.every((s) => pub.includes(s))) pool.push(slug); }
      else if (pub.includes(slug)) pool.push(slug);
    }
    for (const slug of Object.keys(mundoSlugsNombres)) {
      if (pub.includes(slug)) pool.push(slug);
    }
    return pool;
  }

  const $ = (id: string) => document.getElementById(id)!;

  const pBienvenida = $("pantalla-bienvenida");
  const pModo = $("pantalla-modo");
  const pTableroVariante = $("pantalla-tablero-variante");
  const pSetup = $("pantalla-setup");
  const pCategoria = $("pantalla-categoria");
  const pLoader = $("pantalla-loader");
  const pTablero = $("pantalla-tablero");
  const pJuego = $("pantalla-juego");
  const pFinal = $("pantalla-final");
  const pRetoIntro = $("pantalla-reto-intro");
  const pRetoJuego = $("pantalla-reto-juego");
  const pRetoFinal = $("pantalla-reto-final");

  function mostrar(p: HTMLElement) {
    [pBienvenida, pModo, pTableroVariante, pSetup, pCategoria, pLoader, pTablero, pJuego, pFinal, pRetoIntro, pRetoJuego, pRetoFinal].forEach((s) => s.classList.add("hidden"));
    p.classList.remove("hidden");
    // El botón "← Volver" solo es útil cuando estás dentro del flujo
    const esSuperficial = p === pBienvenida;
    $("boton-volver").classList.toggle("invisible", esSuperficial);
  }

  // Ocultar el botón de volver en la pantalla inicial
  $("boton-volver").classList.add("invisible");

  // Flujo: bienvenida → modo → nombres → (categoría si rápida) → juego
  $("boton-jugar").addEventListener("click", () => mostrar(pModo));
  $("boton-menu").addEventListener("click", () => mostrar(pModo));

  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.register("/el-suelo-sw.js").catch(() => {});
  }

  // ── Modo de juego (paso 2: elegir Rápida o Tablero) ────────
  let modo: "rapida" | "tablero" = "rapida";
  let modoElegido = false;

  $("modo-rapida-elegir").addEventListener("click", () => {
    modo = "rapida"; modoElegido = true;
    mostrar(pSetup);
  });
  $("modo-tablero-elegir").addEventListener("click", () => {
    modo = "tablero"; modoElegido = true;
    mostrar($("pantalla-tablero-variante"));
  });
  $("tablero-adultos").addEventListener("click", () => {
    tableroInfantil = false;
    mostrar(pSetup);
  });
  $("tablero-infantil").addEventListener("click", () => {
    tableroInfantil = true;
    mostrar(pSetup);
  });

  // Lista de slugs marcados como infantiles (compartida con tablero y rápida)
  const slugsInfantiles: string[] = JSON.parse(
    document.getElementById("datos-infantiles")!.dataset.json!,
  );
  const setInfantiles = new Set(slugsInfantiles);
  let tableroInfantil = false;

  // ── Filtro de categoría (paso 4 para Rápida) ──────────────
  let categoriaFiltro: "cine" | "mundo" | "deportes" | "arte" | "compras" | "personas" | "aleatorio" | "infantil" = "aleatorio";

  function arrancarConCategoria(filtro: typeof categoriaFiltro) {
    categoriaFiltro = filtro;
    iniciarPartidaRapida();
  }

  // Cada botón de categoría arranca directamente la partida
  for (const btn of document.querySelectorAll<HTMLElement>('#pantalla-categoria [data-filtro]')) {
    const filtro = btn.dataset.filtro as typeof categoriaFiltro;
    btn.addEventListener("click", () => arrancarConCategoria(filtro));
  }

  // ── Categoría ───────────────────────────────────────────────
  type CategoriaTipo = "otras" | "cine";
  let categoriaTipo: CategoriaTipo = "cine";
  let categoriaSlug = "";
  let categoriaNombre = "";
  let categoriaSlugsParaMezcla: string[] | null = null;
  let categoriaDataPath = "cine"; // "cine" | "mundo"

    // ── Estado de juego ─────────────────────────────────────────
  interface Jugador {
    nombre: string;
    decimas: number;
  }

  let items: ItemFloor[] = [];
  let indice = 0;
  let turno: "A" | "B" = "A";
  let categoriaActual = "";
  let jug: { A: Jugador; B: Jugador };
  let tick: ReturnType<typeof setInterval> | null = null;
  let reco: ReconocedorVoz | null = null;
  let bloqueado = false;
  let terminado = false;

  // ── Estado de tablero ────────────────────────────────────────
  interface Casilla {
    catSlug: string;
    catEmoji: string;
    catNombre: string;
    catTipo: "otras" | "cine";
    catNombres: string[] | null;
    catHardcoded: ItemFloor[] | null;
    dueño: "A" | "B" | null;
    items: ItemFloor[];
    itemsOffset: number;
    empateCuenta: number;
  }

  let casillas: Casilla[] = [];
  let casillaDuelo = -1;
  let tableroAtacante: "A" | "B" = "A";

  // ── Recordar nombres entre sesiones ────────────────────────
  const NOMBRES_KEY = "el-suelo:nombres";
  try {
    const saved = JSON.parse(localStorage.getItem(NOMBRES_KEY) ?? "null");
    if (saved && typeof saved === "object") {
      if (saved.a) ($("nombre-a") as HTMLInputElement).value = saved.a;
      if (saved.b) ($("nombre-b") as HTMLInputElement).value = saved.b;
    }
  } catch {}

  // ── Empezar ─────────────────────────────────────────────────
  // Nombres guardados al pulsar "Continuar →"
  let nombreAGuardado = "Jugador A";
  let nombreBGuardado = "Jugador B";

  function leerYValidarNombres(): boolean {
    const errEl = $("error-setup");
    errEl.classList.add("hidden");
    nombreAGuardado = (($("nombre-a") as HTMLInputElement).value.trim()) || "Jugador A";
    nombreBGuardado = (($("nombre-b") as HTMLInputElement).value.trim()) || "Jugador B";
    try { localStorage.setItem(NOMBRES_KEY, JSON.stringify({ a: nombreAGuardado, b: nombreBGuardado })); } catch {}
    return true;
  }

  // Paso 3: tras escribir los nombres, se avanza según el modo
  $("boton-nombres-siguiente").addEventListener("click", async () => {
    if (!leerYValidarNombres()) return;
    if (modo === "tablero") {
      await iniciarPartidaTablero();
    } else {
      mostrar(pCategoria);
    }
  });

  async function iniciarPartidaTablero() {
    const errEl = $("error-setup");
    errEl.classList.add("hidden");
    const pub = await cargarPublicadas();
    let pool = construirPool(pub);
    if (tableroInfantil) pool = pool.filter((s) => setInfantiles.has(s));
    if (pool.length === 0) {
      errEl.textContent = tableroInfantil
        ? "No hay temas infantiles publicados aún."
        : "No hay categorías publicadas aún.";
      errEl.classList.remove("hidden"); return;
    }
    if (pool.length < 9) {
      if (!confirm(`Solo hay ${pool.length} categorías publicadas. Algunas se repetirán en el tablero. ¿Continuar?`)) return;
    }
    pararVoz();
    trackEv("partida-iniciada", { modo: "tablero", variante: tableroInfantil ? "infantil" : "adultos", pool_size: pool.length });
    initTablero(nombreAGuardado, nombreBGuardado, pool);
    mostrar(pTablero);
  }

  async function iniciarPartidaRapida() {
    const errEl = $("error-categoria");
    errEl.classList.add("hidden");
    const pub = await cargarPublicadas();
    const pool = construirPool(pub);
    const esMundoSlug = (s: string) => mundoSlugsNombres[s] !== undefined && cineSlugsNombres[s] === undefined;
    const poolFiltrado = categoriaFiltro === "cine"
      ? pool.filter((s) => !esMundoSlug(s))
      : categoriaFiltro === "aleatorio"
      ? pool
      : categoriaFiltro === "infantil"
      ? pool.filter((s) => setInfantiles.has(s))
      : pool.filter((s) => mundoSlugsGrupo[s] === categoriaFiltro);

    if (poolFiltrado.length === 0) {
      const _nF: Record<string, string> = { mundo: "El Mundo", deportes: "Deportes", arte: "Arte", compras: "Compras", personas: "Personas", infantil: "Infantil" };
      errEl.textContent = _nF[categoriaFiltro]
        ? "No hay categorías de " + _nF[categoriaFiltro] + " publicadas aún."
        : "No hay categorías publicadas aún.";
      errEl.classList.remove("hidden");
      return;
    }

    const _slug = poolFiltrado[Math.floor(Math.random() * poolFiltrado.length)];
    const _esMundo = mundoSlugsNombres[_slug] !== undefined && cineSlugsNombres[_slug] === undefined;
    categoriaTipo = "cine";
    categoriaSlug = _slug;
    categoriaDataPath = _esMundo ? "mundo" : "cine";
    categoriaSlugsParaMezcla = cineSlugsMetaMezcla[_slug] ?? null;
    categoriaNombre = mundoSlugsNombres[_slug] ?? cineSlugsNombres[_slug] ?? _slug;

    trackEv("partida-iniciada", { modo: "rapida", filtro: categoriaFiltro, categoria: _slug });
    pararVoz();
    mostrar(pLoader);
    $("loader-progreso").textContent = "Cargando…";
    $("loader-cat-name").textContent = _esMundo ? `🌍 El Mundo · ${categoriaNombre}` : `🎬 ${categoriaNombre}`;

    try {
      let raw: ItemFloor[];
      if (categoriaSlugsParaMezcla) {
        raw = await cargarMezclaCine(categoriaSlugsParaMezcla);
      } else if (categoriaDataPath === "mundo") {
        raw = await cargarCatalogoMundo(categoriaSlug);
      } else {
        const derivado = cineSlugsDerivados[categoriaSlug];
        raw = derivado
          ? await cargarCatalogoCinePeli(categoriaSlug, derivado.baseSlug)
          : await cargarCatalogoCine(categoriaSlug);
      }
      categoriaActual = categoriaNombre;
      $("juego-cat-label").textContent = _esMundo ? `🌍 El Mundo · ${categoriaNombre}` : `🎬 ${categoriaNombre}`;

      items = [...raw].sort(() => Math.random() - 0.5);
      jug = {
        A: { nombre: nombreAGuardado, decimas: 450 },
        B: { nombre: nombreBGuardado, decimas: 450 },
      };
      indice = 0;
      turno = "A";
      terminado = false;
      $("nombre-a-display").textContent = nombreAGuardado;
      $("nombre-b-display").textContent = nombreBGuardado;
      $("final-nombre-a").textContent = nombreAGuardado;
      $("final-nombre-b").textContent = nombreBGuardado;
      mostrar(pJuego);
      iniciarTurno();
    } catch (e) {
      pararVoz();
      const msg = e instanceof Error ? e.message : "Error";
      errEl.textContent = `No se pudo cargar: ${msg}`;
      errEl.classList.remove("hidden");
      mostrar(pCategoria);
    }
  }

  // ── Tablero ──────────────────────────────────────────────────
  function initTablero(nombreA: string, nombreB: string, poolCine: string[]) {
    // Selección sin repetición: barajar y tomar 9; si hay menos de 9 slugs, rellenar cíclicamente con la mínima repetición
    const barajados = [...poolCine].sort(() => Math.random() - 0.5);
    const slugsN: string[] = [];
    for (let i = 0; i < 9; i++) slugsN.push(barajados[i % barajados.length]);
    slugsN.sort(() => Math.random() - 0.5);
    casillas = slugsN.map((slug) => {
      const esMundo = mundoSlugsNombres[slug] !== undefined && cineSlugsNombres[slug] === undefined;
      let emoji: string;
      let nombre: string;
      if (esMundo) {
        emoji = mundoSlugsEmoji[slug] ?? "🌍";
        nombre = mundoSlugsNombres[slug] ?? slug;
      } else {
        const meta = cineBloques.flatMap((b) => b.subcats).find((s) => s.slug === slug);
        emoji = meta?.emoji ?? "🎬";
        nombre = meta?.nombre ?? cineSlugsNombres[slug] ?? slug;
      }
      return {
        catSlug: slug,
        catEmoji: emoji,
        catNombre: nombre,
        catTipo: "cine" as const,
        catNombres: null,
        catHardcoded: null,
        dueño: null as "A" | "B" | null,
        items: [] as ItemFloor[],
        itemsOffset: 0,
        empateCuenta: 0,
      };
    });

    casillaDuelo = -1;
    tableroAtacante = "A";
    jug = {
      A: { nombre: nombreA, decimas: 450 },
      B: { nombre: nombreB, decimas: 450 },
    };

    $("tablero-nombre-a").textContent = nombreA;
    $("tablero-nombre-b").textContent = nombreB;
    $("final-nombre-a").textContent = nombreA;
    $("final-nombre-b").textContent = nombreB;
    $("nombre-a-display").textContent = nombreA;
    $("nombre-b-display").textContent = nombreB;

    renderTablero();
  }

  function getAttackableIndices(_player: "A" | "B"): Set<number> {
    return new Set(casillas.map((c, i) => c.dueño === null ? i : -1).filter((i) => i >= 0));
  }

  function renderTablero() {
    const countA = casillas.filter((c) => c.dueño === "A").length;
    const countB = casillas.filter((c) => c.dueño === "B").length;
    $("tablero-count-a").textContent = String(countA);
    $("tablero-count-b").textContent = String(countB);

    const attackable = getAttackableIndices(tableroAtacante);
    const gridEl = $("tablero-grid");
    gridEl.innerHTML = "";

    casillas.forEach((casilla, idx) => {
      const btn = document.createElement("button");
      let bgClass = "floor-square-neutral";
      if (casilla.dueño === "A") bgClass = "floor-square-a";
      else if (casilla.dueño === "B") bgClass = "floor-square-b";

      const esAtacable = attackable.has(idx);
      const esDestacado = idx === casillaDuelo;

      btn.className = [
        bgClass,
        "aspect-square rounded flex items-center justify-center text-4xl transition-transform",
        esAtacable ? "floor-square-attackable hover:scale-105 cursor-pointer" : "cursor-default",
        esDestacado ? "scale-105" : "",
      ].filter(Boolean).join(" ");

      btn.textContent = casilla.catEmoji;
      btn.title = casilla.catNombre;
      if (esAtacable) btn.addEventListener("click", () => mostrarPreDuelo(idx));
      gridEl.appendChild(btn);
    });

    const nombreAtacante = jug ? (tableroAtacante === "A" ? jug.A.nombre : jug.B.nombre) : tableroAtacante;
    // Si no hay casillas atacables pero quedan casillas libres (no debería pasar en 3x3
    // porque getAttackableIndices ya devuelve todas las libres), salimos sin recursión.
    if (attackable.size === 0 && countA + countB < 9) {
      $("tablero-instruccion").textContent = `Esperando…`;
      return;
    }
    $("tablero-instruccion").textContent = `${nombreAtacante}, elige una casilla`;
  }

  function mostrarPreDuelo(idx: number) {
    casillaDuelo = idx;
    const casilla = casillas[idx];
    $("preduel-emoji").textContent = casilla.catEmoji;
    $("preduel-nombre-cat").textContent = casilla.catNombre;
    $("preduel-overlay").classList.remove("hidden");
  }

  $("preduel-empezar").addEventListener("click", () => {
    $("preduel-overlay").classList.add("hidden");
    atacarCasilla(casillaDuelo);
  });
  $("preduel-volver").addEventListener("click", () => {
    $("preduel-overlay").classList.add("hidden");
    casillaDuelo = -1;
  });

  async function atacarCasilla(idx: number) {
    mostrar(pLoader);
    $("loader-progreso").textContent = "Cargando…";
    const casilla = casillas[idx];

    if (casilla.items.length === 0) {
      try {
        let raw: ItemFloor[];
        const slug = casilla.catSlug;
        const esMundo = mundoSlugsNombres[slug] !== undefined && cineSlugsNombres[slug] === undefined;
        if (esMundo) {
          raw = await cargarCatalogoMundo(slug);
        } else if (cineSlugsMetaMezcla[slug]) {
          raw = await cargarMezclaCine(cineSlugsMetaMezcla[slug]);
        } else {
          const derivado = cineSlugsDerivados[slug];
          raw = derivado
            ? await cargarCatalogoCinePeli(slug, derivado.baseSlug)
            : await cargarCatalogoCine(slug);
        }
        casilla.items = [...raw].sort(() => Math.random() - 0.5);
        casilla.itemsOffset = 0;
      } catch {
        mostrar(pTablero);
        renderTablero();
        return;
      }
    }

    const off = casilla.itemsOffset;
    items = [...casilla.items.slice(off), ...casilla.items.slice(0, off)];
    categoriaActual = casilla.catNombre;
    $("juego-cat-label").textContent = `${casilla.catEmoji} ${casilla.catNombre}`;
    $("juego-cat-label").classList.remove("opacity-60");
    indice = 0;
    turno = tableroAtacante;
    terminado = false;
    bloqueado = false;
    clearPending();
    pararTimer();
    jug.A.decimas = 450;
    jug.B.decimas = 450;
    $("nombre-a-display").textContent = jug.A.nombre;
    $("nombre-b-display").textContent = jug.B.nombre;

    mostrar(pJuego);
    iniciarTurno();
  }

  function terminarDueloTablero() {
    const sA = jug.A.decimas;
    const sB = jug.B.decimas;
    let ganadorDuelo: "A" | "B" | null = null;
    if (sA > sB) ganadorDuelo = "A";
    else if (sB > sA) ganadorDuelo = "B";

    if (!ganadorDuelo && casillaDuelo >= 0) {
      casillas[casillaDuelo].empateCuenta++;
      if (casillas[casillaDuelo].empateCuenta >= 3) {
        ganadorDuelo = Math.random() < 0.5 ? "A" : "B";
        casillas[casillaDuelo].empateCuenta = 0;
      }
    }

    if (ganadorDuelo && casillaDuelo >= 0) {
      casillas[casillaDuelo].empateCuenta = 0;
      casillas[casillaDuelo].dueño = ganadorDuelo;
    }
    tableroAtacante = tableroAtacante === "A" ? "B" : "A";

    const countA = casillas.filter((c) => c.dueño === "A").length;
    const countB = casillas.filter((c) => c.dueño === "B").length;
    if (countA + countB === 9) { mostrarFinalTablero(); return; }

    jug.A.decimas = 450;
    jug.B.decimas = 450;
    renderTablero();
    mostrar(pTablero);
    document.getElementById("boton-reportar-tablero").classList.remove("hidden");
  }

  function mostrarFinalTablero() {
    const countA = casillas.filter((c) => c.dueño === "A").length;
    const countB = casillas.filter((c) => c.dueño === "B").length;
    trackEv("tablero-completado", { variante: tableroInfantil ? "infantil" : "adultos", marcador: `${countA}-${countB}` });
    const marcador = countA > countB ? `${countA}-${countB}` : `${countB}-${countA}`;
    const ganador = countA > countB
      ? `🥇 Gana ${jug.A.nombre} (${marcador})`
      : countB > countA
      ? `🥇 Gana ${jug.B.nombre} (${marcador})`
      : `¡Empate! ${countA}-${countB} 🤝`;
    $("texto-ganador").textContent = ganador;
    $("final-tiempo-a").textContent = String(countA);
    $("final-tiempo-b").textContent = String(countB);
    $("final-label-a").textContent = "casillas";
    $("final-label-b").textContent = "casillas";
    contarPartida("tablero", `${jug.A.nombre} ${countA}-${countB} ${jug.B.nombre}`);
    mostrar(pFinal);
    lanzarConfeti();
  }

  // ── Estadísticas locales ────────────────────────────────────
  interface Stats {
    partidas: number;
    rapidas: number;
    tableros: number;
    ultimas: string[]; // últimas 10 partidas, texto resumen
  }
  function leerStats(): Stats {
    try {
      const raw = localStorage.getItem("el-suelo:stats-v1");
      if (raw) return { partidas: 0, rapidas: 0, tableros: 0, ultimas: [], ...JSON.parse(raw) };
    } catch {}
    return { partidas: 0, rapidas: 0, tableros: 0, ultimas: [] };
  }
  function contarPartida(tipo: "rapida" | "tablero", resumen: string) {
    const s = leerStats();
    s.partidas++;
    if (tipo === "rapida") s.rapidas++;
    else s.tableros++;
    const fecha = new Date().toISOString().slice(0, 10);
    s.ultimas = [`${fecha} · ${resumen}`, ...s.ultimas].slice(0, 10);
    try { localStorage.setItem("el-suelo:stats-v1", JSON.stringify(s)); } catch {}
  }

  // ── Render ───────────────────────────────────────────────────
  function renderTimers() {
    const sa = Math.max(0, Math.ceil(jug.A.decimas / 10));
    const sb = Math.max(0, Math.ceil(jug.B.decimas / 10));
    $("timer-a").textContent = String(sa);
    $("timer-b").textContent = String(sb);
    $("timer-a").classList.toggle("animate-pulse", turno === "A" && sa <= 10);
    $("timer-b").classList.toggle("animate-pulse", turno === "B" && sb <= 10);
    $("timer-a").classList.toggle("floor-timer-urgent", turno === "A" && sa <= 10);
    $("timer-b").classList.toggle("floor-timer-urgent", turno === "B" && sb <= 10);
    // Botón pasar en rojo cuando poco tiempo (avisa de "menos riesgo cuanto antes")
    const sActual = turno === "A" ? sa : sb;
    $("boton-pasar").classList.toggle("floor-btn-urgent", sActual <= 10);
  }

  const ZONA_BASE = "shrink-0 w-16 flex flex-col items-center justify-center rounded-2xl transition-all";
  function renderTurno() {
    const esA = turno === "A";
    $("zona-a").className = `${ZONA_BASE} ${esA ? "floor-zona-active-a" : "floor-zona-inactive"}`;
    $("zona-b").className = `${ZONA_BASE} ${!esA ? "floor-zona-active-b" : "floor-zona-inactive"}`;
  }

  function mostrarImagen() {
    if (items.length === 0) { terminar(); return; }
    if (indice >= items.length) { terminar(); return; }
    const item = items[indice];
    const img = $("imagen-item") as HTMLImageElement;
    const ph = $("imagen-placeholder");
    img.onload = () => { img.classList.remove("hidden"); ph.classList.add("hidden"); };
    img.onerror = () => { img.classList.add("hidden"); ph.classList.remove("hidden"); (ph as HTMLElement).textContent = "📷"; };
    img.classList.add("hidden");
    ph.classList.remove("hidden");
    (ph as HTMLElement).textContent = "📷";
    img.src = item.imagen;
    img.alt = item.nombre;
    $("overlay-acierto").classList.add("hidden");
    $("overlay-pase").classList.add("hidden");
    $("texto-voz").textContent = "🎤 Escuchando...";
  }

  // ── Vibración (respeta ajuste) ───────────────────────────────
  // Sonidos cortos generados con WebAudio API (sin archivos externos).
  let audioCtx: AudioContext | null = null;
  function getAudioCtx(): AudioContext | null {
    if (!ajustes.sonido) return null;
    try {
      if (!audioCtx) audioCtx = new ((window as any).AudioContext || (window as any).webkitAudioContext)();
      return audioCtx;
    } catch { return null; }
  }
  function tono(freq: number, duracion = 0.08, tipo: OscillatorType = "sine", volumen = 0.15) {
    const ctx = getAudioCtx();
    if (!ctx) return;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = tipo;
    osc.frequency.setValueAtTime(freq, ctx.currentTime);
    gain.gain.setValueAtTime(volumen, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duracion);
    osc.connect(gain).connect(ctx.destination);
    osc.start();
    osc.stop(ctx.currentTime + duracion);
  }
  function sonidoAcierto() {
    tono(880, 0.08, "sine");
    setTimeout(() => tono(1320, 0.12, "sine"), 90);
  }
  function sonidoPase() {
    tono(440, 0.07, "triangle");
    setTimeout(() => tono(330, 0.1, "triangle"), 70);
  }
  function sonidoFin() {
    tono(660, 0.15, "sawtooth", 0.12);
    setTimeout(() => tono(330, 0.25, "sawtooth", 0.12), 160);
  }

  function vibrar(pattern: number | number[]) {
    try {
      if (!ajustes.vibracion) return;
      if (navigator.vibrate) navigator.vibrate(pattern);
    } catch {}
  }

  // ── Turno ────────────────────────────────────────────────────
  let pendingAction: ReturnType<typeof setTimeout> | null = null;
  function clearPending() { if (pendingAction) { clearTimeout(pendingAction); pendingAction = null; } }

  function iniciarTurno() {
    // Si es la primera vez que entra a un duelo, mostrar tutorial corto y pausar
    const tutorialDuelEl = document.getElementById("tutorial-duelo")!;
    if (!localStorage.getItem("el-suelo:tutorial-duelo-v2") && tutorialDuelEl.classList.contains("hidden")) {
      tutorialDuelEl.classList.remove("hidden");
      return;
    }
    bloqueado = false;
    ($("boton-pasar") as HTMLButtonElement).disabled = false;
    clearPending();
    if (items.length === 0) { terminar(); return; }
    if (indice >= items.length) { terminar(); return; }
    renderTurno();
    renderTimers();
    mostrarImagen();
    pararTimer();
    // Timer basado en Date.now() para evitar drift cuando el móvil bloquea
    // pantalla o el navegador ralentiza setInterval en background.
    const decimasInicio = jug[turno].decimas;
    const startMs = Date.now();
    const j = jug[turno];
    tick = setInterval(() => {
      const transcurridoDecimas = Math.floor((Date.now() - startMs) / 100);
      const restantes = Math.max(0, decimasInicio - transcurridoDecimas);
      if (restantes !== j.decimas) {
        j.decimas = restantes;
        renderTimers();
      }
      if (restantes <= 0) {
        bloqueado = true;
        pararTimer();
        pararVoz();
        $("texto-voz").textContent = `⏱️ ¡Se acabó el tiempo de ${j.nombre}!`;
        clearPending();
        pendingAction = setTimeout(terminar, 1200);
      }
    }, 100);
    iniciarReconocedor();
    iniciarVoz();
  }

  function pararTimer() { if (tick) { clearInterval(tick); tick = null; } }
  function pararVoz() { if (reco) { reco.parar(); reco = null; } }

  function iniciarReconocedor() {
    pararVoz();
    if (!navegadorSoportaVoz()) return;
    reco = crearReconocedor({
      onTranscripcion: (texto) => {
        if (bloqueado || terminado) return;
        const item = items[indice];
        if (!item) return;
        $("texto-voz").textContent = `"${texto}"`;
        // Prioridad 1: si lo dicho contiene la respuesta correcta, acierto
        if (aciertoFlexible(texto, item.nombre, categoriaActual, categoriaSlug)) {
          registrarAcierto();
          return;
        }
        // Prioridad 2: comando de voz "paso/pasar" como última palabra de la frase
        // (p.ej. "no lo sé paso", "guepardo paso", "eh... paso")
        const palabras = texto.toLowerCase().trim().replace(/[.,!¡?¿;:]/g, "").split(/\s+/).filter(Boolean);
        const ultima = palabras[palabras.length - 1] || "";
        if (ultima === "paso" || ultima === "pasar" || ultima === "pasa" || ultima === "pasando" || ultima === "siguiente") {
          registrarPase();
        }
      },
      onError: (err) => {
        if (bloqueado || terminado) return;
        const msgs: Record<string, string> = {
          "not-allowed": "Sin permiso de micrófono — actívalo en el navegador",
          "audio-capture": "No se detecta micrófono",
          "network": "Error de red en el reconocedor",
          "aborted": "", "no-speech": "",
        };
        const txt = msgs[err] ?? `Error de voz: ${err}`;
        if (txt) $("texto-voz").textContent = `⚠️ ${txt} — di la respuesta en voz alta`;
      },
      lang: navigator.language || "es-ES",
    });
    reco?.iniciar();
  }

  function iniciarVoz() {
    if (!reco) { $("texto-voz").textContent = "⚠️ Tu navegador no reconoce voz — pulsa Pasar para saltar"; return; }
    reco.resetOffset();
    $("texto-voz").textContent = "🎤 Escuchando...";
  }

  // ── Acciones ────────────────────────────────────────────────
  function registrarAcierto() {
    if (bloqueado) return;
    bloqueado = true;
    vibrar(60);
    sonidoAcierto();
    ($("boton-pasar") as HTMLButtonElement).disabled = true;
    pararTimer();
    const nombre = items[indice].nombre;
    $("overlay-nombre").textContent = nombre;
    $("overlay-acierto").classList.remove("hidden");
    $("texto-voz").textContent = `✓ ¡${nombre}!`;
    indice++;
    renderTimers();
    clearPending();
    pendingAction = setTimeout(cambiarTurno, 1200);
  }

  function registrarPase() {
    if (bloqueado) return;
    bloqueado = true;
    vibrar([40, 40, 40]);
    sonidoPase();
    ($("boton-pasar") as HTMLButtonElement).disabled = true;
    pararTimer();
    const nombre = items[indice].nombre;
    const j = jug[turno];
    j.decimas = Math.max(0, j.decimas - 30);
    indice++;
    renderTimers();
    $("overlay-pase-nombre").textContent = nombre;
    $("overlay-pase").classList.remove("hidden");
    clearPending();
    pendingAction = setTimeout(() => {
      $("overlay-pase").classList.add("hidden");
      if (j.decimas <= 0) {
        $("texto-voz").textContent = `⏱️ ¡Se acabó el tiempo de ${j.nombre}!`;
        pendingAction = setTimeout(terminar, 800);
      } else {
        iniciarTurno();
      }
    }, 1200);
  }

  function cambiarTurno() {
    if (terminado) return;
    turno = turno === "A" ? "B" : "A";
    iniciarTurno();
  }

  function terminar() {
    if (terminado) return;
    terminado = true;
    vibrar([150, 100, 150]);
    sonidoFin();
    pararTimer();
    pararVoz();
    clearPending();
    trackEv("duelo-terminado", { modo: modo, slug: categoriaSlug });
    // Limpiar overlays para no dejarlos visibles al cambiar de pantalla
    $("overlay-acierto").classList.add("hidden");
    $("overlay-pase").classList.add("hidden");

    if (modo === "tablero") {
      if (casillaDuelo >= 0 && casillaDuelo < casillas.length) {
        const c = casillas[casillaDuelo];
        if (c.items.length > 0) c.itemsOffset = (c.itemsOffset + indice) % c.items.length;
      }
      terminarDueloTablero();
      return;
    }

    const sA = Math.max(0, Math.ceil(jug.A.decimas / 10));
    const sB = Math.max(0, Math.ceil(jug.B.decimas / 10));
    $("final-tiempo-a").textContent = `${sA}s`;
    $("final-tiempo-b").textContent = `${sB}s`;
    $("final-label-a").textContent = "tiempo restante";
    $("final-label-b").textContent = "tiempo restante";
    const ganador = sA > sB ? `🥇 Gana ${jug.A.nombre}` : sB > sA ? `🥇 Gana ${jug.B.nombre}` : "¡Empate! 🤝";
    $("texto-ganador").textContent = ganador;
    contarPartida("rapida", `${categoriaActual}: ${jug.A.nombre} ${sA}s vs ${jug.B.nombre} ${sB}s`);
    mostrar(pFinal);
    lanzarConfeti();
  }

  $("boton-pasar").addEventListener("click", registrarPase);

  // Compartir resultado al final
  $("boton-compartir-resultado").addEventListener("click", async () => {
    const ganador = $("texto-ganador").textContent || "";
    const cat = modo === "rapida" ? categoriaActual : "Tablero 3x3";
    const texto = `🎮 El Suelo · ${cat}\n${ganador}\nJuega en ${location.origin}`;
    trackEv("compartir", { tipo: "resultado", modo: modo });
    try {
      if (navigator.share) {
        await navigator.share({ title: "El Suelo", text: texto });
      } else if (navigator.clipboard) {
        await navigator.clipboard.writeText(texto);
        ($("boton-compartir-resultado") as HTMLElement).textContent = "✓ Copiado al portapapeles";
        setTimeout(() => { ($("boton-compartir-resultado") as HTMLElement).textContent = "📤 Compartir resultado"; }, 2000);
      }
    } catch {}
  });

  $("boton-revancha").addEventListener("click", async () => {
    pararVoz();
    if (modo === "tablero") {
      await iniciarPartidaTablero();
    } else {
      // En rápida, llevar a elegir categoría de nuevo
      mostrar(pCategoria);
    }
  });

  $("boton-volver").addEventListener("click", () => {
    // Navegación hacia atrás respetando el orden del flujo
    if (!pBienvenida.classList.contains("hidden")) return;
    if (!pModo.classList.contains("hidden")) { mostrar(pBienvenida); return; }
    const pTabVar = $("pantalla-tablero-variante");
    if (!pTabVar.classList.contains("hidden")) { mostrar(pModo); return; }
    if (!pSetup.classList.contains("hidden")) {
      mostrar(modo === "tablero" ? pTabVar : pModo);
      return;
    }
    if (!pCategoria.classList.contains("hidden")) { mostrar(pSetup); return; }
    // Reto diario: no hay paso intermedio, atrás vuelve a la home y refresca banner
    if (!pRetoIntro.classList.contains("hidden") || !pRetoFinal.classList.contains("hidden")) {
      mostrar(pBienvenida); actualizarBannerReto(); return;
    }
    if (!pRetoJuego.classList.contains("hidden")) {
      pararRetoTick(); pararRetoReco();
      mostrar(pBienvenida); actualizarBannerReto(); return;
    }
    // Desde loader/tablero/juego/final → volver a la pantalla anterior al duelo:
    // - Rápida: a la pantalla de elegir tema (categoría)
    // - Tablero: a elegir modo (no hay paso de categoría)
    pararVoz();
    pararTimer();
    if (modo === "rapida") mostrar(pCategoria);
    else mostrar(pModo);
  });

  function lanzarConfeti() {
    const colores = ["#FF5757", "#FFD93D", "#4ECDC4", "#B084EE", "#95E1D3", "#FF6B9D"];
    const cont = $("confeti");
    cont.innerHTML = "";
    for (let i = 0; i < 60; i++) {
      const t = document.createElement("div");
      const tam = 8 + Math.random() * 10;
      t.style.cssText = `position:absolute;top:-20px;left:${Math.random() * 100}%;width:${tam}px;height:${tam}px;background:${colores[Math.floor(Math.random() * colores.length)]};border:2px solid #1A1A1A;border-radius:${Math.random() > 0.5 ? "50%" : "4px"};animation:confeti ${2 + Math.random() * 2}s ${Math.random() * 1.5}s linear forwards;`;
      cont.appendChild(t);
    }
  }


  // ── Reportar error ────────────────────────────────────────────────────
  const WEBHOOK_REPORTAR = "https://script.google.com/macros/s/AKfycbxO1ttDJ46HP5ftZWIiDBbVDupH3BxLGL0Lr-SU-3aJa1MSSDnz2gz-MLN6RvfzkVUThQ/exec";

  function abrirModalReportar() {
    const modal = document.getElementById("modal-reportar");
    document.getElementById("reportar-cat-label").textContent = "Categoría: " + (categoriaActual || "Categoría desconocida");
    document.querySelectorAll('input[name="tipo-error"]').forEach(r => (r).checked = false);
    document.getElementById("reportar-sugerencia").value = "";
    document.getElementById("reportar-feedback").classList.add("hidden");
    document.getElementById("reportar-falta").classList.add("hidden");
    modal.classList.remove("hidden");
  }
  window.abrirModalReportar = abrirModalReportar;

  document.getElementById("reportar-cancelar").addEventListener("click", () => {
    document.getElementById("modal-reportar").classList.add("hidden");
  });

  document.getElementById("reportar-enviar").addEventListener("click", async () => {
    const sels = Array.from(document.querySelectorAll('input[name="tipo-error"]:checked')).map((r) => r.value);
    const sugerencia = (document.getElementById("reportar-sugerencia").value || "").trim();
    if (sels.length === 0 && !sugerencia) {
      document.getElementById("reportar-falta").classList.remove("hidden");
      return;
    }
    document.getElementById("reportar-falta").classList.add("hidden");
    const btn = document.getElementById("reportar-enviar");
    btn.textContent = "Enviando..."; btn.disabled = true;
    try {
      await fetch(WEBHOOK_REPORTAR, { method: "POST", body: JSON.stringify({
        categoria: categoriaActual || "desconocida",
        elemento: "",
        tipoError: sels.join(" | "),
        sugerencia,
      })});
    } catch {}
    btn.textContent = "Enviar →"; btn.disabled = false;
    document.getElementById("reportar-feedback").classList.remove("hidden");
    setTimeout(() => document.getElementById("modal-reportar").classList.add("hidden"), 1500);
  });

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible" && !bloqueado && !terminado && items.length > 0) {
      reco?.resetOffset();
      $("texto-voz").textContent = "🎤 Escuchando...";
    }
  });

  // ── Link a /multi con feedback de carga ───────────────────────
  const linkMulti = document.getElementById("link-multi");
  if (linkMulti) {
    linkMulti.addEventListener("click", () => {
      linkMulti.textContent = "Cargando…";
      linkMulti.style.opacity = "0.6";
      (linkMulti as HTMLAnchorElement).style.pointerEvents = "none";
    });
  }

  // ── Tutorial (primera visita) ────────────────────────────────
  const TUTORIAL_KEY = "el-suelo:tutorial-visto-v3";
  const tutorialOverlay = document.getElementById("tutorial-overlay")!;
  if (!localStorage.getItem(TUTORIAL_KEY)) {
    tutorialOverlay.classList.remove("hidden");
  }
  document.getElementById("tutorial-ok")!.addEventListener("click", () => {
    localStorage.setItem(TUTORIAL_KEY, "1");
    tutorialOverlay.classList.add("hidden");
  });

  // ── Ajustes ──────────────────────────────────────────────────
  const AJUSTES_KEY = "el-suelo:ajustes-v1";
  const ajustes = (() => {
    try {
      const raw = localStorage.getItem(AJUSTES_KEY);
      if (raw) return { sonido: true, vibracion: true, ...JSON.parse(raw) };
    } catch {}
    return { sonido: true, vibracion: true };
  })();
  function guardarAjustes() { try { localStorage.setItem(AJUSTES_KEY, JSON.stringify(ajustes)); } catch {} }
  (document.getElementById("ajuste-sonido") as HTMLInputElement).checked = ajustes.sonido;
  (document.getElementById("ajuste-vibracion") as HTMLInputElement).checked = ajustes.vibracion;
  document.getElementById("boton-ajustes")!.addEventListener("click", () => {
    document.getElementById("modal-ajustes")!.classList.remove("hidden");
  });
  document.getElementById("ajustes-cerrar")!.addEventListener("click", () => {
    document.getElementById("modal-ajustes")!.classList.add("hidden");
  });
  document.getElementById("ajuste-sonido")!.addEventListener("change", (e) => {
    ajustes.sonido = (e.target as HTMLInputElement).checked;
    guardarAjustes();
  });
  document.getElementById("ajuste-vibracion")!.addEventListener("change", (e) => {
    ajustes.vibracion = (e.target as HTMLInputElement).checked;
    guardarAjustes();
  });
  document.getElementById("ajustes-tutorial")!.addEventListener("click", () => {
    try {
      localStorage.removeItem("el-suelo:tutorial-visto-v3");
      localStorage.removeItem("el-suelo:tutorial-duelo-v2");
    } catch {}
    document.getElementById("modal-ajustes")!.classList.add("hidden");
    document.getElementById("tutorial-overlay")!.classList.remove("hidden");
  });

  // ── Añadir a pantalla de inicio (PWA) ──
  // Android/Chrome: capturamos beforeinstallprompt para invocarlo desde el botón.
  // iOS Safari: no expone API; mostramos modal con instrucciones manuales.
  let pwaPrompt: (Event & { prompt: () => Promise<void>; userChoice: Promise<{ outcome: string }> }) | null = null;
  const btnInstalar = document.getElementById("ajustes-instalar")!;
  const standalone =
    window.matchMedia("(display-mode: standalone)").matches ||
    (window.navigator as Navigator & { standalone?: boolean }).standalone === true;
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) &&
    !(window as Window & { MSStream?: unknown }).MSStream;
  // Solo mostramos el botón si NO está ya instalada
  if (!standalone) btnInstalar.classList.remove("hidden");
  window.addEventListener("beforeinstallprompt", (e) => {
    e.preventDefault();
    pwaPrompt = e as typeof pwaPrompt;
  });
  window.addEventListener("appinstalled", () => {
    btnInstalar.classList.add("hidden");
    pwaPrompt = null;
  });
  btnInstalar.addEventListener("click", async () => {
    const modal = document.getElementById("modal-instalar")!;
    const texto = document.getElementById("instalar-texto")!;
    if (pwaPrompt) {
      try {
        await pwaPrompt.prompt();
        const r = await pwaPrompt.userChoice;
        if (r.outcome === "accepted") btnInstalar.classList.add("hidden");
        pwaPrompt = null;
      } catch {}
      return;
    }
    document.getElementById("modal-ajustes")!.classList.add("hidden");
    if (isIOS) {
      texto.innerHTML = `
        <p>En tu iPhone (Safari):</p>
        <p>1. Pulsa el icono <span style="color:#ffcc00">📤</span> en la barra inferior.</p>
        <p>2. Desliza y elige <strong>"Añadir a pantalla de inicio"</strong>.</p>
        <p>3. Confirma con <strong>Añadir</strong>.</p>
        <p class="text-[#7b9ef5] text-xs pt-2">Si no ves el botón compartir, asegúrate de estar en Safari (no Chrome ni desde otra app).</p>`;
    } else {
      texto.innerHTML = `
        <p>Abre el menú de tu navegador (los tres puntos arriba a la derecha) y elige
        <strong>"Añadir a pantalla de inicio"</strong> o <strong>"Instalar aplicación"</strong>.</p>
        <p class="text-[#7b9ef5] text-xs pt-2">Si no ves la opción, prueba con Chrome o Edge.</p>`;
    }
    modal.classList.remove("hidden");
  });
  document.getElementById("instalar-cerrar")!.addEventListener("click", () => {
    document.getElementById("modal-instalar")!.classList.add("hidden");
  });

  // ── Tutorial del duelo (primera vez que se entra a la pantalla de juego) ──
  const TUTORIAL_DUELO_KEY = "el-suelo:tutorial-duelo-v2";
  const tutorialDuelo = document.getElementById("tutorial-duelo")!;
  document.getElementById("tutorial-duelo-ok")!.addEventListener("click", () => {
    localStorage.setItem(TUTORIAL_DUELO_KEY, "1");
    tutorialDuelo.classList.add("hidden");
    // Reanudar el inicio del turno que quedó pausado
    iniciarTurno();
  });

  // ─── Reto diario ───────────────────────────────────────────────
  // Estado del reto que se va a jugar/se ha jugado hoy
  let retoSlug = "";
  let retoNombre = "";
  let retoEmoji = "";
  let retoItems: ItemFloor[] = [];
  let retoIndice = 0;
  let retoAciertos = 0;
  let retoMsRestantes = 0;
  let retoTickId: ReturnType<typeof setInterval> | null = null;
  let retoReco: ReconocedorVoz | null = null;
  let retoBloqueado = false;

  function pararRetoReco() { if (retoReco) { retoReco.parar(); retoReco = null; } }
  function pararRetoTick() { if (retoTickId) { clearInterval(retoTickId); retoTickId = null; } }

  // Banner en pantalla bienvenida: ya jugado → mostrar score; pendiente → mostrar categoría del día
  async function actualizarBannerReto() {
    const banner = $("banner-reto");
    const txt = $("banner-reto-texto");
    const yaJugado = leerResultadoHoy();
    if (yaJugado) {
      txt.textContent = `✅ Hoy: ${yaJugado.aciertos}/${yaJugado.tope} · ${yaJugado.catEmoji} ${yaJugado.catNombre}`;
      banner.classList.remove("hidden");
      return;
    }
    // Categoría del día — del pool publicado (mismo que tablero/rápida)
    try {
      const pool = await cargarPublicadas();
      const slug = categoriaRetoHoy(pool);
      if (!slug) { banner.classList.add("hidden"); return; }
      const nombre = (mundoSlugsNombres[slug] ?? cineSlugsNombres[slug] ?? slug);
      const emoji = (mundoSlugsEmoji[slug] ?? "🎬");
      txt.textContent = `🎯 Reto de hoy: ${emoji} ${nombre} →`;
      banner.classList.remove("hidden");
      banner.dataset.slug = slug;
      banner.dataset.nombre = nombre;
      banner.dataset.emoji = emoji;
    } catch { banner.classList.add("hidden"); }
  }

  $("banner-reto").addEventListener("click", async () => {
    const yaJugado = leerResultadoHoy();
    if (yaJugado) { mostrarRetoFinal(yaJugado); return; }
    const banner = $("banner-reto");
    const slug = banner.dataset.slug;
    const nombre = banner.dataset.nombre;
    const emoji = banner.dataset.emoji;
    if (!slug || !nombre || !emoji) return;
    retoSlug = slug; retoNombre = nombre; retoEmoji = emoji;
    $("reto-intro-emoji").textContent = emoji;
    $("reto-intro-cat").textContent = nombre;
    $("reto-fecha").textContent = formatearFecha(diaHoy());
    mostrar(pRetoIntro);
  });

  function formatearFecha(iso: string): string {
    const [, m, d] = iso.split("-");
    const mes = ["enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre"][Number(m) - 1];
    return `${Number(d)} de ${mes}`;
  }

  $("reto-empezar").addEventListener("click", async () => {
    trackEv("reto-iniciado", { categoria: retoSlug });
    // Cargar items de la categoría del reto y deducir el subset
    mostrar(pLoader);
    $("loader-progreso").textContent = "Preparando el reto...";
    try {
      const esMundo = mundoSlugsNombres[retoSlug] !== undefined && cineSlugsNombres[retoSlug] === undefined;
      const raw = esMundo
        ? await cargarCatalogoMundo(retoSlug)
        : cineSlugsMetaMezcla[retoSlug]
        ? await cargarMezclaCine(cineSlugsMetaMezcla[retoSlug])
        : cineSlugsDerivados[retoSlug]
        ? await cargarCatalogoCinePeli(retoSlug, cineSlugsDerivados[retoSlug].baseSlug)
        : await cargarCatalogoCine(retoSlug);
      retoItems = subsetReto(raw, retoSlug);
      retoIndice = 0;
      retoAciertos = 0;
      retoMsRestantes = TIEMPO_RETO_S * 1000;
      $("reto-juego-cat").textContent = `${retoEmoji} ${retoNombre}`;
      $("reto-juego-aciertos").textContent = `0 / ${retoItems.length}`;
      $("reto-juego-tiempo").textContent = TIEMPO_RETO_S.toFixed(1);
      mostrar(pRetoJuego);
      arrancarRetoTick();
      mostrarImagenReto();
      arrancarRetoVoz();
    } catch (e) {
      const errEl = $("error-categoria");
      errEl.textContent = "No se pudo cargar la categoría del reto.";
      errEl.classList.remove("hidden");
      mostrar(pBienvenida);
    }
  });

  function arrancarRetoTick() {
    pararRetoTick();
    const inicio = Date.now();
    const restanteInicial = retoMsRestantes;
    retoTickId = setInterval(() => {
      const transcurrido = Date.now() - inicio;
      retoMsRestantes = Math.max(0, restanteInicial - transcurrido);
      $("reto-juego-tiempo").textContent = (retoMsRestantes / 1000).toFixed(1);
      if (retoMsRestantes <= 0) finalizarReto();
    }, 100);
  }

  function mostrarImagenReto() {
    if (retoIndice >= retoItems.length) { finalizarReto(); return; }
    const item = retoItems[retoIndice];
    const img = $("reto-imagen") as HTMLImageElement;
    const ph = $("reto-imagen-ph");
    img.onload = () => { img.classList.remove("hidden"); ph.classList.add("hidden"); };
    img.onerror = () => { img.classList.add("hidden"); ph.classList.remove("hidden"); };
    img.classList.add("hidden");
    ph.classList.remove("hidden");
    img.src = item.imagen;
  }

  function arrancarRetoVoz() {
    pararRetoReco();
    if (!navegadorSoportaVoz()) return;
    retoReco = crearReconocedor({
      onTranscripcion: (texto) => {
        if (retoBloqueado || retoMsRestantes <= 0) return;
        const item = retoItems[retoIndice];
        if (!item) return;
        $("reto-texto-voz").textContent = `"${texto}"`;
        if (aciertoFlexible(texto, item.nombre, retoNombre, retoSlug)) {
          retoAcierto();
          return;
        }
        const palabras = texto.toLowerCase().trim().replace(/[.,!¡?¿;:]/g, "").split(/\s+/).filter(Boolean);
        const ultima = palabras[palabras.length - 1] || "";
        if (ultima === "paso" || ultima === "pasar" || ultima === "pasa" || ultima === "siguiente") {
          retoPaso();
        }
      },
    });
    retoReco?.iniciar();
  }

  function retoAcierto() {
    retoAciertos++;
    $("reto-juego-aciertos").textContent = `${retoAciertos} / ${retoItems.length}`;
    sonidoAcierto();
    if (ajustes.vibracion) try { navigator.vibrate?.(30); } catch {}
    retoIndice++;
    mostrarImagenReto();
  }

  function retoPaso() {
    if (retoBloqueado) return;
    retoBloqueado = true;
    // Penalización: restar PENALIZACION_PASE_S segundos del tiempo restante
    retoMsRestantes = Math.max(0, retoMsRestantes - PENALIZACION_PASE_S * 1000);
    pararRetoTick();
    sonidoPase();
    if (ajustes.vibracion) try { navigator.vibrate?.([30, 30, 30]); } catch {}
    // Mostrar la respuesta del item que se pasa durante 900 ms (timer pausado:
    // ya cuesta -3s, no penalizamos doblemente el tiempo de aprender).
    const nombre = retoItems[retoIndice].nombre.replace(/\s*\([^)]+\)\s*$/, "");
    $("reto-overlay-nombre").textContent = nombre;
    $("reto-overlay-respuesta").classList.remove("hidden");
    ($("reto-pasar") as HTMLButtonElement).disabled = true;
    setTimeout(() => {
      $("reto-overlay-respuesta").classList.add("hidden");
      ($("reto-pasar") as HTMLButtonElement).disabled = false;
      retoBloqueado = false;
      retoIndice++;
      if (retoMsRestantes <= 0) { finalizarReto(); return; }
      mostrarImagenReto();
      arrancarRetoTickConRestante(retoMsRestantes);
    }, 900);
  }

  function arrancarRetoTickConRestante(ms: number) {
    const inicio = Date.now();
    retoTickId = setInterval(() => {
      const transcurrido = Date.now() - inicio;
      retoMsRestantes = Math.max(0, ms - transcurrido);
      $("reto-juego-tiempo").textContent = (retoMsRestantes / 1000).toFixed(1);
      if (retoMsRestantes <= 0) finalizarReto();
    }, 100);
  }

  $("reto-pasar").addEventListener("click", () => {
    if (retoMsRestantes <= 0) return;
    retoPaso();
  });

  function finalizarReto() {
    pararRetoTick();
    pararRetoReco();
    const resultado: ResultadoReto = {
      fecha: diaHoy(),
      slug: retoSlug,
      catNombre: retoNombre,
      catEmoji: retoEmoji,
      aciertos: retoAciertos,
      tope: retoItems.length,
    };
    trackEv("reto-completado", { categoria: retoSlug, aciertos: retoAciertos, tope: retoItems.length });
    guardarResultado(resultado);
    sonidoFin();
    mostrarRetoFinal(resultado);
  }

  function mostrarRetoFinal(r: ResultadoReto) {
    $("reto-final-fecha").textContent = formatearFecha(r.fecha);
    $("reto-final-emoji").textContent = r.catEmoji;
    $("reto-final-cat").textContent = r.catNombre;
    $("reto-final-score").textContent = String(r.aciertos);
    $("reto-final-de").textContent = `de ${r.tope}`;
    // Histórico
    const hist = leerHistorial().filter((h) => h.fecha !== r.fecha).slice(0, 5);
    if (hist.length > 0) {
      $("reto-historial").classList.remove("hidden");
      const lista = $("reto-historial-lista");
      lista.innerHTML = hist.map((h) => {
        const [, m, d] = h.fecha.split("-");
        const mes = ["ene","feb","mar","abr","may","jun","jul","ago","sep","oct","nov","dic"][Number(m) - 1];
        return `<div class="flex items-center justify-between text-xs font-titulo px-3 py-1.5" style="background:#0a1628;border-radius:4px"><span class="text-[#a8c5ff]">${Number(d)} ${mes} · ${h.catEmoji} ${h.catNombre}</span><span class="text-[#ffcc00] font-bold">${h.aciertos}/${h.tope}</span></div>`;
      }).join("");
    } else {
      $("reto-historial").classList.add("hidden");
    }
    mostrar(pRetoFinal);
  }

  $("reto-compartir").addEventListener("click", async () => {
    const r = leerResultadoHoy();
    if (!r) return;
    const dominio = location.host;
    const texto = textoCompartir(r, dominio);
    trackEv("compartir", { tipo: "reto", categoria: r.slug, aciertos: r.aciertos });
    try {
      if (navigator.share) await navigator.share({ title: "El Suelo · Reto del día", text: texto });
      else { await navigator.clipboard.writeText(texto); $("reto-compartir").textContent = "✓ Copiado"; }
    } catch {}
  });

  // Inicializar banner al cargar la página
  actualizarBannerReto();
</script>
